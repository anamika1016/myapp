  transition: opacity 0.4s cubic-bezier(.4,0,.2,1), transform 0.4s cubic-bezier(.4,0,.2,1);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem 1.4rem;
}
.action-bar--hidden { opacity: 0; transform: translateY(16px); pointer-events: none; }
.action-bar--visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
.action-bar__label { font-size: 0.88rem; color: #6b7280; font-weight: 500; }
.action-bar__btns { display: flex; align-items: center; gap: 0.65rem; }

/* Close button */
.btn-close {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  background: #f3f4f6;
  color: #374151;
  font-weight: 700;
  padding: 0.5rem 1.2rem;
  border-radius: 0.6rem;
  font-size: 0.875rem;
  text-decoration: none;
  border: 1.5px solid #e5e7eb;
  transition: background 0.15s;
}
.btn-close:hover { background: #e5e7eb; }

/* Complete button */
.btn-complete {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-weight: 700;
  padding: 0.5rem 1.4rem;
  border-radius: 0.6rem;
  font-size: 0.875rem;
  border: none;
  cursor: pointer;
  transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
}
.btn-complete--disabled {
  background: #f3f4f6;
  color: #9ca3af;
  border: 1.5px solid #e5e7eb;
  cursor: not-allowed;
}
.btn-complete--ready {
  background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  color: #fff;
  box-shadow: 0 3px 12px rgba(34,197,94,0.30);
}
.btn-complete--ready:hover {
  background: linear-gradient(135deg, #15803d 0%, #16a34a 100%);
  transform: translateY(-1px);
  box-shadow: 0 5px 16px rgba(34,197,94,0.36);
}
</style>