
<div class="mb-4">
  <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
</div>

