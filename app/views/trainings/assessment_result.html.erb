<div class="main-content ml-64 w-auto px-6 py-8">
  <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
    <!-- Header -->
    <div class="bg-gray-50 border-b border-gray-200 px-8 py-10 items-center text-center relative">
      <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">Assessment Completed 🎉</h1>
      <p class="text-gray-600 mt-3 text-lg">Here is your performance for <strong class="text-gray-800 underline decoration-blue-500 decoration-2 underline-offset-4"><%= @training.title %></strong></p>
      
      <div class="mt-10 flex flex-wrap justify-center gap-6">
        <div class="bg-white px-8 py-5 rounded-2xl shadow-sm border border-gray-100 min-w-[160px] transform hover:scale-105 transition-transform">
           <div class="text-5xl font-black text-blue-600 mb-2"><%= @total %></div>
           <div class="text-sm font-bold text-gray-400 uppercase tracking-widest mt-1">Questions</div>
        </div>
        
        <div class="bg-white px-8 py-5 rounded-2xl shadow-sm border border-green-100 min-w-[160px] transform hover:scale-105 transition-transform">
           <div class="text-5xl font-black text-green-500 mb-2"><%= @score %></div>
           <div class="text-sm font-bold text-green-600 uppercase tracking-widest mt-1">Correct</div>
        </div>
        
        <div class="bg-white px-8 py-5 rounded-2xl shadow-sm border border-red-100 min-w-[160px] transform hover:scale-105 transition-transform">
           <div class="text-5xl font-black text-red-500 mb-2"><%= @total - @score %></div>
           <div class="text-sm font-bold text-red-600 uppercase tracking-widest mt-1">Incorrect</div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="p-8 md:p-12">
      <% if @results.any? %>
        <h2 class="text-2xl font-bold text-gray-800 mb-8 border-b border-gray-200 pb-4 inline-block">Detailed Review</h2>
        <div class="space-y-8">
          <% @results.each_with_index do |res, index| %>
            <div class="p-8 rounded-2xl border <%= res[:is_correct] ? 'bg-green-50/50 border-green-200' : 'bg-red-50/50 border-red-200' %> shadow-sm hover:shadow-md transition-shadow">
              <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-start gap-5">
                <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-xl text-white text-base shadow-sm font-black <%= res[:is_correct] ? 'bg-green-500 shadow-green-500/40' : 'bg-red-500 shadow-red-500/40' %>">
                   <%= index + 1 %>
                </span>
                <span class="pt-1.5 leading-relaxed"><%= res[:question] %></span>
              </h3>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 pt-6 border-t <%= res[:is_correct] ? 'border-green-200/60' : 'border-red-200/60' %>">
                <div>
                  <span class="text-xs font-bold text-gray-500 block mb-3 uppercase tracking-wider">Your Answer</span>
                  <% if res[:user_answer].present? %>
                    <div class="px-5 py-4 bg-white rounded-xl border flex items-center gap-3 font-semibold shadow-sm text-base <%= res[:is_correct] ? 'text-green-700 border-green-200' : 'text-red-700 border-red-200' %>">
                      <% if res[:is_correct] %>
                        <svg class="w-6 h-6 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                      <% else %>
                        <svg class="w-6 h-6 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                      <% end %>
                      <span class="break-words"><%= res[:user_answer] %></span>
                    </div>
                  <% else %>
                    <div class="px-5 py-4 bg-gray-100 rounded-xl border border-gray-200 flex items-center gap-3 font-medium text-gray-500 italic shadow-sm text-base">
                      <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      No Answer
                    </div>
                  <% end %>
                </div>
                
                <% unless res[:is_correct] %>
                <div>
                  <span class="text-xs font-bold text-gray-500 block mb-3 uppercase tracking-wider">Correct Answer</span>
                  <div class="px-5 py-4 bg-white rounded-xl border border-green-200 flex items-center gap-3 font-semibold shadow-sm text-green-700 text-base">
                    <svg class="w-6 h-6 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="break-words"><%= res[:correct_answer] %></span>
                  </div>
                </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="mt-14 flex flex-wrap justify-center gap-6 border-t border-gray-100 pt-10 pb-4">
        <%= link_to certificate_training_path(@training, format: :pdf), class: "bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-10 rounded-xl shadow-[0_4px_14px_0_rgba(22,163,74,0.39)] transition-all transform hover:-translate-y-1 hover:shadow-[0_6px_20px_rgba(22,163,74,0.23)] text-lg flex items-center gap-3", target: "_blank" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Download Certificate
        <% end %>
        
        <%= link_to trainings_path, class: "bg-white hover:bg-gray-50 text-gray-800 font-bold py-4 px-10 rounded-xl shadow-sm transition-all transform hover:-translate-y-1 hover:shadow-md text-lg flex items-center gap-3 border border-gray-300" do %>
          <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Trainings
        <% end %>
      </div>
    </div>
  </div>
</div>
