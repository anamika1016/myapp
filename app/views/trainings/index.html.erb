<div class="main-content ml-64 w-auto px-8 py-10" style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); min-height: 100vh; font-family: 'Georgia', serif;">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap');

    .trainings-wrap { font-family: 'DM Sans', sans-serif; }
    .trainings-wrap h2 { font-family: 'Playfair Display', serif; }

    .train-card {
      background: #fff;
      border-radius: 20px;
      border: 1px solid #e8edf3;
      padding: 22px;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.22s, transform 0.22s;
      position: relative;
      overflow: hidden;
    }
    .train-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #16a34a, #22c55e, #4ade80);
      opacity: 0;
      transition: opacity 0.22s;
    }
    .train-card:hover { box-shadow: 0 12px 40px rgba(22,163,74,0.12); transform: translateY(-3px); }
    .train-card:hover::before { opacity: 1; }
    .train-card.inactive { opacity: 0.65; }

    .badge-active {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      background: #f0fdf4; color: #166534; border: 1px solid #86efac;
      padding: 3px 10px; border-radius: 99px;
    }
    .badge-inactive {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      background: #f1f5f9; color: #000; border: 1px solid #cbd5e1;
      padding: 3px 10px; border-radius: 99px;
    }
    .dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }

    .duration-chip {
      font-size: 11px; color: #000; display: flex; align-items: center; gap: 4px;
      background: #f8fafc; border: 1px solid #e2e8f0; padding: 3px 9px; border-radius: 8px;
    }

    .card-title { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: #000; margin: 10px 0 6px; line-height: 1.35; }
    .card-meta { font-size: 11.5px; color: #333; display: flex; align-items: center; gap: 6px; margin-bottom: 16px; }

    .btn-view    { font-size: 11.5px; font-weight: 600; color: #000; background: #f1f5f9; padding: 6px 13px; border-radius: 10px; text-decoration: none; transition: background 0.15s; }
    .btn-view:hover { background: #e2e8f0; }
    .btn-edit    { font-size: 11.5px; font-weight: 600; color: #000; background: #dcfce7; padding: 6px 13px; border-radius: 10px; text-decoration: none; transition: background 0.15s; border: 1px solid #86efac; }
    .btn-edit:hover { background: #bbf7d0; }
    .btn-deactivate { font-size: 11.5px; font-weight: 700; color: #000; background: #fef9c3; padding: 6px 13px; border-radius: 10px; border: 1px solid #fde047; cursor: pointer; transition: background 0.15s; }
    .btn-deactivate:hover { background: #fef08a; }
    .btn-activate   { font-size: 11.5px; font-weight: 700; color: #000; background: #dcfce7; padding: 6px 13px; border-radius: 10px; border: 1px solid #86efac; cursor: pointer; transition: background 0.15s; }
    .btn-activate:hover { background: #bbf7d0; }
    .btn-delete  { font-size: 11.5px; font-weight: 700; color: #000; background: #fee2e2; padding: 6px 13px; border-radius: 10px; border: 1px solid #fca5a5; cursor: pointer; transition: background 0.15s; margin-left: auto; }
    .btn-delete:hover { background: #fecaca; }

    .btn-start {
      width: 100%; text-align: center; background: linear-gradient(135deg, #16a34a, #15803d);
      color: #fff; font-size: 12px; font-weight: 700; padding: 10px; border-radius: 13px;
      text-decoration: none; display: block; letter-spacing: 0.03em;
      box-shadow: 0 4px 14px rgba(22,163,74,0.25); transition: box-shadow 0.2s, transform 0.2s;
    }
    .btn-start:hover { box-shadow: 0 6px 20px rgba(22,163,74,0.35); transform: translateY(-1px); }

    .btn-view-again { font-size: 11px; color: #333; text-decoration: underline; text-underline-offset: 3px; margin-left: auto; }
    .btn-view-again:hover { color: #000; }

    .completed-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #f0fdf4; color: #000; padding: 7px 13px;
      border-radius: 10px; font-size: 11.5px; font-weight: 700; border: 1px solid #86efac;
    }

    .filter-bar {
      background: #fff; border-radius: 16px; border: 1px solid #e8edf3;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      padding: 14px 18px; display: flex; align-items: center; gap: 10px; margin-bottom: 28px; flex-wrap: wrap;
    }
    .filter-select {
      border: 1px solid #e2e8f0; background: #f8fafc; color: #000;
      font-size: 13px; padding: 7px 13px; border-radius: 10px;
      outline: none; font-family: 'DM Sans', sans-serif; transition: border-color 0.15s;
    }
    .filter-select:focus { border-color: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,0.12); }
    .filter-btn {
      background: linear-gradient(135deg, #16a34a, #15803d); color: #fff;
      font-size: 12.5px; font-weight: 700; padding: 8px 20px; border-radius: 10px;
      border: none; cursor: pointer; font-family: 'DM Sans', sans-serif;
      box-shadow: 0 3px 10px rgba(22,163,74,0.2); transition: box-shadow 0.15s;
    }
    .filter-btn:hover { box-shadow: 0 5px 16px rgba(22,163,74,0.32); }

    .upload-btn {
      display: inline-flex; align-items: center; gap: 7px;
      background: linear-gradient(135deg, #166534, #15803d); color: #fff;
      padding: 10px 20px; border-radius: 13px; font-size: 13px; font-weight: 700;
      text-decoration: none; font-family: 'DM Sans', sans-serif;
      box-shadow: 0 4px 15px rgba(22,101,52,0.22); transition: box-shadow 0.2s, transform 0.2s;
    }
    .upload-btn:hover { box-shadow: 0 6px 22px rgba(22,101,52,0.32); transform: translateY(-1px); }

    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #333; margin-bottom: 4px; font-family: 'DM Sans', sans-serif; }
    .section-heading { font-size: 30px; font-weight: 700; color: #000; letter-spacing: -0.02em; }

    .divider { border: none; border-top: 1px solid #f1f5f9; margin: 14px 0; }

    .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
    @media (max-width: 1100px) { .cards-grid { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 700px)  { .cards-grid { grid-template-columns: 1fr; } }
  </style>

  <div class="trainings-wrap">

    <!-- HEADER ROW -->
    <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom: 28px;">
      <div>
        <p class="section-label">Learning &amp; Development</p>
        <h2 class="section-heading">Trainings</h2>
      </div>
      <% if current_user.role == "hod" %>
        <%= link_to new_training_path, class: "upload-btn" do %>
          <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Upload New Training
        <% end %>
      <% end %>
    </div>

    <!-- FILTER BAR -->
    <%= form_with url: trainings_path, method: :get, local: true do %>
      <div class="filter-bar">
        <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;color:#94a3b8;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
        </svg>
        <span style="font-size:13px;font-weight:600;color:#000;">Filter by:</span>

        <%= select_tag :month,
              options_for_select(Date::MONTHNAMES.compact.each_with_index.map { |m,i| [m,i+1] }, params[:month]),
              include_blank: "All Months",
              class: "filter-select" %>

        <%= select_tag :year,
              options_for_select((2025..2030).to_a, params[:year]),
              include_blank: "All Years",
              class: "filter-select" %>

        <%= select_tag :training_id,
              options_from_collection_for_select(Training.order(:title), :id, :title, params[:training_id]),
              include_blank: "All Training Titles",
              class: "filter-select" %>

        <%= submit_tag "Apply Filter", class: "filter-btn" %>
      </div>
    <% end %>

    <!-- TRAINING CARDS GRID -->
    <div class="cards-grid">
      <% @trainings.each do |training| %>
        <div class="train-card <%= !training.status ? 'inactive' : '' %>">

          <!-- Badge Row -->
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <% if training.status %>
              <span class="badge-active">
                <span class="dot" style="background:#10b981;"></span>Active
              </span>
            <% else %>
              <span class="badge-inactive">
                <span class="dot" style="background:#94a3b8;"></span>Inactive
              </span>
            <% end %>
            <span class="duration-chip">
              <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= training.duration %> min
            </span>
          </div>

          <!-- Title -->
          <h3 class="card-title"><%= training.title %></h3>

          <!-- Meta -->
          <div class="card-meta">
            <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <%= training.month.present? ? training.month_name : "No Month" %> <%= training.year %>
            <span style="color:#aaa;">•</span>
            <%= training.created_at.strftime("%d %b %Y") %>
          </div>

          <hr class="divider" style="margin-top:auto;">

          <!-- Actions -->
          <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            <% if current_user.role == "hod" %>
              <%= link_to "View", training_path(training), class: "btn-view" %>
              <%= link_to "Edit", edit_training_path(training), class: "btn-edit" %>

              <%= button_to toggle_status_training_path(training), method: :patch,
                    class: training.status ? "btn-deactivate" : "btn-activate" do %>
                <%= training.status ? "Deactivate" : "Activate" %>
              <% end %>

              <%= button_to training_path(training), method: :delete,
                    data: { confirm: "Are you sure?" }, class: "btn-delete" do %>
                Delete
              <% end %>

            <% else %>
              <% progress = training.user_training_progresses.find { |p| p.user_id == current_user.id } %>
              <% if progress&.status == "completed" %>
                <div style="display:flex; align-items:center; gap:8px; width:100%;">
                  <span class="completed-badge">✅ Completed</span>
                  <div style="margin-left: auto; display: flex; gap: 10px; align-items: center;">
                    <%= link_to "View Again", training_path(training), class: "btn-view-again" %>
                    <% if current_user.role == "employee" %>
                      <%= link_to certificate_training_path(training, format: :pdf), target: "_blank", class: "btn-view-again", style: "color: #16a34a; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 4px;" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        View Certificate
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <%= link_to training_path(training), class: "btn-start" do %>
                  Start Training →
                <% end %>
              <% end %>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

  </div>
</div>