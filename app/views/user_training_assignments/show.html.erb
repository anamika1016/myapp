<div class="main-content ml-64 w-auto px-8 py-10" style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); min-height: 100vh; font-family: 'Georgia', serif;">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap');

    .uta-show-wrap { font-family: 'DM Sans', sans-serif; }
    .uta-show-wrap h2 { font-family: 'Playfair Display', serif; }

    .back-btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12.5px; font-weight: 600; color: #475569;
      background: #f1f5f9; border: 1px solid #e2e8f0;
      padding: 7px 14px; border-radius: 10px; text-decoration: none;
      transition: background 0.15s;
    }
    .back-btn:hover { background: #e2e8f0; color: #000; }

    .emp-info-box {
      background: #fff;
      border: 1px solid #e8edf3;
      border-radius: 16px;
      padding: 22px;
      display: flex; align-items: center; gap: 20px;
      margin: 20px 0 30px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .emp-avatar {
      width: 60px; height: 60px; border-radius: 15px;
      background: linear-gradient(135deg, #16a34a, #15803d);
      display: flex; align-items: center; justify-content: center;
    }
    .emp-avatar svg { width: 30px; height: 30px; stroke: #fff; }
    .emp-name  { font-size: 18px; font-weight: 700; color: #111; }
    .emp-meta  { font-size: 13px; color: #64748b; margin-top: 3px; }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: #fff; border-radius: 15px; padding: 18px;
      border: 1px solid #e8edf3; text-align: center;
    }
    .stat-val { font-size: 24px; font-weight: 800; color: #16a34a; display: block; }
    .stat-label { font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }

    .progress-table-wrap {
      background: #fff;
      border-radius: 18px;
      border: 1px solid #e8edf3;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .progress-table { width: 100%; border-collapse: collapse; }
    .progress-table th {
      background: #f8fafc; text-align: left; padding: 14px 20px;
      font-size: 12px; font-weight: 700; color: #475569;
      text-transform: uppercase; letter-spacing: 0.05em;
      border-bottom: 2px solid #f1f5f9;
    }
    .progress-table td { padding: 16px 20px; border-bottom: 1px solid #f1f5f9; font-size: 13.5px; }
    .progress-table tr:last-child td { border-bottom: none; }

    .status-badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 700;
      padding: 4px 10px; border-radius: 20px;
    }
    .status-completed { background: #dcfce7; color: #166534; }
    .status-started   { background: #fef9c3; color: #854d0e; }
    .status-pending   { background: #f1f5f9; color: #64748b; }

    .time-val { font-family: monospace; font-weight: 600; color: #1e293b; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }
  </style>

  <div class="uta-show-wrap">

    <!-- Back button -->
    <%= link_to user_training_assignments_path, class: "back-btn" do %>
      <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Employees
    <% end %>

    <!-- Header -->
    <div style="margin-top:20px;">
      <p style="font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#333; margin-bottom:4px;">Employee Progress Report</p>
      <h2 style="font-size:30px; font-weight:700; color:#000; letter-spacing:-0.02em;">Training Completion Details</h2>
    </div>

    <!-- Employee Profile -->
    <div class="emp-info-box">
      <div class="emp-avatar">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div>
        <div class="emp-name"><%= @employee.employee_name %></div>
        <div class="emp-meta">
          <%= @employee.employee_email %> &nbsp;·&nbsp; Code: <%= @employee.employee_code %>
          <% if @employee.user %>
             &nbsp;·&nbsp; <span style="color:#16a34a; font-weight:700;">Login Active</span>
          <% end %>
        </div>
      </div>
      <div style="margin-left: auto;">
         <%= link_to edit_user_training_assignment_path(@employee.id), style: "font-size: 13px; color: #16a34a; font-weight: 700; text-decoration: none; border: 1px solid #16a34a; padding: 8px 16px; border-radius: 10px;" do %>
           Manage Assignments
         <% end %>
      </div>
    </div>

    <!-- Stats Summary -->
    <% 
      assigned = @assigned_trainings.size
      completed = @progress_map.values.select { |p| p.status == 'completed' }.size
      pending = assigned - completed
    %>
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-val"><%= assigned %></span>
        <span class="stat-label">Assigned</span>
      </div>
      <div class="stat-card" style="background: #f0fdf4; border-color: #bbf7d0;">
        <span class="stat-val" style="color: #15803d;"><%= completed %></span>
        <span class="stat-label">Completed</span>
      </div>
      <div class="stat-card">
        <span class="stat-val" style="color: #475569;"><%= pending %></span>
        <span class="stat-label">Remaining</span>
      </div>
    </div>

    <!-- Detailed Progress Table Grouped by Month -->
    <% @assigned_trainings.group_by { |t| [t.year, t.month] }.sort.reverse.each do |(year, month), month_trainings| %>
      <div style="margin-bottom: 30px;">
        <div style="display: flex; align-items: center; justify-content: space-between; background: #f8fafc; padding: 10px 20px; border: 1px solid #e8edf3; border-bottom: none; border-radius: 12px 12px 0 0;">
          <h3 style="font-size: 16px; font-weight: 700; color: #1e293b;">
            <%= Date::MONTHNAMES[month] %> <%= year %>
          </h3>
          
          <% 
            total_in_db = Training.where(year: year, month: month)
            all_done = total_in_db.any? && total_in_db.all? do |t| 
              prog = @progress_map[t.id]
              prog&.status == 'completed' && (prog.time_spent.to_i >= t.duration.to_i)
            end
          %>
          
          <% if all_done %>
            <%= link_to monthly_certificate_trainings_path(year: year, month: month, user_id: @employee.user_id, format: :pdf), target: "_blank", style: "background: #16a34a; color: #fff; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; text-decoration: none; display: flex; align-items: center; gap: 5px;" do %>
               <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
               </svg>
               Download Monthly Certificate
            <% end %>
          <% else %>
            <span style="font-size: 11px; font-weight: 600; color: #64748b;">
              <% 
                valid_completed = total_in_db.select do |t| 
                  prog = @progress_map[t.id]
                  prog&.status == 'completed' && (prog.time_spent.to_i >= t.duration.to_i)
                end.size
              %>
              <%= valid_completed %> / <%= total_in_db.size %> Total PPTs Completed (with required time)
            </span>
          <% end %>
        </div>

        <div class="progress-table-wrap" style="border-radius: 0 0 18px 18px;">
          <table class="progress-table">
            <thead>
              <tr>
                <th style="width: 35%;">Training Title</th>
                <th style="width: 15%;">Duration</th>
                <th style="width: 15%;">Status</th>
                <th style="width: 15%;">Time Spent</th>
                <th style="width: 20%;">Completion</th>
              </tr>
            </thead>
            <tbody>
              <% month_trainings.each do |training| %>
                <% progress = @progress_map[training.id] %>
                <tr>
                  <td style="font-weight: 700;">
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <%= training.title %>
                      <%= link_to training_path(training), target: "_blank", style: "color: #64748b; font-size: 11px; font-weight: 600; text-decoration: underline;" do %>
                        View Materials (PDF)
                      <% end %>
                    </div>
                  </td>
                  <td><%= training.duration >= 60 ? "#{training.duration / 60} mins" : "#{training.duration} secs" %></td>
                  <td>
                    <% if progress&.status == 'completed' %>
                      <span class="status-badge status-completed">✅ Done</span>
                    <% elsif progress&.status == 'started' %>
                      <span class="status-badge status-started">⏳ Doing</span>
                    <% else %>
                      <span class="status-badge status-pending">⚪ Pending</span>
                    <% end %>
                  </td>
                  <td>
                    <% if progress&.time_spent.present? %>
                      <span class="time-val"><%= (progress.time_spent / 60) %>m <%= (progress.time_spent % 60) %>s</span>
                    <% else %>
                      --
                    <% end %>
                  </td>
                  <td>
                    <div style="font-size: 11px; color: #475569;">
                      <%= progress&.ended_at&.strftime("%d %b %Y") || "--" %>
                      <div style="font-size: 10px; color: #94a3b8;"><%= progress&.ended_at&.strftime("%I:%M %p") if progress&.ended_at %></div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <% if @assigned_trainings.empty? %>
      <div class="progress-table-wrap" style="padding: 60px; text-align: center; color: #94a3b8; font-style: italic;">
        No trainings assigned to this employee.
      </div>
    <% end %>

  </div>
</div>
