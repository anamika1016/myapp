<div class="main-content bg-gray-50 min-h-screen p-6">
  <div class="max-w-6xl mx-auto">
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">SMS Logs</h1>
        <div class="flex gap-3">
          <%= link_to "Clear SMS Tracking", clear_sms_tracking_user_details_path, 
              class: "px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700",
              data: { confirm: "This will clear all SMS tracking. Continue?" } %>
          <%= link_to "Back to Form", get_user_detail_user_details_path, 
              class: "px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700" %>
        </div>
      </div>

      <% if @sms_logs.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full bg-white border border-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 tracking-wider border-b">Employee</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 tracking-wider border-b">Quarter</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 tracking-wider border-b">Sent At</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 tracking-wider border-b">Status</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @sms_logs.each do |sms_log| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= sms_log.employee_detail&.employee_name || 'N/A' %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= sms_log.quarter %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= sms_log.sent_at&.strftime("%Y-%m-%d %H:%M:%S") || 'N/A' %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if sms_log.sent? %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        ✅ Sent
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                        ❌ Failed
                      </span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-gray-500 text-lg">No SMS logs found.</p>
          <p class="text-gray-400 text-sm mt-2">SMS logs will appear here after you submit achievements.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
