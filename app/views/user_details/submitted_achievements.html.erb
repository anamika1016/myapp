      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200 shadow-sm">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th rowspan="3" class="activity-column px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Activity</th>
                <th rowspan="3" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Theme</th>
                <th rowspan="3" class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit</th>
                <th colspan="11" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-orange-700">Q1 (APR-JUN)</th>
                <th colspan="11" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-purple-700">Q2 (JUL-SEP)</th>
                <th colspan="11" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-blue-700">Q3 (OCT-DEC)</th>
                <th colspan="11" class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-green-700">Q4 (JAN-MAR)</th>
              </tr>
              <tr class="bg-gray-700">
                <!-- Q1 Months -->
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">April</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">May</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">June</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q2 Months -->
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">July</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">August</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">September</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q3 Months -->
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">October</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">November</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">December</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
                
                <!-- Q4 Months -->
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">January</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">February</th>
                <th colspan="3" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">March</th>
                <th colspan="2" class="px-2 py-2 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Quarter</th>
              </tr>
              <tr class="bg-gray-600">
                <% 4.times do %>
                  <!-- Monthly Columns -->
                  <% 3.times do %>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Target</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Achievement</th>
                    <th class="px-2 py-1 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Remarks</th>
                  <% end %>
                  <!-- Quarter Columns -->
                  <th class="px-2 py-1 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Details</th>
                  <th class="px-2 py-1 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Status</th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% 
                # Calculate quarter statuses based on ALL activities across ALL rows
                all_q1_statuses = []
                all_q2_statuses = []
                all_q3_statuses = []
                all_q4_statuses = []
                
                @user_details.each do |detail|
                  achievements = detail.achievements.index_by(&:month)
                  # Q1 (APR-JUN)
                  ['april', 'may', 'june'].each do |month|
                    all_q1_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q2 (JUL-SEP)
                  ['july', 'august', 'september'].each do |month|
                    all_q2_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q3 (OCT-DEC)
                  ['october', 'november', 'december'].each do |month|
                    all_q3_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                  # Q4 (JAN-MAR)
                  ['january', 'february', 'march'].each do |month|
                    all_q4_statuses << achievements[month]&.status if achievements[month]&.status.present?
                  end
                end
                
                # Determine overall quarter statuses based on highest priority
                def calculate_overall_quarter_status(statuses)
                  return "pending" if statuses.empty?
                  # Priority: L2 Returned > L1 Returned > L2 Approved > L1 Approved > Submitted > Pending
                  if statuses.include?("l2_returned")
                    "l2_returned"
                  elsif statuses.include?("l1_returned")
                    "l1_returned"
                  elsif statuses.include?("l2_approved")
                    "l2_approved"
                  elsif statuses.include?("l1_approved")
                    "l1_approved"
                  elsif statuses.include?("submitted")
                    "submitted"
                  else
                    "pending"
                  end
                end
                
                overall_q1_status = calculate_overall_quarter_status(all_q1_statuses)
                overall_q2_status = calculate_overall_quarter_status(all_q2_statuses)
                overall_q3_status = calculate_overall_quarter_status(all_q3_statuses)
                overall_q4_status = calculate_overall_quarter_status(all_q4_statuses)
              %>
              
              <% @user_details.each_with_index do |detail, index| %>
                <% existing_achievements = detail.achievements.index_by(&:month) %>
                <% if existing_achievements.values.any? { |a| a.achievement.present? } %>
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200" data-detail-id="<%= detail.id %>">
                    <td class="activity-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.theme_name.presence || 'No Theme' %></td>
                    <td class="px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>

                    <!-- Q1 (APR-JUN) -->
                    <%
                      q1_months = ['april', 'may', 'june']
                      # Use overall quarter status instead of calculating per row
                      q1_status = overall_q1_status
                      
                      q1_targets = []
                      q1_achievements = []
                      q1_remarks = []
                    %>
                    
                    <% q1_months.each do |month| %>
                      <% target_value = detail.send(month.to_sym) %>
                      <% achievement_record = existing_achievements[month] %>
                      <% achievement = achievement_record&.achievement %>
                      <% remarks = achievement_record&.employee_remarks %>
                      <% l1_remarks = achievement_record&.achievement_remark&.l1_remarks %>
                      <% l2_remarks = achievement_record&.achievement_remark&.l2_remarks %>
                      <% l1_percentage = achievement_record&.achievement_remark&.l1_percentage %>
                      <% l2_percentage = achievement_record&.achievement_remark&.l2_percentage %>
                      <% month_status = achievement_record&.status || 'pending' %>
                      
                      <% q1_targets << target_value.to_f %>
                      <% q1_achievements << achievement.to_f %>
                      <% q1_remarks << {month: month, target: target_value, achievement: achievement, remarks: remarks, l1_remarks: l1_remarks, l2_remarks: l2_remarks, l1_percentage: l1_percentage, l2_percentage: l2_percentage, status: month_status} %>
                      
                      <td class="px-2 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= achievement.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement.presence || '-' %>
                        </span>
                      </td>
                      <td class="px-2 py-3 text-sm text-center border-r border-gray-200 bg-orange-50">
                        <span class="<%= remarks.presence ? 'text-orange-700 font-medium bg-orange-50 px-2 py-1 rounded text-xs' : 'text-gray-400' %>">
                          <%= remarks.presence || '-' %>
                        </span>
                      </td>
                    <% end %>
                    
                    <!-- Q1 Details -->
