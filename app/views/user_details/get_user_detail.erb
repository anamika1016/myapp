<script>
// Message handling functions
function showMessage(messageType, title, text) {
  // Hide all messages first
  hideAllMessages();
  
  // Show the specific message
  const messageElement = document.getElementById(messageType + 'Message');
  if (messageElement) {
    const titleElement = document.getElementById(messageType + 'Title');
    const textElement = document.getElementById(messageType + 'Text');
    
    if (titleElement) titleElement.textContent = title;
    if (textElement) textElement.textContent = text;
    
    messageElement.classList.remove('hidden');
    
    // Auto-hide success messages after 5 seconds
    if (messageType === 'success') {
      setTimeout(() => {
        hideMessage(messageType + 'Message');
      }, 5000);
    }
  }
}

function hideMessage(messageId) {
  const messageElement = document.getElementById(messageId);
  if (messageElement) {
    messageElement.classList.add('hidden');
  }
}

function hideAllMessages() {
  const messages = ['successMessage', 'errorMessage', 'warningMessage'];
  messages.forEach(messageId => {
    hideMessage(messageId);
  });
}

// Form submission handling
function handleAchievementFormSubmission() {
  const form = document.getElementById('achievementForm');
  const submitBtn = document.getElementById('submitBtn');
  
  console.log('Form found:', form ? 'Yes' : 'No');
  console.log('Submit button found:', submitBtn ? 'Yes' : 'No');
  
  if (!form) {
    console.error('Achievement form not found!');
    return;
  }
  
  // Form validation
  form.addEventListener('submit', function(e) {
    console.log('Form submit event triggered');
    console.log('Form action:', form.action);
    console.log('Form method:', form.method);
    e.preventDefault();
    
    // Show loading state
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Submitting...';
    }
    
    // Check if any data is entered
    const achievementInputs = document.querySelectorAll('.achievement-input:not([disabled])');
    let hasAnyData = false;
    
    achievementInputs.forEach(input => {
      if (input.value && input.value.trim() !== '') {
        hasAnyData = true;
      }
    });
    
    if (!hasAnyData) {
      showMessage('warning', 'No Data Entered', 'Please enter at least one achievement value before submitting.');
      resetSubmitButton();
      return;
    }
    
    // Submit form via AJAX
    const formData = new FormData(form);
    
    // Debug: Log form data
    console.log('Form data entries:');
    for (let [key, value] of formData.entries()) {
      console.log(key, value);
    }
    
    // Get CSRF token from the hidden field in the form
    let csrfToken = document.querySelector('input[name="authenticity_token"]')?.value;
    
    console.log('CSRF Token found:', csrfToken ? 'Yes' : 'No');
    console.log('CSRF Token value:', csrfToken);
    
    if (!csrfToken) {
      showMessage('error', 'CSRF Error', 'CSRF token not found. Please refresh the page and try again.');
      resetSubmitButton();
      return;
    }
    
    fetch(form.action, {
      method: 'POST',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': csrfToken
      }
    })
    .then(response => {
      if (!response.ok) {
        // Handle HTTP errors (like 500)
        if (response.status === 500) {
          throw new Error('Server error (500). Please check the server logs.');
        }
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      if (data.success) {
        showMessage('success', 'Success!', data.message || 'Achievements have been submitted successfully.');
        
        // Clear form inputs
        achievementInputs.forEach(input => {
          input.value = '';
        });
        
        // Clear remarks
        document.querySelectorAll('.remarks-textarea').forEach(textarea => {
          textarea.value = '';
        });
        
        // Update the Submitted Achievements table immediately
        updateSubmittedAchievementsTable();
        
        // Optional: Scroll to success message
        document.getElementById('successMessage').scrollIntoView({ behavior: 'smooth' });
      } else {
        showMessage('error', 'Error!', data.message || 'There was an error submitting achievements. Please try again.');
      }
    })
    .catch(error => {
      console.error('Form submission error:', error);
      if (error.message.includes('Server error (500)')) {
        showMessage('error', 'Server Error', 'There was a server error. Please contact the administrator or try again later.');
      } else if (error.message.includes('JSON')) {
        showMessage('error', 'Response Error', 'The server returned an invalid response. Please try again.');
      } else if (error.message.includes('CSRF')) {
        showMessage('error', 'CSRF Error', 'Security token error. Please refresh the page and try again.');
      } else {
        showMessage('error', 'Network Error', 'There was an error submitting achievements. Please try again.');
      }
    })
    .finally(() => {
      resetSubmitButton();
    });
  });
}

function resetSubmitButton() {
  const submitBtn = document.getElementById('submitBtn');
  if (submitBtn) {
    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Submit Achievements';
  }
}

// Initialize form handling
function initializeAchievementForm() {
  handleAchievementFormSubmission();
  
  // Check for flash messages from controller
  checkForFlashMessages();
}

function checkForFlashMessages() {
  // Check if there are any flash messages in the page
  const flashSuccess = document.querySelector('.alert-success, .notice, [data-flash="success"]');
  const flashError = document.querySelector('.alert-danger, .alert-error, [data-flash="error"]');
  const flashWarning = document.querySelector('.alert-warning, [data-flash="warning"]');
  
  if (flashSuccess) {
    showMessage('success', 'Success!', flashSuccess.textContent.trim());
    flashSuccess.remove();
  }
  
  if (flashError) {
    showMessage('error', 'Error!', flashError.textContent.trim());
    flashError.remove();
  }
  
  if (flashWarning) {
    showMessage('warning', 'Warning!', flashWarning.textContent.trim());
    flashWarning.remove();
  }
}

// Function to update the Submitted Achievements table
function updateSubmittedAchievementsTable() {
  // Get the current form data to update the table
  const form = document.getElementById('achievementForm');
  if (!form) return;
  
  const formData = new FormData(form);
  const achievements = {};
  
  // Parse form data to get achievements
  for (let [key, value] of formData.entries()) {
    if (key.startsWith('achievement[') && key.includes('][achievement]')) {
      if (value && value.trim() !== '') {
        // Extract detail_id and month from key like "achievement[123][april][achievement]"
        const matches = key.match(/achievement\[(\d+)\]\[(\w+)\]\[achievement\]/);
        if (matches) {
          const detailId = matches[1];
          const month = matches[2];
          
          if (!achievements[detailId]) {
            achievements[detailId] = {};
          }
          achievements[detailId][month] = value.trim();
        }
      }
    }
  }
  
  // Update the Submitted Achievements table rows
  Object.keys(achievements).forEach(detailId => {
    const tableRow = document.querySelector(`tr[data-detail-id="${detailId}"]`);
    if (tableRow) {
      // Update the achievement values in the table
      Object.keys(achievements[detailId]).forEach(month => {
        const achievementValue = achievements[detailId][month];
        
        // Find all cells in the row and look for achievement cells
        const allCells = tableRow.querySelectorAll('td');
        let monthIndex = -1;
        
        // Find the month index by looking at the month headers
        const monthHeaders = document.querySelectorAll('.month-header');
        monthHeaders.forEach((header, index) => {
          if (header.dataset.month === month) {
            monthIndex = index;
          }
        });
        
        if (monthIndex !== -1) {
          // Calculate the cell position: 5 (fixed columns) + (monthIndex * 3) + 1 (achievement is second in month group)
          const achievementCellIndex = 5 + (monthIndex * 3) + 1;
          if (allCells[achievementCellIndex]) {
            allCells[achievementCellIndex].innerHTML = `<span class="text-green-700 font-semibold bg-green-50 px-2 py-1 rounded">${achievementValue}</span>`;
          }
        }
      });
      
      // Update the status to "submitted" for all quarters
      const statusCells = tableRow.querySelectorAll('td:last-child, td:nth-last-child(2)');
      statusCells.forEach(statusCell => {
        if (statusCell && statusCell.querySelector('span')) {
          const statusSpan = statusCell.querySelector('span');
          statusSpan.className = 'inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-800';
          statusSpan.innerHTML = '<i class="fas fa-paper-plane mr-1 text-xs"></i>Submitted';
        }
      });
    }
  });
  
  // Show a message that the table has been updated
  console.log('Submitted Achievements table updated with new data');
  
  // Optionally refresh the page after a short delay to show the updated data
  setTimeout(() => {
    if (confirm('Achievements submitted successfully! Would you like to refresh the page to see the updated data?')) {
      window.location.reload();
    }
  }, 2000);
}

document.addEventListener('turbo:load', function() {

    // A function to set up all the event listeners for the page
    function initializePage() {
        // Function to populate activities
        function populateActivityDropdown() {
            const activityRows = document.querySelectorAll('.activity-row');
            const activities = new Set();
            
            activityRows.forEach(row => {
                const activity = row.dataset.activity;
                if (activity && activity.trim() !== '') {
                    activities.add(activity);
                }
            });
            
            const activityFilter = document.getElementById('activityFilter');
            if (!activityFilter) return; // Guard clause
            
            // Clear existing options except the first one
            while (activityFilter.children.length > 1) {
                activityFilter.removeChild(activityFilter.lastChild);
            }
            
            // Populate activity dropdown
            activities.forEach(activity => {
                const option = document.createElement('option');
                option.value = activity;
                option.textContent = activity;
                activityFilter.appendChild(option);
            });
        }
        
        // Month mapping
        const monthMapping = {
            'april': 0, 'may': 1, 'june': 2, 'july': 3, 'august': 4, 'september': 5,
            'october': 6, 'november': 7, 'december': 8, 'january': 9, 'february': 10, 'march': 11
        };
        
        // FIXED: Function to update status based on month filter
        function updateStatusBasedOnMonth() {
            const monthFilter = document.getElementById('monthFilter');
            if (!monthFilter) return;
            
            const selectedMonth = monthFilter.value;
            const submittedRows = document.querySelectorAll('.submitted-activity-row');
            
            submittedRows.forEach(row => {
                const statusColumn = row.querySelector('.status-column span');
                if (!statusColumn) return;
                
                if (selectedMonth) {
                    // Get status for the specific month
                    const monthStatus = row.getAttribute(`data-${selectedMonth}-status`);
                    
                    if (monthStatus && monthStatus !== 'no_data') {
                        // Update status display for specific month
                        let statusConfig;
                        
                        switch (monthStatus) {
                            case "pending":
                                statusConfig = { 
                                    color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                    text: "Pending", 
                                    icon: "fas fa-clock" 
                                };
                                break;
                            case "l1_approved":
                                statusConfig = { 
                                    color: "bg-green-100 text-green-800 border-green-300", 
                                    text: "L1 Approved", 
                                    icon: "fas fa-check-circle" 
                                };
                                break;
                            case "l1_returned":
                                statusConfig = { 
                                    color: "bg-red-100 text-red-800 border-red-300", 
                                    text: "L1 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "l2_approved":
                                statusConfig = { 
                                    color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                    text: "L2 Approved", 
                                    icon: "fas fa-check-double" 
                                };
                                break;
                            case "l2_returned":
                                statusConfig = { 
                                    color: "bg-orange-100 text-orange-800 border-orange-300", 
                                    text: "L2 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "submitted":
                                statusConfig = { 
                                    color: "bg-blue-100 text-blue-800 border-blue-300", 
                                    text: "Submitted", 
                                    icon: "fas fa-paper-plane" 
                                };
                                break;
                            default:
                                statusConfig = { 
                                    color: "bg-gray-100 text-gray-600 border-gray-300", 
                                    text: "No Data", 
                                    icon: "fas fa-question-circle" 
                                };
                        }
                        
                        // Update the status badge
                        statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                        statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                        
                    } else {
                        // No data for this month
                        statusColumn.className = "inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border bg-gray-100 text-gray-600 border-gray-300";
                        statusColumn.innerHTML = '<i class="fas fa-question-circle mr-1 text-xs"></i>No Data';
                    }
                } else {
                    // Reset to original overall status when no month filter is applied
                    // Get all month statuses for this row
                    const allStatuses = [];
                    const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
                    
                    months.forEach(month => {
                        const monthStatus = row.getAttribute(`data-${month}-status`);
                        if (monthStatus && monthStatus !== 'no_data') {
                            allStatuses.push(monthStatus);
                        }
                    });
                    
                    // Determine overall status
                    let overallStatus = "pending";
                    if (allStatuses.includes("l2_approved")) {
                        overallStatus = "l2_approved";
                    } else if (allStatuses.includes("l1_approved")) {
                        overallStatus = "l1_approved";
                    } else if (allStatuses.includes("l2_returned")) {
                        overallStatus = "l2_returned";
                    } else if (allStatuses.includes("l1_returned")) {
                        overallStatus = "l1_returned";
                    } else if (allStatuses.includes("submitted")) {
                        overallStatus = "submitted";
                    }
                    
                    let statusConfig;
                    switch (overallStatus) {
                        case "pending":
                            statusConfig = { 
                                color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                text: "Pending", 
                                icon: "fas fa-clock" 
                            };
                            break;
                        case "l1_approved":
                            statusConfig = { 
                                color: "bg-green-100 text-green-800 border-green-300", 
                                text: "L1 Approved", 
                                icon: "fas fa-check-circle" 
                            };
                            break;
                        case "l1_returned":
                            statusConfig = { 
                                color: "bg-red-100 text-red-800 border-red-300", 
                                text: "L1 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "l2_approved":
                            statusConfig = { 
                                color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                text: "L2 Approved", 
                                icon: "fas fa-check-double" 
                            };
                            break;
                        case "l2_returned":
                            statusConfig = { 
                                color: "bg-orange-100 text-orange-800 border-orange-300", 
                                text: "L2 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "submitted":
                            statusConfig = { 
                                color: "bg-blue-100 text-blue-800 border-blue-300", 
                                text: "Submitted", 
                                icon: "fas fa-paper-plane" 
                            };
                            break;
                        default:
                            statusConfig = { 
                                color: "bg-gray-100 text-gray-600 border-gray-300", 
                                text: "No Status", 
                                icon: "fas fa-question-circle" 
                            };
                    }
                    
                    // Update the status badge
                    statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                    statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                }
            });
        }
        
        // Modal functionality
        // Modal functionality - Simplified to avoid conflicts with quarterly modal
        function setupModal() {
            // This function is kept for compatibility but the quarterly modal handles its own functionality
            console.log('Basic modal setup completed - quarterly modal is handling details');
        }
        
        function filterTable() {
            const activityFilter = document.getElementById('activityFilter');
            const monthFilter = document.getElementById('monthFilter');
            if (!activityFilter || !monthFilter) return; // Guard clause

            const selectedActivity = activityFilter.value;
            const selectedMonth = monthFilter.value;
            
            // Filter activity rows
            document.querySelectorAll('.activity-row').forEach(row => {
                const rowActivity = row.dataset.activity;
                const shouldShowRow = !selectedActivity || rowActivity === selectedActivity;
                row.style.display = shouldShowRow ? '' : 'none';
            });
            
            // Filter submitted activity rows
            document.querySelectorAll('.submitted-activity-row').forEach(row => {
                const rowActivity = row.dataset.activity;
                const shouldShowRow = !selectedActivity || rowActivity === selectedActivity;
                row.style.display = shouldShowRow ? '' : 'none';
            });
            
            // Filter month columns
            if (selectedMonth) {
                const selectedIndex = monthMapping[selectedMonth];
                
                document.querySelectorAll('.month-header, .submitted-month-header').forEach((header, index) => {
                    header.style.display = index === selectedIndex ? '' : 'none';
                });
                
                document.querySelectorAll('.month-subheader, .submitted-month-subheader').forEach((subheader, index) => {
                    const monthIndex = Math.floor(index / 3);
                    subheader.style.display = monthIndex === selectedIndex ? '' : 'none';
                });
                
                document.querySelectorAll('.month-cell, .submitted-month-cell').forEach(cell => {
                    cell.style.display = cell.dataset.month === selectedMonth ? '' : 'none';
                });
            } else {
                // Show all month columns
                document.querySelectorAll('.month-header, .submitted-month-header, .month-subheader, .submitted-month-subheader, .month-cell, .submitted-month-cell').forEach(el => {
                    el.style.display = '';
                });
            }
            
            // FIXED: Update status after filtering
            updateStatusBasedOnMonth();
        }

        function resetAllFilters() {
             const activityFilter = document.getElementById('activityFilter');
             const monthFilter = document.getElementById('monthFilter');
             if (activityFilter) activityFilter.value = '';
             if (monthFilter) monthFilter.value = '';
             filterTable(); // Apply the reset state
        }
        
        // --- Setup ---
        // Populate dropdown immediately
        populateActivityDropdown();
        
        // Setup modal functionality
        setupModal();

        // Attach event listeners
        const showSelectedBtn = document.getElementById('showSelected');
        const showAllBtn = document.getElementById('showAll');
        const clearFiltersBtn = document.getElementById('clearFilters');
        const activityFilterSelect = document.getElementById('activityFilter');
        const monthFilterSelect = document.getElementById('monthFilter');

        if (showSelectedBtn) showSelectedBtn.addEventListener('click', filterTable);
        if (showAllBtn) showAllBtn.addEventListener('click', resetAllFilters);
        if (clearFiltersBtn) clearFiltersBtn.addEventListener('click', resetAllFilters);
        if (activityFilterSelect) activityFilterSelect.addEventListener('change', filterTable);
        if (monthFilterSelect) monthFilterSelect.addEventListener('change', filterTable);
    }
    
    // Run the setup function for the page
    initializePage();
    
    // Initialize achievement form handling
    initializeAchievementForm();
  });
</script>