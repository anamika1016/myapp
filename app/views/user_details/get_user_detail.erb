<div class="main-content bg-gray-50 min-h-screen">
  <!-- Filter Section - Added without changing your existing code -->
  <div class="filter-shell border border-slate-200 rounded-[28px] shadow-lg mb-6 overflow-hidden">
    <div class="filter-hero px-6 py-5 border-b border-white/40">
      <h2 class="text-2xl font-bold text-slate-900 flex items-center">
        <i class="fas fa-filter me-3 text-teal-700"></i>
        key result indicators
      </h2>
      <p class="filter-subtitle">Choose financial year and month to keep the target sheet focused and easy to review.</p>
    </div>
    <div class="p-6 md:p-7">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div class="filter-field">
          <%= form_with url: get_user_detail_user_details_path, method: :get, local: true do |form| %>
            <%= form.label :financial_year, "Financial year", class: "block text-xs font-semibold text-slate-600 tracking-[0.08em] mb-2" %>
            <%= form.select :financial_year,
                options_for_select(@financial_years, @selected_financial_year),
                {},
                class: "dashboard-select w-full",
                onchange: "this.form.submit();" %>
          <% end %>
        </div>

        <select id="activityFilter" class="hidden">
          <option value="">All key result indicators</option>
        </select>

        <div class="filter-field">
          <label class="block text-xs font-semibold text-slate-600 tracking-[0.08em] mb-2">Select month</label>
          <select id="monthFilter" class="dashboard-select w-full">
            <option value="">-- Select Month --</option>
            <% @active_month_options.each do |label, value| %>
              <option value="<%= value %>" <%= "selected" if value == @selected_month %>><%= label %></option>
            <% end %>
          </select>
        </div>
        
        <input type="hidden" id="quarterFilter" value="april-june">
        
        <div class="flex gap-3 filter-actions">
          <button type="button" id="showSelected" class="dashboard-action-btn dashboard-action-btn-primary">
            <i class="fas fa-eye me-1"></i> Show Month
          </button>
        </div>
      </div>
    </div>
  </div>

  <% if @user_details.any? && @selected_month.present? %>
    <!-- ======================== FORM TO SUBMIT ACHIEVEMENTS ======================== -->
    <%= form_with url: submit_achievements_user_details_path, method: :post, local: true, id: "achievementForm" do %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :financial_year, @selected_financial_year %>
      <%= hidden_field_tag :month, @selected_month, id: "selectedSubmissionMonth" %>
      <%= hidden_field_tag :employee_detail_id, @employee_detail&.id %>
      <!-- Success Message Display -->
      <div id="successMessage" class="hidden bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-check-circle text-green-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800" id="successTitle">Success!</h3>
            <div class="mt-2 text-sm text-green-700" id="successText">
              Achievements have been submitted successfully.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-green-400 hover:text-green-600" onclick="hideMessage('successMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Error Message Display -->
      <div id="errorMessage" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-triangle text-red-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800" id="errorTitle">Error!</h3>
            <div class="mt-2 text-sm text-red-700" id="errorText">
              There was an error submitting achievements. Please try again.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-red-400 hover:text-red-600" onclick="hideMessage('errorMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Warning Message Display -->
      <div id="warningMessage" class="hidden bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-circle text-yellow-400 text-xl"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-yellow-800" id="warningTitle">Warning!</h3>
            <div class="mt-2 text-sm text-yellow-700" id="warningText">
              Please review your input before submitting.
            </div>
          </div>
          <div class="ml-auto pl-3">
            <button type="button" class="text-yellow-400 hover:text-yellow-600" onclick="hideMessage('warningMessage')">
              <i class="fas fa-times text-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="submission-shell border border-slate-200 rounded-[28px] shadow-lg mt-4 overflow-hidden">
        <div class="submission-hero px-6 py-5 border-b border-slate-200/80">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-3xl font-bold text-slate-900 flex items-center">
              <i class="fas fa-users me-3 text-sky-700"></i>
              Monthly key result indicator submission
            </h2>
            <% if @employee_detail.present? %>
              <button type="button"
                      id="addKriRowBtn"
                      data-kri-limit="<%= @remaining_manual_kri_slots %>"
                      data-selected-month="<%= @selected_month %>"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-gray-700 hover:bg-gray-800 text-white text-sm font-semibold rounded-lg shadow-sm transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                      title="<%= @achievement_entry_locked ? @achievement_entry_lock_message : (@remaining_manual_kri_slots.positive? ? "You can add #{@remaining_manual_kri_slots} key result indicator row(s) for #{short_month_label(@selected_month)}" : "Maximum 3 key result indicator rows already added for #{short_month_label(@selected_month)}") %>"
                      <%= "disabled" if @achievement_entry_locked || @remaining_manual_kri_slots.zero? %>>
                <i class="fas fa-plus"></i>
                Add key result indicator
              </button>
            <% end %>
          </div>
          <p class="submission-subtitle"></p>
          <% if @achievement_entry_locked %>
            <div class="entry-lock-banner mt-4">
              <i class="fas fa-lock"></i>
              <span><%= @achievement_entry_lock_message %> Changes are disabled for this month.</span>
            </div>
          <% end %>
        </div>

        <div class="p-6">
          <div class="table-wrapper overflow-auto rounded-[24px] border border-slate-200 shadow-sm">
            <table class="table table-hover w-full min-w-full" id="activityTable">
              <thead class="bg-gray-800">
                <% quarter_groups = [
                  { label: "APR - JUN", key: "april-june", months: [["APR", "april"], ["MAY", "may"], ["JUN", "june"]] },
                  { label: "JUL - SEP", key: "july-september", months: [["JUL", "july"], ["AUG", "august"], ["SEP", "september"]] },
                  { label: "OCT - DEC", key: "october-december", months: [["OCT", "october"], ["NOV", "november"], ["DEC", "december"]] },
                  { label: "JAN - MAR", key: "january-march", months: [["JAN", "january"], ["FEB", "february"], ["MAR", "march"]] }
                ] %>
                <tr>
                  <th rowspan="3" class="serial-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">S.No</th>
                  <th rowspan="3" class="activity-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Key result indicators</th>
                  <th rowspan="3" class="unit-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600">Unit of measurement</th>
                  <th rowspan="3" class="annual-target-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600"><%= annual_target_fy_label(@selected_financial_year) %></th>
                  <% quarter_groups.each do |quarter| %>
                    <th colspan="12" class="px-4 py-3 text-center text-xs font-semibold text-white tracking-widest border-r border-gray-500 bg-gray-900 quarter-header" data-quarter="<%= quarter[:key] %>">
                      <%= quarter[:label] %>
                    </th>
                  <% end %>
                </tr>
                <tr>
                  <% quarter_groups.each do |quarter| %>
                    <% quarter[:months].each do |month_label, month_key| %>
                      <th colspan="4" class="px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700 month-header" data-month="<%= month_key %>" data-quarter="<%= quarter[:key] %>"><%= month_label %></th>
                    <% end %>
                  <% end %>
                </tr>
                <tr class="bg-gray-700">
                  <% quarter_groups.each do |quarter| %>
                    <% quarter[:months].each do |month_label, month_key| %>
                      <th class="px-3 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 month-subheader" data-month="<%= month_key %>" data-quarter="<%= quarter[:key] %>">Target</th>
                      <th class="achievement-header px-3 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 month-subheader" data-month="<%= month_key %>" data-quarter="<%= quarter[:key] %>">Achievement</th>
                      <th class="total-achievement-header px-3 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 month-subheader" data-month="<%= month_key %>" data-quarter="<%= quarter[:key] %>">% Progress</th>
                      <th class="px-3 py-2 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 month-subheader remarks-header" data-month="<%= month_key %>" data-quarter="<%= quarter[:key] %>"><%= employee_remarks_column_label(month_label) %></th>
                    <% end %>
                  <% end %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200" id="activityTableBody">
                <%
                  months = [:april, :may, :june, :july, :august, :september, :october, :november, :december, :january, :february, :march]
                  monthly_summary_totals = months.each_with_object({}) do |month, totals|
                    totals[month] = {
                      progress_sum: 0.0,
                      progress_count: 0
                    }
                  end
                %>
                <% @user_details.each_with_index do |detail, index| %>
                  <%
                    # Create target data for JavaScript filtering
                    achievements_by_month = detail.achievements.index_by { |achievement| achievement.month.to_s.downcase }
                    is_manual_kri = detail.activity.theme_name.to_s == UserDetailsController::MANUAL_KRI_THEME
                    target_data = {}
                    has_any_target = false
                    selected_month_key = @selected_month.to_s
                    selected_month_target = clean_spreadsheet_display_value(detail.send(selected_month_key.to_sym))
                    selected_month_target_text = selected_month_target.to_s.delete(",").strip
                    selected_month_target_numeric = selected_month_target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
                    has_selected_month_target = selected_month_target.present? && (!selected_month_target_numeric || selected_month_target_text.to_f.positive?)

                    if is_manual_kri
                      manual_kri_month = months.find do |month|
                        value = clean_spreadsheet_display_value(detail.send(month))
                        target_text = value.to_s.delete(",").strip
                        next false if value.blank?

                        !target_text.match?(/\A-?\d+(?:\.\d+)?\z/) || target_text.to_f.positive?
                      end
                      has_selected_month_target = manual_kri_month.to_s == selected_month_key
                    end

                    months.each do |month|
                      target_value = clean_spreadsheet_display_value(detail.send(month))
                      target_text_for_filter = target_value.to_s.delete(",").strip
                      target_is_numeric_for_filter = target_text_for_filter.match?(/\A-?\d+(?:\.\d+)?\z/)
                      # Consider a target valid if it is filled; numeric zero still counts as blank.
                      is_valid_target = target_value.present? && (!target_is_numeric_for_filter || target_text_for_filter.to_f.positive?)
                      target_data[month.to_s] = is_valid_target ? target_value.to_s : ''
                      has_any_target = true if is_valid_target
                    end
                  %>
                  
                  <tr class="<%= index.even? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200 activity-row" 
                      data-detail-id="<%= detail.id %>"
                      data-activity="<%= detail.activity.activity_name %>" 
                      data-targets='<%= target_data.to_json.html_safe %>'
                      data-has-any-target="<%= has_any_target %>"
                      <%= 'data-manual-kri="true"'.html_safe if is_manual_kri %>
                      <%= 'data-manual-kri-month="' + manual_kri_month.to_s + '"'.html_safe if is_manual_kri && manual_kri_month.present? %>
                      <%= 'data-filtered-hidden="true" style="display:none;"'.html_safe unless has_selected_month_target %>>

                    <td class="serial-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= index + 1 %></td>
                    <td class="activity-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200"><%= detail.activity.activity_name %></td>
                    <td class="unit-column px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= detail.activity.unit %></td>
                    <td class="annual-target-column px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"><%= annual_target_display(detail.activity) %></td>

                    <% months.each do |month| %>
                      <% target_value = clean_spreadsheet_display_value(detail.send(month)) %>
                      <% target_text = target_value.to_s.delete(",").strip %>
                      <% target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/) %>
                      <% has_target = target_value.present? && (!target_is_numeric || target_text.to_f.positive?) %>
                      <% existing_achievement = achievements_by_month[month.to_s] %>
                      <% target_number = target_is_numeric ? target_text.to_f : 0.0 %>
                      <% achievement_number = existing_achievement&.achievement.to_s.delete(",").to_f %>
                      <% month_locked = (@achievement_entry_locked && month.to_s == @selected_month.to_s) || %w[l1_approved l2_approved].include?(existing_achievement&.status.to_s) %>
                      <% total_achievement_percentage = has_target && target_number.positive? && existing_achievement&.achievement.present? ? (((achievement_number / target_number) * 100.0 * 100).floor / 100.0) : nil %>
                      <%
                        if has_target && target_number.positive?
                          row_progress = total_achievement_percentage || 0.0
                          monthly_summary_totals[month][:progress_sum] += row_progress
                          monthly_summary_totals[month][:progress_count] += 1
                        end
                      %>
                      
                      <td class="target-cell px-3 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <span class="<%= has_target ? 'target-static-value text-gray-800 font-medium' : 'target-static-value text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      <td class="achievement-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <input 
                          type="number" 
                          step="any"
                          inputmode="decimal"
                          name="achievement[<%= detail.id %>][<%= month.to_s.downcase %>][achievement]" 
                          placeholder="Value"
                          value="<%= existing_achievement&.achievement %>"
                          class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm <%= 'locked-field' if month_locked %>"
                          <%= 'disabled' if !has_target || month_locked %>
                          <%= raw('data-locked="true" readonly') if month_locked %>
                        />
                      </td>
                      <td class="total-achievement-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell"
                          data-month="<%= month %>"
                          data-has-target="<%= has_target %>"
                          data-target-value="<%= target_value %>">
                        <span class="<%= total_achievement_percentage ? 'total-achievement-value text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'total-achievement-value text-gray-400' %>">
                          <%= total_achievement_percentage ? "#{format('%.2f', total_achievement_percentage)}%" : '-' %>
                        </span>
                      </td>
                      <td class="remarks-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="<%= month %>" data-has-target="<%= has_target %>">
                        <textarea 
                          name="achievement[<%= detail.id %>][<%= month.to_s.downcase %>][employee_remarks]" 
                          placeholder="EMP RM"
                          rows="1"
                          maxlength="<%= UserDetailsController::REMARKS_MAX_LENGTH %>"
                          class="remarks-textarea border border-gray-300 p-1 rounded w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none <%= 'locked-field' if month_locked %>"
                          <%= 'disabled' if !has_target || month_locked %>
                          <%= raw('data-locked="true" readonly') if month_locked %>
                        ><%= existing_achievement&.employee_remarks %></textarea>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
                <tr class="monthly-summary-footer">
                  <td colspan="4" class="monthly-summary-label px-4 py-3 text-right text-sm font-bold border-r border-gray-600"></td>
                  <% months.each do |month| %>
                    <% month_total = monthly_summary_totals[month] %>
                    <% progress_total = month_total[:progress_count].positive? ? ((month_total[:progress_sum] / month_total[:progress_count]) * 100).floor / 100.0 : nil %>
                    <td class="monthly-summary-target px-3 py-3 text-center text-sm font-bold border-r border-gray-600 month-cell" data-month="<%= month %>" data-summary-month="<%= month %>">
                    </td>
                    <td class="monthly-summary-achievement px-3 py-3 text-center text-sm font-bold border-r border-gray-600 month-cell" data-month="<%= month %>" data-summary-month="<%= month %>">
                    </td>
                    <td class="monthly-summary-total px-3 py-3 text-center text-sm font-bold border-r border-gray-600 month-cell" data-month="<%= month %>" data-summary-month="<%= month %>">
                      <span class="<%= progress_total ? 'summary-total-achievement-value text-emerald-900 font-bold bg-emerald-100 px-2 py-1 rounded' : 'summary-total-achievement-value text-gray-300' %>"><%= progress_total ? "#{format('%.2f', progress_total)}%" : '-' %></span>
                    </td>
                    <td class="monthly-summary-remarks px-3 py-3 text-center text-sm font-bold border-r border-gray-600 month-cell" data-month="<%= month %>" data-summary-month="<%= month %>">
                    </td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="mt-6 flex justify-center">
        <%= submit_tag "Submit achievements", class: "inline-flex items-center px-8 py-3 bg-gray-700 hover:bg-gray-800 text-white font-semibold rounded-lg shadow-md transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none", id: "submitBtn", disabled: @achievement_entry_locked %>
      </div>
    <% end %>
  <% elsif @user_details.any? %>
    <div class="flex justify-center mt-10">
      <div class="w-full max-w-2xl bg-white border border-slate-200 rounded-3xl shadow-xl p-10 text-center">
        <i class="fas fa-calendar-alt text-5xl text-teal-600 mb-5"></i>
        <h2 class="text-2xl font-bold text-slate-900 mb-3">Please select a month first</h2>
        <p class="text-slate-600 leading-relaxed">
          Select a month from the filter above and click Show Month to open the monthly key result indicator submission sheet.
        </p>
      </div>
    </div>
  <% else %>
    <div class="flex justify-center mt-10">
      <div class="w-full max-w-lg bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 border border-indigo-100 rounded-3xl shadow-xl p-10 text-center">

        <!-- Lottie Animation -->
        <div class="mb-6 flex justify-center">
          <lottie-player 
            src="https://assets9.lottiefiles.com/packages/lf20_t24tpvcu.json" 
            background="transparent"  
            speed="1"  
            style="width: 1000px !important;  height: 300px;"  
            loop  
            autoplay>
          </lottie-player>
        </div>

        <!-- Heading -->
        <h2 class="text-3xl font-extrabold text-gray-800 mb-3">
          No User Details Found
        </h2>

        <!-- Sub-text -->
        <p class="text-gray-600 text-base mb-6 leading-relaxed">
          It looks like there are no user details available to submit achievements.<br>
          Please check with your HOD or try again later.
        </p>
      </div>
    </div>

    <!-- Lottie Script -->
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
  <% end %>

<style>
  .activity-row[data-filtered-hidden="true"] {
    display: none !important;
  }

  .quarter-header[data-quarter-hidden="true"] {
    display: none !important;
  }
  
  .month-header[data-month-hidden="true"],
  .month-subheader[data-month-hidden="true"] {
    display: none !important;
  }
  
.month-cell[data-month-hidden="true"] {
  display: none !important;
}

.total-achievement-header {
  width: 8.5rem;
  min-width: 8.5rem;
  max-width: 8.5rem;
  white-space: normal;
  line-height: 1.25;
}

.total-achievement-cell {
  width: 8.5rem;
  min-width: 8.5rem;
  max-width: 8.5rem;
  background: #f8fafc;
}

.total-achievement-value {
  display: inline-flex;
  justify-content: center;
  min-width: 4.5rem;
}

.monthly-summary-footer td {
  background: linear-gradient(135deg, #1f2937 0%, #111827 100%) !important;
  color: #ffffff;
  vertical-align: middle;
}

.monthly-summary-label {
  letter-spacing: 0.02em;
}

.monthly-summary-target,
.monthly-summary-achievement,
.monthly-summary-remarks,
.monthly-summary-total {
  font-weight: 700;
}

.summary-target-value,
.summary-achievement-value,
.summary-total-achievement-value {
  display: inline-flex;
  justify-content: center;
  min-width: 4.5rem;
  white-space: normal;
}
  
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    initializeAchievementFilters();
});

document.addEventListener('turbo:load', function() {
    initializeAchievementFilters();
});

function initializeAchievementFilters() {
    const activityFilter = document.getElementById('activityFilter');
    if (!activityFilter || activityFilter.dataset.filtersBound === 'true') return;
    activityFilter.dataset.filtersBound = 'true';

    const quarterFilter = document.getElementById('quarterFilter');
    const monthFilter = document.getElementById('monthFilter');
    const showSelectedBtn = document.getElementById('showSelected');
    const showAllBtn = document.getElementById('showAll');
    const activityRows = document.querySelectorAll('.activity-row');
    const quarterHeaders = document.querySelectorAll('.quarter-header');
    const monthHeaders = document.querySelectorAll('.month-header');
    const monthSubheaders = document.querySelectorAll('.month-subheader');
    const monthCells = document.querySelectorAll('.month-cell');
    const quarterMonths = {
        'april-june': ['april', 'may', 'june'],
        'july-september': ['july', 'august', 'september'],
        'october-december': ['october', 'november', 'december'],
        'january-march': ['january', 'february', 'march']
    };
    const monthToQuarter = {
        april: 'april-june',
        may: 'april-june',
        june: 'april-june',
        july: 'july-september',
        august: 'july-september',
        september: 'july-september',
        october: 'october-december',
        november: 'october-december',
        december: 'october-december',
        january: 'january-march',
        february: 'january-march',
        march: 'january-march'
    };

    // Populate activity filter dropdown
    function populateActivityFilter() {
        const activities = new Set();
        activityRows.forEach(row => {
            const activity = row.dataset.activity;
            if (activity) {
                activities.add(activity);
            }
        });

        // Clear existing options except "All key result indicators"
        activityFilter.innerHTML = '<option value="">All key result indicators</option>';
        
        // Add unique activities
        Array.from(activities).sort().forEach(activity => {
            const option = document.createElement('option');
            option.value = activity;
            option.textContent = activity;
            activityFilter.appendChild(option);
        });
    }

    // Filter functions
    function filterByActivity(selectedActivity) {
        activityRows.forEach(row => {
            if (!selectedActivity || row.dataset.activity === selectedActivity) {
                row.removeAttribute('data-activity-hidden');
            } else {
                row.setAttribute('data-activity-hidden', 'true');
            }
        });
    }

    function filterByMonth(selectedMonth) {
        const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
        if (!selectedMonth) {
            months.forEach(month => {
                monthHeaders.forEach(header => {
                    if (header.dataset.month === month) header.setAttribute('data-month-hidden', 'true');
                });
                monthSubheaders.forEach(subheader => {
                    if (subheader.dataset && subheader.dataset.month === month) subheader.setAttribute('data-month-hidden', 'true');
                });
                monthCells.forEach(cell => {
                    if (cell.dataset.month === month) cell.setAttribute('data-month-hidden', 'true');
                });
            });
            activityRows.forEach(row => row.setAttribute('data-filtered-hidden', 'true'));
            return;
        }

        const activeMonth = selectedMonth;
        const selectedQuarter = monthToQuarter[activeMonth] || '';
        
        quarterHeaders.forEach(header => header.setAttribute('data-quarter-hidden', 'true'));

        months.forEach(month => {
            const shouldShowMonth = month === activeMonth;
            
            monthHeaders.forEach(header => {
                if (header.dataset.month === month) {
                    if (shouldShowMonth) {
                        header.removeAttribute('data-month-hidden');
                    } else {
                        header.setAttribute('data-month-hidden', 'true');
                    }
                }
            });

            monthSubheaders.forEach(subheader => {
                if (subheader.dataset && subheader.dataset.month === month) {
                    if (shouldShowMonth) {
                        subheader.removeAttribute('data-month-hidden');
                    } else {
                        subheader.setAttribute('data-month-hidden', 'true');
                    }
                }
            });
            
            monthCells.forEach(cell => {
                if (cell.dataset.month === month) {
                    if (shouldShowMonth) {
                        cell.removeAttribute('data-month-hidden');
                    } else {
                        cell.setAttribute('data-month-hidden', 'true');
                    }
                }
            });
        });

        activityRows.forEach(row => {
            if (row.dataset.newRow === 'true') {
                const manualMonth = row.dataset.manualKriMonth;
                if (!manualMonth || manualMonth === activeMonth) {
                    row.removeAttribute('data-filtered-hidden');
                } else {
                    row.setAttribute('data-filtered-hidden', 'true');
                }
                return;
            }

            if (row.dataset.manualKri === 'true' && row.dataset.manualKriMonth) {
                if (row.dataset.manualKriMonth === activeMonth) {
                    row.removeAttribute('data-filtered-hidden');
                } else {
                    row.setAttribute('data-filtered-hidden', 'true');
                }
                return;
            }

            let targets = {};
            try {
                targets = JSON.parse(row.dataset.targets || '{}');
            } catch (error) {
                targets = {};
            }

            const monthTarget = targets[activeMonth];
            const hasTarget = monthTarget && String(monthTarget).trim() !== '' && String(monthTarget).trim() !== '0';
            const numericTarget = String(monthTarget || '').replace(/,/g, '');
            const isPositiveTarget = hasTarget && (!/^-?\d+(?:\.\d+)?$/.test(numericTarget) || parseFloat(numericTarget) > 0);

            if (isPositiveTarget) {
                row.removeAttribute('data-filtered-hidden');
            } else {
                row.setAttribute('data-filtered-hidden', 'true');
            }
        });
    }

    function applyFilters() {
        const selectedActivity = activityFilter.value;
        const selectedMonth = monthFilter.value;
        quarterFilter.value = monthToQuarter[selectedMonth] || '';

        // Reset all filters first
        activityRows.forEach(row => {
            row.removeAttribute('data-activity-hidden');
            row.removeAttribute('data-filtered-hidden');
        });

        quarterHeaders.forEach(header => header.setAttribute('data-quarter-hidden', 'true'));
        monthHeaders.forEach(header => header.removeAttribute('data-month-hidden'));
        monthSubheaders.forEach(subheader => subheader.removeAttribute('data-month-hidden'));
        monthCells.forEach(cell => cell.removeAttribute('data-month-hidden'));

        // Apply filters
        filterByActivity(selectedActivity);
        filterByMonth(selectedMonth);

        // Update visibility
        updateRowVisibility();
    }

    function updateRowVisibility() {
        activityRows.forEach(row => {
            const isActivityHidden = row.hasAttribute('data-activity-hidden');
            const isFilteredHidden = row.hasAttribute('data-filtered-hidden');

            if (isActivityHidden || isFilteredHidden) {
                row.style.display = 'none';
            } else {
                row.style.display = '';
            }
        });

        if (typeof updateMonthlySummaryRows === 'function') {
            updateMonthlySummaryRows();
        }

        if (typeof updateActivityRowSerials === 'function') {
            updateActivityRowSerials();
        }
    }

    function showAll() {
        activityFilter.value = '';
        monthFilter.value = '<%= @selected_month.to_s %>';
        quarterFilter.value = monthToQuarter[monthFilter.value] || '';
        applyFilters();
    }

    function showSelectedMonth() {
        const selectedMonth = monthFilter?.value || '';
        if (!selectedMonth) {
            alert('Please select a month first.');
            return;
        }

        const url = new URL(window.location.href);
        url.searchParams.set('month', selectedMonth);

        const financialYearSelect = document.querySelector('select[name="financial_year"]');
        if (financialYearSelect?.value) {
            url.searchParams.set('financial_year', financialYearSelect.value);
        }

        window.location.href = url.toString();
    }

    // Event listeners
    if (showSelectedBtn) showSelectedBtn.addEventListener('click', showSelectedMonth);
    if (showAllBtn) showAllBtn.addEventListener('click', showAll);
    
    activityFilter.addEventListener('change', applyFilters);

    // Initialize
    populateActivityFilter();
    
    quarterFilter.value = monthToQuarter[monthFilter.value] || '';
    applyFilters();
}

function hasFilledTargetValueForFilter(value) {
    const rawValue = String(value || '').trim();
    if (!rawValue) return false;

    const normalizedValue = rawValue.replace(/,/g, '');
    if (!/^-?\d+(?:\.\d+)?$/.test(normalizedValue)) return true;

    return parseFloat(normalizedValue) > 0;
}
</script>

