<script>
const achievementEntryLocked = <%= @achievement_entry_locked ? "true" : "false" %>;

// Message handling functions
function showMessage(messageType, title, text) {
  // Hide all messages first
  hideAllMessages();
  
  // Show the specific message
  const messageElement = document.getElementById(messageType + 'Message');
  if (messageElement) {
    const titleElement = document.getElementById(messageType + 'Title');
    const textElement = document.getElementById(messageType + 'Text');
    
    if (titleElement) titleElement.textContent = title;
    if (textElement) textElement.textContent = text;
    
    messageElement.classList.remove('hidden');
    
    // Auto-hide success messages after 5 seconds
    if (messageType === 'success') {
      setTimeout(() => {
        hideMessage(messageType + 'Message');
      }, 5000);
    }
  }
}

function hideMessage(messageId) {
  const messageElement = document.getElementById(messageId);
  if (messageElement) {
    messageElement.classList.add('hidden');
  }
}

function hideAllMessages() {
  const messages = ['successMessage', 'errorMessage', 'warningMessage'];
  messages.forEach(messageId => {
    hideMessage(messageId);
  });
}

function parseAchievementNumber(value) {
  const normalizedValue = String(value || '').replace(/,/g, '').replace(/[^0-9.-]/g, '');
  const number = parseFloat(normalizedValue);
  return Number.isFinite(number) ? number : null;
}

function hasFilledTargetValue(value) {
  const rawValue = String(value || '').trim();
  if (!rawValue) return false;

  const normalizedValue = rawValue.replace(/,/g, '');
  if (!/^-?\d+(?:\.\d+)?$/.test(normalizedValue)) return true;

  return parseFloat(normalizedValue) > 0;
}

function formatAchievementPercentage(value) {
  if (!Number.isFinite(value)) return '-';

  const truncatedValue = Math.floor(value * 100) / 100;
  return `${Number.isInteger(truncatedValue) ? truncatedValue : truncatedValue.toFixed(2)}%`;
}

var targetSubmitMonths = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];

function monthLabel(month) {
  const labels = {
    april: 'APR',
    may: 'MAY',
    june: 'JUN',
    july: 'JUL',
    august: 'AUG',
    september: 'SEP',
    october: 'OCT',
    november: 'NOV',
    december: 'DEC',
    january: 'JAN',
    february: 'FEB',
    march: 'MAR'
  };

  return labels[month] || month.toUpperCase();
}

function updateActivityRowSerials() {
  let visibleIndex = 1;
  document.querySelectorAll('#activityTableBody .activity-row').forEach(row => {
    const cell = row.querySelector('.serial-cell');
    if (!cell) return;

    const isHidden = row.style.display === 'none' ||
      row.hasAttribute('data-activity-hidden') ||
      row.hasAttribute('data-filtered-hidden');

    if (!isHidden) {
      cell.textContent = visibleIndex++;
    }
  });
}

function applySelectedMonthVisibilityToRow(row) {
  const monthFilter = document.getElementById('monthFilter');
  const selectedMonth = monthFilter?.value || '<%= @selected_month.to_s %>';
  if (!selectedMonth) return;

  row.querySelectorAll('.month-cell').forEach(cell => {
    cell.style.display = cell.dataset.month === selectedMonth ? '' : 'none';
  });
}

function selectedSubmissionMonthValue() {
  return document.getElementById('selectedSubmissionMonth')?.value ||
         document.getElementById('monthFilter')?.value ||
         document.getElementById('addKriRowBtn')?.dataset.selectedMonth ||
         '<%= @selected_month.to_s %>';
}

function newKriRowHtml(rowIndex) {
  const selectedMonth = selectedSubmissionMonthValue();
  const monthCells = targetSubmitMonths.map(month => {
    if (month !== selectedMonth) return '';

    return `
    <td class="target-cell px-3 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50 month-cell" data-month="${month}" data-has-target="false">
      <input type="text"
             name="new_targets[${rowIndex}][${month}]"
             class="target-input border border-gray-300 p-2 rounded-lg w-full bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-center"
             placeholder="Target"
             data-month="${month}"
             required>
    </td>
    <td class="achievement-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="${month}" data-has-target="false">
      <input type="number"
             step="any"
             inputmode="decimal"
             name="new_targets[${rowIndex}][achievements][${month}][achievement]"
             placeholder="Value"
             class="achievement-input border border-gray-300 p-2 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
             >
    </td>
    <td class="total-achievement-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="${month}" data-has-target="false" data-target-value="">
      <span class="total-achievement-value text-gray-400">-</span>
    </td>
    <td class="remarks-cell px-3 py-3 text-sm text-center border-r border-gray-200 month-cell" data-month="${month}" data-has-target="false">
      <textarea name="new_targets[${rowIndex}][achievements][${month}][employee_remarks]"
                placeholder="EMP RM"
                rows="1"
                maxlength="<%= UserDetailsController::REMARKS_MAX_LENGTH %>"
                class="remarks-textarea border border-gray-300 p-1 rounded-lg w-full bg-gray-50 focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 text-xs resize-none"
                ></textarea>
    </td>
  `;
  }).join('');

  return `
    <tr class="bg-white hover:bg-gray-100 transition-colors duration-200 activity-row" data-activity="" data-targets="{}" data-has-any-target="false" data-new-row="true" data-manual-kri-month="${selectedMonth}">
      <td class="serial-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center"></td>
      <td class="activity-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
        <div class="flex items-start gap-2">
          <input type="text"
                 name="new_targets[${rowIndex}][activity_name]"
                 class="new-kri-name border border-gray-300 p-2 rounded-lg w-full bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm"
                 placeholder="Key result indicators"
                 required>
          <button type="button" class="remove-new-kri-row inline-flex items-center justify-center px-3 py-2 bg-red-600 hover:bg-red-700 text-white text-xs font-semibold rounded-lg">
            Remove
          </button>
        </div>
      </td>
      <td class="unit-column px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
        <input type="text"
               name="new_targets[${rowIndex}][unit]"
               class="border border-gray-300 p-2 rounded-lg w-full bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-center"
               placeholder="Unit of measurement">
      </td>
      <td class="annual-target-column px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
        <input type="text"
               name="new_targets[${rowIndex}][annual_target_fy]"
               class="border border-gray-300 p-2 rounded-lg w-full bg-white focus:border-indigo-500 focus:ring-indigo-200 transition-all duration-200 text-sm text-center"
               placeholder="Annual target">
      </td>
      ${monthCells}
    </tr>
  `;
}

function updateNewRowTargetState(input) {
  const row = input.closest('.activity-row');
  const month = input.dataset.month;
  const targetValue = input.value.trim();
  const hasTarget = hasFilledTargetValue(targetValue);
  const isNewRow = row?.dataset.newRow === 'true';
  const targetCell = input.closest('.target-cell');
  const achievementInput = row?.querySelector(`.achievement-cell[data-month="${month}"] .achievement-input`);
  const remarksInput = row?.querySelector(`.remarks-cell[data-month="${month}"] .remarks-textarea`);
  const totalCell = row?.querySelector(`.total-achievement-cell[data-month="${month}"]`);

  if (targetCell) targetCell.dataset.hasTarget = String(hasTarget);
  if (totalCell) {
    totalCell.dataset.hasTarget = String(hasTarget);
    totalCell.dataset.targetValue = targetValue;
  }
  if (achievementInput) achievementInput.disabled = !isNewRow && !hasTarget;
  if (remarksInput) remarksInput.disabled = !isNewRow && !hasTarget;
  if (typeof updateMonthlyAchievementRemarksRequirements === 'function') {
    updateMonthlyAchievementRemarksRequirements();
  }

  const targets = {};
  row?.querySelectorAll('.target-input').forEach(targetInput => {
    const value = targetInput.value.trim();
    if (hasFilledTargetValue(value)) targets[targetInput.dataset.month] = value;
  });
  if (row) {
    row.dataset.targets = JSON.stringify(targets);
    row.dataset.hasAnyTarget = Object.keys(targets).length > 0 ? 'true' : 'false';
  }

  if (!hasTarget && !isNewRow && achievementInput) achievementInput.value = '';
  if (!hasTarget && !isNewRow && remarksInput) remarksInput.value = '';
  if (achievementInput) updateTotalAchievementCell(achievementInput);
  updateMonthlySummaryRows();
}

function initializeNewKriRows() {
  const addButton = document.getElementById('addKriRowBtn');
  const tableBody = document.getElementById('activityTableBody');
  if (!addButton || !tableBody) return;

  if (achievementEntryLocked) {
    addButton.disabled = true;
    addButton.title = '<%= j(@achievement_entry_lock_message || "This month is locked after L1 approval.") %>';
    return;
  }

  if (addButton.dataset.bound === 'true') return;
  addButton.dataset.bound = 'true';

  let newKriRowIndex = Date.now();
  const maxNewRows = parseInt(addButton.dataset.kriLimit || '0', 10);

  function updateAddKriButtonState() {
    const newRowsCount = tableBody.querySelectorAll('.activity-row[data-new-row="true"]').length;
    const limitReached = maxNewRows <= 0 || newRowsCount >= maxNewRows;
    addButton.disabled = maxNewRows <= 0 || limitReached;
    const selectedMonth = selectedSubmissionMonthValue();
    addButton.title = addButton.disabled
      ? (maxNewRows <= 0 ? `Maximum 3 key result indicator rows already added for ${monthLabel(selectedMonth)}` : 'Maximum 3 key result indicator rows allowed for this month')
      : `You can add ${maxNewRows - newRowsCount} more key result indicator row(s) for ${monthLabel(selectedMonth)}`;
  }

  addButton.addEventListener('click', () => {
    const newRowsCount = tableBody.querySelectorAll('.activity-row[data-new-row="true"]').length;
    if (newRowsCount >= maxNewRows) {
      showMessage('warning', 'Add key result indicator limit', `You can add maximum 3 key result indicator rows for ${monthLabel(selectedSubmissionMonthValue())}.`);
      updateAddKriButtonState();
      return;
    }

    const summaryRow = tableBody.querySelector('.monthly-summary-footer');
    const template = document.createElement('tbody');
    template.innerHTML = newKriRowHtml(newKriRowIndex++).trim();
    const newRow = template.firstElementChild;
    tableBody.insertBefore(newRow, summaryRow);
    updateActivityRowSerials();
    applySelectedMonthVisibilityToRow(newRow);
    initializeTotalAchievementCalculations();
    updateAddKriButtonState();
    newRow?.querySelector('.new-kri-name')?.focus();
  });

  tableBody.addEventListener('click', (event) => {
    const removeButton = event.target.closest('.remove-new-kri-row');
    if (!removeButton) return;

    removeButton.closest('tr')?.remove();
    updateActivityRowSerials();
    updateMonthlySummaryRows();
    updateAddKriButtonState();
  });

  tableBody.addEventListener('input', (event) => {
    if (event.target.classList.contains('target-input')) {
      updateNewRowTargetState(event.target);
      return;
    }

    if (event.target.classList.contains('new-kri-name')) {
      const row = event.target.closest('.activity-row');
      if (row) row.dataset.activity = event.target.value.trim();
    }
  });

  updateAddKriButtonState();
}

function updateTotalAchievementCell(input) {
  const achievementCell = input.closest('td');
  const targetCell = achievementCell?.previousElementSibling;
  const totalCell = achievementCell?.nextElementSibling;
  const valueElement = totalCell?.querySelector('.total-achievement-value');

  if (!targetCell || !totalCell || !valueElement) return;

  const targetValue = parseAchievementNumber(totalCell.dataset.targetValue || targetCell.querySelector('.target-input')?.value || targetCell.textContent);
  const achievementValue = parseAchievementNumber(input.value);

  if (targetValue === null || targetValue <= 0 || achievementValue === null) {
    valueElement.textContent = '-';
    valueElement.className = 'total-achievement-value text-gray-400';
    updateMonthlySummaryRows();
    return;
  }

  const percentage = (achievementValue / targetValue) * 100;
  valueElement.textContent = formatAchievementPercentage(percentage);
  valueElement.className = 'total-achievement-value text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded';

  updateMonthlySummaryRows();
}

function setSummaryText(element, value, placeholderClass = 'text-gray-300') {
  if (!element) return;
  const baseClass = Array.from(element.classList).find(className => className.startsWith('summary-')) || 'summary-value';

  if (value === null || value === undefined) {
    element.textContent = '-';
    element.className = `${baseClass} ${placeholderClass}`.trim();
    return;
  }

  element.textContent = Number.isFinite(value) ? formatAchievementNumber(value) : value;
  element.className = `${baseClass} text-white`;
}

function formatAchievementNumber(value) {
  if (!Number.isFinite(value)) return '-';

  const roundedValue = Math.round(value * 100) / 100;
  return Number.isInteger(roundedValue) ? String(roundedValue) : roundedValue.toFixed(2);
}

function visibleActivityRows() {
  return Array.from(document.querySelectorAll('.activity-row')).filter(row => {
    return row.style.display !== 'none' &&
      !row.hasAttribute('data-activity-hidden') &&
      !row.hasAttribute('data-filtered-hidden');
  });
}

function updateMonthlySummaryRows() {
  const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
  const rows = visibleActivityRows();

  months.forEach(month => {
    let progressTotal = 0;
    let progressCount = 0;

    rows.forEach(row => {
      const targetCell = row.querySelector(`.target-cell[data-month="${month}"]`);
      const achievementInput = row.querySelector(`.achievement-cell[data-month="${month}"] .achievement-input`);
      const targetValue = parseAchievementNumber(targetCell?.querySelector('.target-input')?.value || targetCell?.textContent);
      const achievementValue = parseAchievementNumber(achievementInput?.value);

      if (targetValue !== null && targetValue > 0) {
        progressTotal += achievementValue !== null ? Math.floor(((achievementValue / targetValue) * 100) * 100) / 100 : 0;
        progressCount += 1;
      }
    });

    const targetSummaryCell = document.querySelector(`.monthly-summary-target[data-summary-month="${month}"]`);
    const achievementSummaryCell = document.querySelector(`.monthly-summary-achievement[data-summary-month="${month}"]`);
    const totalElement = document.querySelector(`.monthly-summary-total[data-summary-month="${month}"] .summary-total-achievement-value`);

    if (targetSummaryCell) targetSummaryCell.textContent = '';
    if (achievementSummaryCell) achievementSummaryCell.textContent = '';

    if (totalElement) {
      if (progressCount > 0) {
        totalElement.textContent = formatAchievementPercentage(progressTotal / progressCount);
        totalElement.className = 'summary-total-achievement-value text-emerald-900 font-bold bg-emerald-100 px-2 py-1 rounded';
      } else {
        totalElement.textContent = '-';
        totalElement.className = 'summary-total-achievement-value text-gray-300';
      }
    }
  });
}

function updateAllTotalAchievementCells() {
  document.querySelectorAll('.achievement-input').forEach(input => {
    updateTotalAchievementCell(input);
  });

  updateMonthlySummaryRows();
}

function initializeTotalAchievementCalculations() {
  updateAllTotalAchievementCells();

  document.querySelectorAll('.achievement-input').forEach(input => {
    if (input.dataset.totalAchievementBound === 'true') return;

    input.addEventListener('input', () => {
      updateTotalAchievementCell(input);
      updateMonthlySummaryRows();
    });
    input.dataset.totalAchievementBound = 'true';
  });

  updateMonthlySummaryRows();
}

function submissionTargetValueForRow(row, month) {
  const targetCell = row?.querySelector(`.target-cell[data-month="${month}"]`);
  if (!targetCell) return '';

  const targetInput = targetCell.querySelector('.target-input');
  const rawValue = targetInput ? targetInput.value : targetCell.querySelector('.target-static-value')?.textContent || targetCell.textContent;
  const value = String(rawValue || '').trim();

  return value === '-' ? '' : value;
}

function rowKriName(row) {
  const newKriName = row?.querySelector('.new-kri-name')?.value.trim();
  if (newKriName) return newKriName;

  const activityCell = row?.querySelector('.activity-cell');
  return activityCell ? activityCell.textContent.replace(/\s*Remove\s*$/, '').trim() : 'selected key result indicator';
}

function clearMonthlyAchievementRemarksValidation() {
  document.querySelectorAll('.achievement-input, .remarks-textarea').forEach(input => {
    input.classList.remove('border-red-500', 'ring-2', 'ring-red-200');
  });
}

function updateMonthlyAchievementRemarksRequirements() {
  const selectedMonth = selectedSubmissionMonthValue();
  if (!selectedMonth) return;

  document.querySelectorAll('#activityTableBody .activity-row').forEach(row => {
    const achievementInput = row.querySelector(`.achievement-cell[data-month="${selectedMonth}"] .achievement-input`);
    const remarksInput = row.querySelector(`.remarks-cell[data-month="${selectedMonth}"] .remarks-textarea`);
    if (!achievementInput || !remarksInput || achievementInput.disabled || remarksInput.disabled) return;

    const targetValue = submissionTargetValueForRow(row, selectedMonth);
    const needsRemarks = hasFilledTargetValue(targetValue) && achievementInput.value.trim() === '';
    remarksInput.required = needsRemarks;
    remarksInput.placeholder = needsRemarks ? 'EMP RM required' : 'EMP RM';
  });
}

function validateBlankAchievementRemarks(selectedMonth) {
  clearMonthlyAchievementRemarksValidation();
  updateMonthlyAchievementRemarksRequirements();

  const invalidRow = Array.from(document.querySelectorAll('#activityTableBody .activity-row')).find(row => {
    const achievementInput = row.querySelector(`.achievement-cell[data-month="${selectedMonth}"] .achievement-input`);
    const remarksInput = row.querySelector(`.remarks-cell[data-month="${selectedMonth}"] .remarks-textarea`);
    if (!achievementInput || !remarksInput || achievementInput.disabled || remarksInput.disabled) return false;

    const targetValue = submissionTargetValueForRow(row, selectedMonth);
    return hasFilledTargetValue(targetValue) && achievementInput.value.trim() === '' && remarksInput.value.trim() === '';
  });

  if (!invalidRow) return true;

  const achievementInput = invalidRow.querySelector(`.achievement-cell[data-month="${selectedMonth}"] .achievement-input`);
  const remarksInput = invalidRow.querySelector(`.remarks-cell[data-month="${selectedMonth}"] .remarks-textarea`);
  achievementInput?.classList.add('border-red-500', 'ring-2', 'ring-red-200');
  remarksInput?.classList.add('border-red-500', 'ring-2', 'ring-red-200');

  showMessage('warning', 'Remarks required', `${monthLabel(selectedMonth)}: Please enter employee remarks when Achievement is blank for ${rowKriName(invalidRow)}.`);
  remarksInput?.focus();
  return false;
}

function initializeAchievementRemarksRequirements() {
  const form = document.getElementById('achievementForm');
  if (!form || form.dataset.remarksRequirementBound === 'true') return;

  form.dataset.remarksRequirementBound = 'true';
  form.addEventListener('input', event => {
    if (event.target.matches('.achievement-input, .remarks-textarea, .target-input')) {
      clearMonthlyAchievementRemarksValidation();
      updateMonthlyAchievementRemarksRequirements();
    }
  });

  updateMonthlyAchievementRemarksRequirements();
}

// Form submission handling
function handleAchievementFormSubmission() {
  const form = document.getElementById('achievementForm');
  const submitBtn = document.getElementById('submitBtn');
  
  console.log('Form found:', form ? 'Yes' : 'No');
  console.log('Submit button found:', submitBtn ? 'Yes' : 'No');
  
  if (!form) return;
  
  // Form validation
  form.addEventListener('submit', function(e) {
    console.log('Form submit event triggered');
    console.log('Form action:', form.action);
    console.log('Form method:', form.method);
    e.preventDefault();

    if (achievementEntryLocked) {
      showMessage('warning', 'Month locked', '<%= j(@achievement_entry_lock_message || "This month is locked after L1 approval.") %>');
      resetSubmitButton();
      return;
    }
    
    // Show loading state
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Submitting...';
    }
    
    // Check if any data is entered
    const selectedMonthForSubmit = selectedSubmissionMonthValue();
    if (!selectedMonthForSubmit) {
      showMessage('warning', 'Month required', 'Please select a month and click Show Month before submitting.');
      resetSubmitButton();
      return;
    }

    const selectedSubmissionMonth = document.getElementById('selectedSubmissionMonth');
    if (selectedSubmissionMonth) selectedSubmissionMonth.value = selectedMonthForSubmit;

    const achievementInputs = document.querySelectorAll(`.achievement-cell[data-month="${selectedMonthForSubmit}"] .achievement-input:not([disabled])`);
    const targetInputs = document.querySelectorAll(`.target-cell[data-month="${selectedMonthForSubmit}"] .target-input`);
    const newKriNameInputs = document.querySelectorAll('.new-kri-name');
    const remarksInputs = document.querySelectorAll(`.remarks-cell[data-month="${selectedMonthForSubmit}"] .remarks-textarea:not([disabled])`);
    let hasAnyData = false;

    if (!validateBlankAchievementRemarks(selectedMonthForSubmit)) {
      resetSubmitButton();
      return;
    }
    
    achievementInputs.forEach(input => {
      if (input.value && input.value.trim() !== '') {
        hasAnyData = true;
      }
    });

    targetInputs.forEach(input => {
      const originalValue = input.dataset.originalValue || '';
      if (input.value.trim() !== originalValue) {
        hasAnyData = true;
      }
    });

    newKriNameInputs.forEach(input => {
      if (input.value && input.value.trim() !== '') {
        hasAnyData = true;
      }
    });

    remarksInputs.forEach(input => {
      if (input.value && input.value.trim() !== '') {
        hasAnyData = true;
      }
    });
    
    if (!hasAnyData) {
      showMessage('warning', 'No Data Entered', 'Please enter at least one achievement, employee remark, or new key result indicator target before submitting.');
      resetSubmitButton();
      return;
    }

    const incompleteNewRow = Array.from(document.querySelectorAll('.activity-row[data-new-row="true"]')).find(row => {
      const hasAnyField = Array.from(row.querySelectorAll('input, textarea')).some(input => input.value.trim() !== '');
      const hasKriName = row.querySelector('.new-kri-name')?.value.trim() !== '';
      return hasAnyField && !hasKriName;
    });

    if (incompleteNewRow) {
      showMessage('warning', 'Key result indicator required', 'Please enter key result indicators before submitting the new row.');
      incompleteNewRow.querySelector('.new-kri-name')?.focus();
      resetSubmitButton();
      return;
    }

    const invalidAchievement = Array.from(achievementInputs).find(input => {
      return input.value.trim() !== '' && !/^-?\d+(?:\.\d+)?$/.test(input.value.trim());
    });

    if (invalidAchievement) {
      showMessage('warning', 'Invalid Achievement', 'Achievement value must be a number only.');
      invalidAchievement.focus();
      resetSubmitButton();
      return;
    }
    
    // Submit form via AJAX
    const formData = new FormData(form);
    formData.set('month', selectedMonthForSubmit);
    
    // Debug: Log form data
    console.log('Form data entries:');
    for (let [key, value] of formData.entries()) {
      console.log(key, value);
    }
    
    // Get CSRF token from the hidden field in the form
    let csrfToken = document.querySelector('input[name="authenticity_token"]')?.value;
    
    console.log('CSRF Token found:', csrfToken ? 'Yes' : 'No');
    console.log('CSRF Token value:', csrfToken);
    
    if (!csrfToken) {
      showMessage('error', 'CSRF Error', 'CSRF token not found. Please refresh the page and try again.');
      resetSubmitButton();
      return;
    }
    
    fetch(form.action, {
      method: 'POST',
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': csrfToken
      }
    })
    .then(response => {
      if (!response.ok) {
        // Handle HTTP errors (like 500)
        if (response.status === 500) {
          throw new Error('Server error (500). Please check the server logs.');
        }
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return response.json();
    })
    .then(data => {
      if (data.success) {
        showMessage('success', 'Success!', data.message || 'Achievements have been submitted successfully.');
        
        updateAllTotalAchievementCells();
        
        // Update the Submitted Achievements table immediately
        updateSubmittedAchievementsTable();
        
        // Optional: Scroll to success message
        document.getElementById('successMessage').scrollIntoView({ behavior: 'smooth' });
      } else {
        showMessage('error', 'Error!', data.message || 'There was an error submitting achievements. Please try again.');
      }
    })
    .catch(error => {
      console.error('Form submission error:', error);
      if (error.message.includes('Server error (500)')) {
        showMessage('error', 'Server Error', 'There was a server error. Please contact the administrator or try again later.');
      } else if (error.message.includes('JSON')) {
        showMessage('error', 'Response Error', 'The server returned an invalid response. Please try again.');
      } else if (error.message.includes('CSRF')) {
        showMessage('error', 'CSRF Error', 'Security token error. Please refresh the page and try again.');
      } else {
        showMessage('error', 'Network Error', 'There was an error submitting achievements. Please try again.');
      }
    })
    .finally(() => {
      resetSubmitButton();
    });
  });
}

function resetSubmitButton() {
  const submitBtn = document.getElementById('submitBtn');
  if (submitBtn) {
    if (achievementEntryLocked) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Submit achievements';
      return;
    }

    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Submit achievements';
  }
}

// Initialize form handling
function initializeAchievementForm() {
  handleAchievementFormSubmission();
  initializeNewKriRows();
  initializeTotalAchievementCalculations();
  initializeAchievementRemarksRequirements();
  
  // Check for flash messages from controller
  checkForFlashMessages();
}

function checkForFlashMessages() {
  // Check if there are any flash messages in the page
  const flashSuccess = document.querySelector('.alert-success, .notice, [data-flash="success"]');
  const flashError = document.querySelector('.alert-danger, .alert-error, [data-flash="error"]');
  const flashWarning = document.querySelector('.alert-warning, [data-flash="warning"]');
  
  if (flashSuccess) {
    showMessage('success', 'Success!', flashSuccess.textContent.trim());
    flashSuccess.remove();
  }
  
  if (flashError) {
    showMessage('error', 'Error!', flashError.textContent.trim());
    flashError.remove();
  }
  
  if (flashWarning) {
    showMessage('warning', 'Warning!', flashWarning.textContent.trim());
    flashWarning.remove();
  }
}

// Function to update the Submitted Achievements table
function updateSubmittedAchievementsTable() {
  // Get the current form data to update the table
  const form = document.getElementById('achievementForm');
  if (!form) return;
  
  const formData = new FormData(form);
  const achievements = {};
  const selectedMonth = document.getElementById('monthFilter')?.value || formData.get('month');
  
  // Parse form data to get achievements
  for (let [key, value] of formData.entries()) {
    if (key.startsWith('achievement[') && key.includes('][achievement]')) {
      if (value && value.trim() !== '') {
        // Extract detail_id and month from key like "achievement[123][april][achievement]"
        const matches = key.match(/achievement\[(\d+)\]\[(\w+)\]\[achievement\]/);
        if (matches) {
          const detailId = matches[1];
          const month = matches[2];
          
          if (!achievements[detailId]) {
            achievements[detailId] = {};
          }
          achievements[detailId][month] = value.trim();
        }
      }
    }
  }
  
  // Update the Submitted Achievements table rows
  Object.keys(achievements).forEach(detailId => {
    const tableRow = document.querySelector(`tr[data-detail-id="${detailId}"]`);
    if (tableRow) {
      // Update the achievement values in the table
      Object.keys(achievements[detailId]).forEach(month => {
        const achievementValue = achievements[detailId][month];
        
        // Find all cells in the row and look for achievement cells
        const allCells = tableRow.querySelectorAll('td');
        let monthIndex = -1;
        
        // Find the month index by looking at the month headers
        const monthHeaders = document.querySelectorAll('.month-header');
        monthHeaders.forEach((header, index) => {
          if (header.dataset.month === month) {
            monthIndex = index;
          }
        });
        
        if (monthIndex !== -1) {
          // Fixed cells: S.No, key result indicator, unit of measurement, annual target. Achievement is second in each month group.
          const achievementCellIndex = 4 + (monthIndex * 4) + 1;
          if (allCells[achievementCellIndex]) {
            allCells[achievementCellIndex].innerHTML = `<span class="text-green-700 font-semibold bg-green-50 px-2 py-1 rounded">${achievementValue}</span>`;
          }
        }
      });
      
      if (selectedMonth) {
        tableRow.setAttribute(`data-${selectedMonth}-status`, 'submitted');
      }

      const statusSpan = tableRow.querySelector('.status-column span');
      if (statusSpan) {
        statusSpan.className = 'inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border bg-blue-100 text-blue-800 border-blue-300';
        statusSpan.innerHTML = '<i class="fas fa-paper-plane mr-1 text-xs"></i>Submitted';
      }
    }
  });
  
  console.log('Submitted Achievements table updated with new data');
}

document.addEventListener('turbo:load', function() {

    // A function to set up all the event listeners for the page
    function initializePage() {
        // Function to populate activities
        function populateActivityDropdown() {
            const activityRows = document.querySelectorAll('.activity-row');
            const activities = new Set();
            
            activityRows.forEach(row => {
                const activity = row.dataset.activity;
                if (activity && activity.trim() !== '') {
                    activities.add(activity);
                }
            });
            
            const activityFilter = document.getElementById('activityFilter');
            if (!activityFilter) return; // Guard clause
            
            // Clear existing options except the first one
            while (activityFilter.children.length > 1) {
                activityFilter.removeChild(activityFilter.lastChild);
            }
            
            // Populate activity dropdown
            activities.forEach(activity => {
                const option = document.createElement('option');
                option.value = activity;
                option.textContent = activity;
                activityFilter.appendChild(option);
            });
        }
        
        // Month mapping
        const monthMapping = {
            'april': 0, 'may': 1, 'june': 2, 'july': 3, 'august': 4, 'september': 5,
            'october': 6, 'november': 7, 'december': 8, 'january': 9, 'february': 10, 'march': 11
        };
        const quarterMonths = {
            'april-june': ['april', 'may', 'june'],
            'july-september': ['july', 'august', 'september'],
            'october-december': ['october', 'november', 'december'],
            'january-march': ['january', 'february', 'march']
        };
        const monthToQuarter = {
            april: 'april-june',
            may: 'april-june',
            june: 'april-june',
            july: 'july-september',
            august: 'july-september',
            september: 'july-september',
            october: 'october-december',
            november: 'october-december',
            december: 'october-december',
            january: 'january-march',
            february: 'january-march',
            march: 'january-march'
        };
        
        // FIXED: Function to update status based on month filter
        function updateStatusBasedOnMonth() {
            const monthFilter = document.getElementById('monthFilter');
            if (!monthFilter) return;
            
            const selectedMonth = monthFilter.value;
            const submittedRows = document.querySelectorAll('.submitted-activity-row');
            
            submittedRows.forEach(row => {
                const statusColumn = row.querySelector('.status-column span');
                if (!statusColumn) return;
                
                if (selectedMonth) {
                    // Get status for the specific month
                    const monthStatus = row.getAttribute(`data-${selectedMonth}-status`);
                    
                    if (monthStatus && monthStatus !== 'no_data') {
                        // Update status display for specific month
                        let statusConfig;
                        
                        switch (monthStatus) {
                            case "pending":
                                statusConfig = { 
                                    color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                    text: "Pending", 
                                    icon: "fas fa-clock" 
                                };
                                break;
                            case "l1_approved":
                                statusConfig = { 
                                    color: "bg-green-100 text-green-800 border-green-300", 
                                    text: "L1 Approved", 
                                    icon: "fas fa-check-circle" 
                                };
                                break;
                            case "l1_returned":
                                statusConfig = { 
                                    color: "bg-red-100 text-red-800 border-red-300", 
                                    text: "L1 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "l2_approved":
                                statusConfig = { 
                                    color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                    text: "L2 Approved", 
                                    icon: "fas fa-check-double" 
                                };
                                break;
                            case "l2_returned":
                                statusConfig = { 
                                    color: "bg-orange-100 text-orange-800 border-orange-300", 
                                    text: "L2 Returned", 
                                    icon: "fas fa-exclamation-triangle" 
                                };
                                break;
                            case "submitted":
                                statusConfig = { 
                                    color: "bg-blue-100 text-blue-800 border-blue-300", 
                                    text: "Submitted", 
                                    icon: "fas fa-paper-plane" 
                                };
                                break;
                            default:
                                statusConfig = { 
                                    color: "bg-gray-100 text-gray-600 border-gray-300", 
                                    text: "No Data", 
                                    icon: "fas fa-question-circle" 
                                };
                        }
                        
                        // Update the status badge
                        statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                        statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                        
                    } else {
                        // No data for this month
                        statusColumn.className = "inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border bg-gray-100 text-gray-600 border-gray-300";
                        statusColumn.innerHTML = '<i class="fas fa-question-circle mr-1 text-xs"></i>No Data';
                    }
                } else {
                    // Reset to original overall status when no month filter is applied
                    // Get all month statuses for this row
                    const allStatuses = [];
                    const months = ['april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december', 'january', 'february', 'march'];
                    
                    months.forEach(month => {
                        const monthStatus = row.getAttribute(`data-${month}-status`);
                        if (monthStatus && monthStatus !== 'no_data') {
                            allStatuses.push(monthStatus);
                        }
                    });
                    
                    // Determine overall status
                    let overallStatus = "pending";
                    if (allStatuses.includes("l2_approved")) {
                        overallStatus = "l2_approved";
                    } else if (allStatuses.includes("l1_approved")) {
                        overallStatus = "l1_approved";
                    } else if (allStatuses.includes("l2_returned")) {
                        overallStatus = "l2_returned";
                    } else if (allStatuses.includes("l1_returned")) {
                        overallStatus = "l1_returned";
                    } else if (allStatuses.includes("submitted")) {
                        overallStatus = "submitted";
                    }
                    
                    let statusConfig;
                    switch (overallStatus) {
                        case "pending":
                            statusConfig = { 
                                color: "bg-yellow-100 text-yellow-800 border-yellow-300", 
                                text: "Pending", 
                                icon: "fas fa-clock" 
                            };
                            break;
                        case "l1_approved":
                            statusConfig = { 
                                color: "bg-green-100 text-green-800 border-green-300", 
                                text: "L1 Approved", 
                                icon: "fas fa-check-circle" 
                            };
                            break;
                        case "l1_returned":
                            statusConfig = { 
                                color: "bg-red-100 text-red-800 border-red-300", 
                                text: "L1 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "l2_approved":
                            statusConfig = { 
                                color: "bg-emerald-100 text-emerald-800 border-emerald-300", 
                                text: "L2 Approved", 
                                icon: "fas fa-check-double" 
                            };
                            break;
                        case "l2_returned":
                            statusConfig = { 
                                color: "bg-orange-100 text-orange-800 border-orange-300", 
                                text: "L2 Returned", 
                                icon: "fas fa-exclamation-triangle" 
                            };
                            break;
                        case "submitted":
                            statusConfig = { 
                                color: "bg-blue-100 text-blue-800 border-blue-300", 
                                text: "Submitted", 
                                icon: "fas fa-paper-plane" 
                            };
                            break;
                        default:
                            statusConfig = { 
                                color: "bg-gray-100 text-gray-600 border-gray-300", 
                                text: "No Status", 
                                icon: "fas fa-question-circle" 
                            };
                    }
                    
                    // Update the status badge
                    statusColumn.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${statusConfig.color}`;
                    statusColumn.innerHTML = `<i class="${statusConfig.icon} mr-1 text-xs"></i>${statusConfig.text}`;
                }
            });
        }
        
        // Modal functionality
        // Modal functionality - Simplified to avoid conflicts with quarterly modal
        function setupModal() {
            // This function is kept for compatibility but the quarterly modal handles its own functionality
            console.log('Basic modal setup completed - quarterly modal is handling details');
        }
        
        function filterTable() {
            const activityFilter = document.getElementById('activityFilter');
            const quarterFilter = document.getElementById('quarterFilter');
            const monthFilter = document.getElementById('monthFilter');
            if (!activityFilter || !quarterFilter || !monthFilter) return; // Guard clause

            const selectedActivity = activityFilter.value;
            const selectedMonth = monthFilter.value || '<%= @selected_month.to_s %>';
            const selectedQuarter = monthToQuarter[selectedMonth] || '';
            quarterFilter.value = selectedQuarter;
            
            // Filter activity rows
            document.querySelectorAll('.activity-row').forEach(row => {
                if (row.dataset.newRow === 'true') {
                    const manualMonth = row.dataset.manualKriMonth;
                    if (!manualMonth || manualMonth === selectedMonth) {
                        row.removeAttribute('data-filtered-hidden');
                        row.style.display = '';
                    } else {
                        row.setAttribute('data-filtered-hidden', 'true');
                        row.style.display = 'none';
                    }
                    return;
                }

                if (row.dataset.manualKri === 'true' && row.dataset.manualKriMonth) {
                    const shouldShowManualKri = row.dataset.manualKriMonth === selectedMonth;
                    if (!shouldShowManualKri) {
                        row.setAttribute('data-filtered-hidden', 'true');
                        row.style.display = 'none';
                    } else {
                        row.removeAttribute('data-filtered-hidden');
                        row.style.display = '';
                    }
                    return;
                }

                const rowActivity = row.dataset.activity;
                const shouldShowActivity = !selectedActivity || rowActivity === selectedActivity;

                let targets = {};
                try {
                    targets = JSON.parse(row.dataset.targets || '{}');
                } catch (error) {
                    targets = {};
                }

                const hasTargetForMonth = typeof hasFilledTargetValue === 'function'
                    ? hasFilledTargetValue(targets[selectedMonth])
                    : false;

                if (!shouldShowActivity || !hasTargetForMonth) {
                    row.setAttribute('data-filtered-hidden', 'true');
                    row.style.display = 'none';
                } else {
                    row.removeAttribute('data-filtered-hidden');
                    row.style.display = '';
                }
            });
            
            // Filter submitted activity rows
            document.querySelectorAll('.submitted-activity-row').forEach(row => {
                const rowActivity = row.dataset.activity;
                const shouldShowRow = !selectedActivity || rowActivity === selectedActivity;
                row.style.display = shouldShowRow ? '' : 'none';
            });

            document.querySelectorAll('.quarter-header').forEach(header => {
                header.style.display = 'none';
            });
            
            // Filter month columns
            document.querySelectorAll('.month-header, .submitted-month-header').forEach((header, index) => {
                const monthName = header.dataset.month || Object.keys(monthMapping)[index];
                header.style.display = monthName === selectedMonth ? '' : 'none';
            });
            
            document.querySelectorAll('.month-subheader, .submitted-month-subheader').forEach((subheader, index) => {
                const monthName = subheader.dataset.month || Object.keys(monthMapping)[Math.floor(index / 3)];
                subheader.style.display = monthName === selectedMonth ? '' : 'none';
            });
            
            document.querySelectorAll('.month-cell, .submitted-month-cell').forEach(cell => {
                cell.style.display = cell.dataset.month === selectedMonth ? '' : 'none';
            });
            
            // FIXED: Update status after filtering
            updateStatusBasedOnMonth();

            if (typeof updateMonthlySummaryRows === 'function') {
                updateMonthlySummaryRows();
            }
        }

        function resetAllFilters() {
             const activityFilter = document.getElementById('activityFilter');
             const quarterFilter = document.getElementById('quarterFilter');
             const monthFilter = document.getElementById('monthFilter');
             if (activityFilter) activityFilter.value = '';
             if (monthFilter) monthFilter.value = '<%= @selected_month.to_s %>';
             if (quarterFilter) quarterFilter.value = monthToQuarter[monthFilter?.value || '<%= @selected_month.to_s %>'] || '';
             filterTable(); // Apply the reset state
        }
        
        // --- Setup ---
        // Setup modal functionality
        setupModal();

        // Filtering is handled by initializeAchievementFilters()
    }
    
    // Run the setup function for the page
    initializePage();
    
    // Initialize achievement form handling
    initializeAchievementForm();
  });
</script>
