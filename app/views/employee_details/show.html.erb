<!-- Employee Detail show l1 View - Quarterly Support with FIXED Modal -->
<% if @employee_detail.nil? %>
  <div class="main-content bg-gray-50 min-h-screen">
    <div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
      <div class="text-center py-12">
        <i class="fas fa-exclamation-triangle text-6xl text-red-500 mb-4"></i>
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Employee Detail Not Found</h2>
        <p class="text-gray-600 mb-6">The employee detail you're looking for may have been deleted or doesn't exist.</p>
        <%= link_to "← Back to Employee List", employee_details_path, class: "inline-flex items-center px-6 py-3 bg-gray-700 text-white font-semibold rounded-lg hover:bg-gray-800 transition duration-200" %>
      </div>
    </div>
  </div>
<% else %>
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <h2 class="text-3xl font-bold text-gray-800 flex items-center">
        <i class="fas fa-user-circle mr-3 text-gray-600"></i>
        Employee Detail
      </h2>
      <% if @observer_context %>
        <% observer_back_path = observer_pli_index_path(@observer_level, financial_year: @selected_financial_year, quarter: @selected_quarter, month: @selected_month) %>
        <%= link_to observer_back_path,
            class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold border border-gray-300 transition-all duration-200 self-start md:self-center" do %>
          <i class="fas fa-arrow-left"></i>
          Back to <%= @observer_title %>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Status Message Container -->
  <div id="statusMessage" class="hidden mb-4 p-4 rounded-lg"></div>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Employee Code</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_code.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Employee Name</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_name.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Department</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.department.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Post</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.post.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Location</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.location.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Financial Year</p>
      <p class="text-sm font-semibold text-gray-900"><%= @selected_financial_year.presence || "All" %></p>
    </div>
  </div>

  <% if @user_details.any? %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
          <% if params[:month].present? %>
            <%= short_month_label(params[:month]) %> Achievement Details
          <% elsif params[:quarter].present? %>
            Quarter Achievement Details
          <% else %>
            Submitted Achievements
          <% end %>
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <%
            # Define months to display based on quarter or all months if no quarter is specified
            display_months = if params[:month].present?
                              [[params[:month].to_s.downcase.to_sym, short_month_label(params[:month])]]
                            elsif params[:quarter].present?
                              case params[:quarter]
                              when 'Q1'
                                [[:april, 'APR'], [:may, 'MAY'], [:june, 'JUN']]
                              when 'Q2'
                                [[:july, 'JUL'], [:august, 'AUG'], [:september, 'SEP']]
                              when 'Q3'
                                [[:october, 'OCT'], [:november, 'NOV'], [:december, 'DEC']]
                              when 'Q4'
                                [[:january, 'JAN'], [:february, 'FEB'], [:march, 'MAR']]
                              else
                                []
                              end
                            else
                              # Fallback to a default or all months if no quarter is specified
                              [[:april, 'APR'], [:may, 'MAY'], [:june, 'JUN']] # Defaulting to Q1 for example
                            end
            monthly_summary_totals = display_months.each_with_object({}) do |(month_symbol, _), totals|
              totals[month_symbol] = { progress_sum: 0.0, progress_count: 0 }
            end
            target_present_for_display = lambda do |detail, month_symbol|
              target_value = detail.public_send(month_symbol)
              target_text = target_value.to_s.delete(",").strip
              target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
              target_value.present? && (!target_is_numeric || target_text.to_f.positive?)
            end
          %>
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="serial-column sticky-col px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">S.No</th>
                <th class="kri-column sticky-col px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Key result indicators</th>
                <th class="unit-column sticky-col px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit of Measurement</th>
                <th class="annual-target-column sticky-col px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600"><%= annual_target_fy_label(@selected_financial_year) %></th>

                <!-- DYNAMIC MONTH COLUMNS -->
                <% display_months.each do |month_symbol, month_name| %>
                  <th class="month-target-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Target</th>
                  <th class="month-achievement-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Achievement</th>
                  <th class="month-progress-column px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700">% Progress</th>
                  <th class="remarks-header px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= employee_remarks_column_label %></th>
                  <% observer_levels_for_display(@employee_detail).each do |obs_level| %>
                    <th class="observer-remarks-column manager-remarks-header px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label(observer_column_label(obs_level)) %></th>
                  <% end %>
                  <% unless @observer_context %>
                    <th class="l1-remarks-column manager-remarks-header px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L1") %></th>
                  <% end %>
                  <% if l2_reviewer_assigned?(@employee_detail) && !@observer_context %>
                    <th class="l2-remarks-column manager-remarks-header px-4 py-3 text-center text-xs font-medium text-white tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L2") %></th>
                  <% end %>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% visible_detail_index = 0 %>
              <% @user_details.each do |detail| %>
                <% 
                  existing_achievements = detail.achievements.index_by(&:month)
                  has_quarterly_data = detail.activity.present? && display_months.any? { |month_symbol, _| target_present_for_display.call(detail, month_symbol) }
                %>
                <% if has_quarterly_data %>
                  <% visible_detail_index += 1 %>
                  <tr class="<%= visible_detail_index.odd? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <td class="serial-cell sticky-col px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= visible_detail_index %>
                    </td>
                    <td class="kri-cell sticky-col px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <div class="kri-cell-inner">
                        <span class="activity-name"><%= detail.activity&.activity_name || 'N/A' %></span>
                      </div>
                    </td>
                    <td class="unit-cell sticky-col px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= detail.activity&.unit || '' %>
                    </td>
                    <td class="annual-target-cell sticky-col px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= annual_target_display(detail.activity) %>
                    </td>

                    <!-- Dynamic Month Data Columns -->
                    <% display_months.each do |month_symbol, month_name| %>
                      <%
                        target_value = detail.send(month_symbol)
                        target_text = target_value.to_s.delete(",").strip
                        target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
                        has_target = target_value.present? && (!target_is_numeric || target_text.to_f.positive?)
                        achievement_record = existing_achievements[month_symbol.to_s]
                        achievement_value = achievement_record&.achievement
                        employee_remarks = achievement_record&.employee_remarks
                        l1_manager_remarks = achievement_record&.achievement_remark&.reporting_manager_remarks
                        obs_remarks_by_level = ApplicationHelper::OBSERVER_LEVELS.index_with do |obs_level|
                          achievement_record&.achievement_remark&.public_send("#{obs_level}_remarks")
                        end
                        l2_manager_remarks = achievement_record&.achievement_remark&.l2_remarks
                        target_number = target_is_numeric ? target_text.to_f : 0.0
                        achievement_number = achievement_value.to_s.delete(",").to_f
                        progress_percentage = has_target && target_number.positive? && achievement_value.present? ? (((achievement_number / target_number) * 100.0 * 100).floor / 100.0) : nil
                        if has_target && target_number.positive?
                          monthly_summary_totals[month_symbol][:progress_sum] += (progress_percentage || 0.0)
                          monthly_summary_totals[month_symbol][:progress_count] += 1
                        end
                      %>
                      <!-- Target -->
                      <td class="month-target-cell px-4 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Achievement -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 achievement-cell">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>

                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 progress-cell">
                        <span class="<%= progress_percentage ? 'text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= progress_percentage ? "#{format('%.2f', progress_percentage)}%" : '-' %>
                        </span>
                      </td>
                      
                      <!-- Remarks -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 remarks-cell">
                        <% if employee_remarks.present? %>
                          <div class="text-blue-700 text-xs break-words remarks-text leading-snug">
                            <%= employee_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>

                      <% observer_levels_for_display(@employee_detail).each do |obs_level| %>
                        <% obs_remarks = obs_remarks_by_level[obs_level] %>
                        <% obs_assigned = observer_assigned_for_display?(@employee_detail, obs_level) %>
                        <td class="px-4 py-3 text-sm text-center border-r border-gray-200 observer-remarks-cell">
                          <% if @observer_context && @observer_level == obs_level %>
                            <% if @can_observer_approve_or_return %>
                              <textarea
                                form="observerForm"
                                class="observer-remarks-input w-full rounded border border-gray-300 p-2 text-xs focus:border-sky-500 focus:ring-2 focus:ring-sky-100"
                                rows="2"
                                maxlength="500"
                                name="observer_remarks[<%= detail.id %>][<%= month_symbol %>]"
                                placeholder="<%= observer_column_label(obs_level) %> remarks"><%= obs_remarks %></textarea>
                            <% elsif obs_remarks.present? %>
                              <div class="text-sky-700 font-medium bg-sky-50 px-2 py-1 rounded text-xs break-words max-w-full overflow-hidden" style="word-wrap: break-word; word-break: break-word; hyphens: auto; max-width: 300px;">
                                <%= obs_remarks %>
                              </div>
                            <% else %>
                              <span class="text-gray-400 text-xs">-</span>
                            <% end %>
                          <% elsif !@observer_context && obs_assigned && obs_remarks.present? %>
                            <div class="text-sky-700 text-xs break-words max-w-[110px] mx-auto leading-snug">
                              <%= obs_remarks %>
                            </div>
                          <% else %>
                            <span class="text-gray-400 text-xs">-</span>
                          <% end %>
                        </td>
                      <% end %>

                      <% unless @observer_context %>
                      <td class="l1-remarks-cell px-4 py-3 text-sm text-center border-r border-gray-200 reporting-manager-remarks-cell">
                        <% if @can_approve_or_return && (achievement_record.blank? || (achievement_record.status.presence || "pending") == "pending") %>
                          <textarea
                            class="l1-reporting-manager-remarks-input w-full min-w-[220px] rounded border border-gray-300 p-2 text-xs focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100"
                            rows="2"
                            maxlength="500"
                            data-user-detail-id="<%= detail.id %>"
                            data-month="<%= month_symbol %>"
                            placeholder="L1 remarks"><%= l1_manager_remarks %></textarea>
                        <% elsif l1_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words max-w-full overflow-hidden" style="word-wrap: break-word; word-break: break-word; hyphens: auto; max-width: 300px;">
                            <%= l1_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>
                      <% end %>

                      <% if l2_reviewer_assigned?(@employee_detail) && !@observer_context %>
                        <td class="px-4 py-3 text-sm text-center border-r border-gray-200 reporting-manager-remarks-cell">
                          <% if l2_manager_remarks.present? %>
                            <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words max-w-full overflow-hidden" style="word-wrap: break-word; word-break: break-word; hyphens: auto; max-width: 300px;">
                              <%= l2_manager_remarks %>
                            </div>
                          <% else %>
                            <span class="text-gray-400 text-xs">-</span>
                          <% end %>
                        </td>
                      <% end %>

                    <% end %>
                  </tr>
                <% end %>
              <% end %>
              <% if visible_detail_index.positive? %>
                <tr class="monthly-summary-footer bg-gray-100">
                  <td colspan="4" class="sticky-col summary-sticky-footer px-4 py-3 text-right text-sm font-bold text-gray-800 border-r border-gray-200">Total</td>
                  <% display_months.each do |month_symbol, month_name| %>
                    <%
                      month_total = monthly_summary_totals[month_symbol]
                      progress_total = if month_total[:progress_count].positive?
                        (((month_total[:progress_sum] / month_total[:progress_count]) * 100).floor / 100.0)
                      end
                    %>
                    <td class="monthly-summary-target px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <td class="monthly-summary-achievement px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <td class="monthly-summary-total px-4 py-3 text-center text-sm font-bold border-r border-gray-200" data-summary-month="<%= month_symbol %>">
                      <span class="<%= progress_total ? 'summary-total-progress-value text-emerald-900 font-bold bg-emerald-100 px-2 py-1 rounded' : 'summary-total-progress-value text-gray-400' %>">
                        <%= progress_total ? "#{format('%.2f', progress_total)}%" : '-' %>
                      </span>
                    </td>
                    <td class="monthly-summary-remarks px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <% observer_levels_for_display(@employee_detail).each do |obs_level| %>
                      <td class="monthly-summary-observer px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <% end %>
                    <% unless @observer_context %>
                      <td class="monthly-summary-l1 px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <% end %>
                    <% if l2_reviewer_assigned?(@employee_detail) && !@observer_context %>
                      <td class="monthly-summary-l2 px-4 py-3 text-center text-sm font-bold border-r border-gray-200"></td>
                    <% end %>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

<%
  review_progress_percentage = nil
  if defined?(monthly_summary_totals) && monthly_summary_totals.present?
    review_progress_sum = monthly_summary_totals.values.sum { |total| total[:progress_sum].to_f }
    review_progress_count = monthly_summary_totals.values.sum { |total| total[:progress_count].to_i }
    if review_progress_count.positive?
      review_progress_percentage = ((review_progress_sum / review_progress_count) * 100).floor / 100.0
    end
  end
%>

<!-- FIXED: Single Overall Status Display for Quarter -->
<% if params[:quarter].present? %>
  <%
    quarter_months = if params[:month].present?
                   [params[:month].to_s.downcase]
                   else
                   case params[:quarter]
                   when 'Q1'
                     ['april', 'may', 'june']
                   when 'Q2'
                     ['july', 'august', 'september']
                   when 'Q3'
                     ['october', 'november', 'december']
                   when 'Q4'
                     ['january', 'february', 'march']
                   else
                     []
                   end
                   end

    # Calculate quarterly data - collect all statuses for the quarter
    quarterly_statuses = []
    quarter_l1_total = 0
    quarter_l2_total = 0
    quarter_achievement_count = 0
    quarter_remarks_l1 = Set.new
    quarter_remarks_l2 = Set.new
    
    @user_details.each do |detail|
      quarter_achievements = detail.achievements.select { |a| quarter_months.include?(a.month) }
      quarter_achievements.each do |achievement|
        quarterly_statuses << (achievement.status || "pending")
        
        
        
        if achievement.achievement_remark.present?
          quarter_achievement_count += 1
          
          # Collect L1 data
          if achievement.achievement_remark.l1_percentage.present?
            quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
          end
          
          # Add unique L1 remarks only
          if achievement.achievement_remark.l1_remarks.present?
            quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
          end
          
          # Collect L2 data
          if achievement.achievement_remark.l2_percentage.present?
            quarter_l2_total += achievement.achievement_remark.l2_percentage.to_f
          end
          
          # Add unique L2 remarks only
          if achievement.achievement_remark.l2_remarks.present?
            quarter_remarks_l2.add(achievement.achievement_remark.l2_remarks)
          end
        end
      end
    end
    
    # Determine overall quarter status (single status for entire quarter)
    overall_quarter_status = "pending"
    if quarterly_statuses.any?
      # FIXED: Quarter status logic - check for actual approval data, not just status strings
      
      
      
      # FIXED: L2 statuses should take highest priority
      # If ANY month has L2 approved, the quarter is L2 approved
      if quarterly_statuses.include?("l2_approved")
        overall_quarter_status = "l2_approved"

      # If ANY month has L2 returned, the quarter is L2 returned
      elsif quarterly_statuses.include?("l2_returned")
        overall_quarter_status = "l2_returned"

      # If ALL months are L1 approved, the quarter is L1 approved
      elsif quarterly_statuses.all? { |s| s == "l1_approved" }
        overall_quarter_status = "l1_approved"

      # If ANY month has L1 returned, the quarter is L1 returned
      elsif quarterly_statuses.any? { |s| s == "l1_returned" }
        overall_quarter_status = "l1_returned"

      # Check if L1 has approved the quarter (has percentage and remarks) even if some months are pending
      # BUT only if no months are returned
      elsif quarter_l1_total > 0 && quarter_remarks_l1.any? && !quarterly_statuses.any? { |s| ["l1_returned", "l2_returned"].include?(s) }
        overall_quarter_status = "l1_approved"

      # Check for submitted status
      elsif quarterly_statuses.any? { |s| s == "submitted" }
        overall_quarter_status = "submitted"

      # If any month is pending, the quarter is pending
      elsif quarterly_statuses.any? { |s| s == "pending" }
        # FIXED: If ANY month is pending, the entire quarter is pending
        overall_quarter_status = "pending"

      end
      
  
    end

    status_config = case overall_quarter_status
    when "pending"
      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
    when "l1_approved"
      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
    when "l1_returned"
      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
    when "l2_approved"
      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
    when "l2_returned"
      { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
    when "submitted"
      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
    else
      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
    end
    
    # Calculate averages
    quarter_l1_average = quarter_achievement_count > 0 ? (quarter_l1_total / quarter_achievement_count).round(1) : 0.0
    quarter_l2_average = quarter_achievement_count > 0 ? (quarter_l2_total / quarter_achievement_count).round(1) : 0.0
    
    # Convert Sets to Arrays for display
    quarter_remarks_l1_array = quarter_remarks_l1.to_a
    quarter_remarks_l2_array = quarter_remarks_l2.to_a
