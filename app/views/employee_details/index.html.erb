<div class="main-content sidebar-hidden">
  <div class="min-h-screen pl-64 pr-4 pt-4 pb-12 overflow-x-auto bg-gray-100">
    <!-- Flash Messages -->
    <% if flash[:notice] %>
      <div class="bg-green-100 text-green-800 px-4 py-2 rounded mb-4 mt-4 w-full max-w-7xl mx-auto">
        <%= flash[:notice] %>
      </div>
    <% elsif flash[:alert] %>
      <div class="bg-red-100 text-red-800 px-4 py-2 rounded mb-4 mt-4 w-full max-w-7xl mx-auto">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Bulk Upload and Export Buttons -->
    <div class="w-full max-w-7xl mx-auto mt-4 flex justify-between items-center bg-white p-6 rounded-xl shadow">
      <%= form_with(url: import_employee_details_path, local: true, html: { multipart: true }, class: "flex flex-col gap-2") do |f| %>
        <div class="flex space-x-4 items-center">
          <%= f.file_field :file, class: "block w-full border border-gray-300 rounded-lg px-4 py-2" %>
          <%= f.submit "Upload Excel", class: "bg-gray-700 text-white px-4 py-2 rounded-lg hover:bg-gray-800" %>
        </div>
        <p class="text-xs text-gray-500">Single-sheet and multi-sheet Excel files are supported; every sheet with the same header format will be imported.</p>
      <% end %>

      <div class="flex space-x-4">
        <%= link_to(export_quarterly_xlsx_employee_details_path,
                    class: "inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg shadow-md transition duration-200 transform hover:scale-105") do %>
          <i class="fas fa-file-excel mr-2"></i>
          Export Quarterly L1 Data
        <% end %>
        
        <%= link_to "Export to Excel", export_xlsx_employee_details_path(format: :xlsx), class: "bg-gray-700 text-white px-4 py-2 rounded hover:bg-gray-800" %>
      </div>
    </div>

    <!-- Form to Add Employee -->
    <div class="w-full max-w-7xl mx-auto bg-white p-8 rounded-xl shadow-lg mt-8">
      <h2 class="text-3xl font-bold text-gray-800 mb-8 border-b pb-2">Add Employee Details</h2>

      <%= form_with(model: @employee_detail, url: employee_details_path, local: true, data: { turbo: false }) do |form| %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% [:employee_name, :employee_email, :mobile_number, :employee_code,
              :l1_code, :l1_employer_name, :obs_code1, :obs_code2, :obs_code3, :obs_code4, :post, :location, :department].each do |field| %>
            <div>
              <%= form.label field, field.to_s.titleize, class: "block text-sm font-semibold text-gray-700 mb-1" %>
              <%= form.text_field field, class: "form-control w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500" %>
            </div>
          <% end %>
        </div>

        <div class="mt-8 flex justify-end space-x-4">
          <%= link_to 'Cancel', employee_details_path, class: "btn btn-secondary px-5 py-2 bg-gray-200 text-gray-800 font-semibold rounded-lg hover:bg-gray-300" %>
          <%= form.submit "Save Employee", class: "btn btn-primary px-5 py-2 bg-gray-700 text-white font-semibold rounded-lg hover:bg-gray-800 shadow" %>
        </div>
      <% end %>
    </div>

    <!-- Employee List -->
    <a name="employee-list"></a>
    <div id="employee-list" class="w-full max-w-7xl mx-auto bg-white p-8 rounded-xl shadow-lg mt-12">
      <!-- Heading and Search Box -->
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-800 border-b pb-2">Employee List</h2>
      <%= search_form_for(@q, url: employee_details_path, method: :get, html: { class: "flex items-center space-x-2", id: "search-form" }) do |f| %>
        <%= f.search_field :employee_name_or_employee_email_or_employee_code_or_obs_code1_or_obs_code2_or_obs_code3_or_obs_code4_or_post_or_location_or_department_cont,
          placeholder: "Search anything...",
          class: "px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500",
          id: "global-search" %>
      <% end %>


      </div>

      <% employee_search_params = params[:q].respond_to?(:to_unsafe_h) ? params[:q].to_unsafe_h : {} %>
      <% employee_search_signature = employee_search_params.to_query %>
      <%= form_with(url: bulk_update_portal_status_employee_details_path,
                    method: :post,
                    authenticity_token: true,
                    local: true,
                    data: { turbo: false },
                    html: { id: "employee-bulk-status-form", data: { search_signature: employee_search_signature } },
                    class: "mb-4 flex flex-wrap items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3") do %>
        <%= hidden_field_tag :_method, "patch", id: "employee-bulk-method" %>
        <%= hidden_field_tag :selection_scope, "current_page", id: "employee-selection-scope" %>
        <% employee_search_params.each do |key, value| %>
          <%= hidden_field_tag "q[#{key}]", value %>
        <% end %>
        <span class="text-sm font-semibold text-gray-700">Selected employees:</span>
        <%= button_tag "Mark Active",
                       type: "submit",
                       name: "portal_active",
                       value: "true",
                       data: { bulk_action: "status" },
                       class: "rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700" %>
        <%= button_tag "Mark Inactive",
                       type: "submit",
                       name: "portal_active",
                       value: "false",
                       data: { bulk_action: "status" },
                       class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700" %>
        <%= button_tag "Delete All",
                       type: "submit",
                       data: { bulk_action: "delete", delete_url: bulk_destroy_employee_details_path },
                       class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-black" %>
        <span id="employee-bulk-selection-note" class="hidden text-xs font-semibold text-red-700">
          Select All is ON: action will apply to all filtered employees across pagination.
        </span>
      <% end %>

      <div class="overflow-x-auto">
        <table class="table table-striped table-bordered min-w-full divide-y divide-gray-200 border text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">
                <input type="checkbox" id="select-all-employees" class="h-4 w-4 rounded border-gray-300 text-gray-700">
              </th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Mobile</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Emp Code</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">L1 Code </th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">L1 Name</th>
              <!-- L2 columns hidden as requested -->
              <!-- <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">L2 Code</th> -->
              <!-- <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">L2 Name</th> -->
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">OBS Code 1</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">OBS Code 2</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">OBS Code 3</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">OBS Code 4</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Post</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Location</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Department</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Login Status</th>
              <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @employee_details.each do |emp| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-4 py-4 whitespace-nowrap">
                  <%= check_box_tag "employee_detail_ids[]",
                                    emp.id,
                                    false,
                                    form: "employee-bulk-status-form",
                                    class: "employee-select h-4 w-4 rounded border-gray-300 text-gray-700" %>
                </td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.employee_name %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.employee_email %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.mobile_number %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.employee_code %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.l1_code %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.l1_employer_name %></td>
                <!-- L2 columns hidden as requested -->
                <!-- <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.l2_code %></td> -->
                <!-- <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.l2_employer_name %></td> -->
                <% %i[obs_code1 obs_code2 obs_code3 obs_code4].each do |observer_field| %>
                  <%
                    observer_code = emp.public_send(observer_field).to_s.strip
                    observer_name = @observer_names_by_code[observer_code.downcase]
                  %>
                  <td class="px-4 py-4 whitespace-nowrap text-gray-900">
                    <div class="font-medium"><%= observer_code.presence || "-" %></div>
                    <% if observer_name.present? %>
                      <div class="text-xs text-gray-500"><%= observer_name %></div>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.post %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.location %></td>
                <td class="px-4 py-4 whitespace-nowrap text-gray-900"><%= emp.department %></td>
                <td class="px-4 py-4 whitespace-nowrap">
                  <% if emp.portal_active? %>
                    <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">Active</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">Inactive</span>
                  <% end %>
                </td>
                <td class="px-4 py-4 whitespace-nowrap space-x-2">
                  <%= link_to 'Edit', edit_employee_detail_path(emp), class: "text-gray-700 hover:text-gray-900 font-medium" %>
                  <%= button_to(emp.portal_active? ? "Inactive" : "Active",
                                toggle_portal_status_employee_detail_path(emp),
                                method: :patch,
                                form: { class: "inline-block" },
                                class: emp.portal_active? ? "text-orange-600 hover:text-orange-900 font-medium" : "text-green-600 hover:text-green-900 font-medium") %>
                  <%= link_to 'Delete', '#', 
                      onclick: "confirmDelete('#{emp.employee_name}', '#{employee_detail_path(emp)}')", 
                      class: "text-red-600 hover:text-red-900 font-medium cursor-pointer" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="mt-6 flex justify-center">
        <%= paginate @employee_details, params: request.query_parameters.merge(anchor: 'employee-list') %>
      </div>
    </div>
  </div>
</div>

<script>
  window.initializeEmployeeBulkControls = function () {
    const selectAllStorageKey = "employeeBulkSelectAll";
    const searchInput = document.getElementById("global-search");
    const searchForm = document.getElementById("search-form");
    const bulkForm = document.getElementById("employee-bulk-status-form");
    const bulkMethod = document.getElementById("employee-bulk-method");
    const selectionScope = document.getElementById("employee-selection-scope");
    const selectionNote = document.getElementById("employee-bulk-selection-note");
    const selectAll = document.getElementById("select-all-employees");
    const employeeCheckboxes = Array.from(document.querySelectorAll(".employee-select"));
    const statusUrl = bulkForm?.action;
    const searchSignature = bulkForm?.dataset.searchSignature || "";

    function clearStoredBulkSelectAll() {
      try {
        sessionStorage.removeItem(selectAllStorageKey);
      } catch (error) {
        // Ignore storage failures; the form still works for the current page.
      }
    }

    if (searchInput && searchForm && searchForm.dataset.employeeSearchInitialized !== "true") {
      searchForm.dataset.employeeSearchInitialized = "true";
      let timeout = null;

      searchInput.addEventListener("input", function () {
        clearStoredBulkSelectAll();
        clearTimeout(timeout);
        timeout = setTimeout(() => {
          searchForm.submit();
        }, 300); // delay (in ms) after typing stops
      });

      searchForm.addEventListener("submit", clearStoredBulkSelectAll);
    }

    if (!bulkForm || bulkForm.dataset.employeeBulkInitialized === "true") {
      return;
    }

    bulkForm.dataset.employeeBulkInitialized = "true";

    function getStoredSelectAllState() {
      try {
        return JSON.parse(sessionStorage.getItem(selectAllStorageKey) || "null");
      } catch (error) {
        return null;
      }
    }

    function setStoredSelectAll(active) {
      try {
        if (active) {
          sessionStorage.setItem(selectAllStorageKey, JSON.stringify({
            active: true,
            searchSignature: searchSignature
          }));
        } else {
          sessionStorage.removeItem(selectAllStorageKey);
        }
      } catch (error) {
        // Storage is only for pagination persistence; submit still uses hidden fields.
      }
    }

    function storedSelectAllMatchesCurrentSearch() {
      const storedState = getStoredSelectAllState();
      return storedState?.active === true && storedState.searchSignature === searchSignature;
    }

    function ensureBulkCsrfToken() {
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content");
      if (!csrfToken) return;

      let tokenInput = bulkForm.querySelector('input[name="authenticity_token"]');
      if (!tokenInput) {
        tokenInput = document.createElement("input");
        tokenInput.type = "hidden";
        tokenInput.name = "authenticity_token";
        bulkForm.appendChild(tokenInput);
      }

      tokenInput.value = csrfToken;
    }

    function setSelectionScope(scope) {
      if (selectionScope) selectionScope.value = scope;
      if (selectionNote) {
        selectionNote.classList.toggle("hidden", scope !== "all_matching");
      }
    }

    function applySelectAllMode(active) {
      employeeCheckboxes.forEach((checkbox) => {
        checkbox.checked = active;
      });

      if (selectAll) {
        selectAll.checked = active;
        selectAll.indeterminate = false;
      }

      setSelectionScope(active ? "all_matching" : "current_page");
    }

    if (storedSelectAllMatchesCurrentSearch()) {
      applySelectAllMode(true);
    }

    if (selectAll) {
      selectAll.addEventListener("change", function () {
        setStoredSelectAll(selectAll.checked);
        applySelectAllMode(selectAll.checked);
      });
    }

    employeeCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", function () {
        setStoredSelectAll(false);
        setSelectionScope("current_page");
        const checkedCount = employeeCheckboxes.filter((item) => item.checked).length;
        if (selectAll) {
          selectAll.checked = checkedCount === employeeCheckboxes.length && employeeCheckboxes.length > 0;
          selectAll.indeterminate = checkedCount > 0 && checkedCount < employeeCheckboxes.length;
        }
      });
    });

    bulkForm?.addEventListener("submit", function (event) {
      const submitter = event.submitter;
      const actionType = submitter?.dataset.bulkAction || "status";

      if (actionType === "delete") {
        const scopeText = selectionScope?.value === "all_matching" ? "all filtered employees across all pages" : "selected employees on this page";
        if (!confirm(`Are you sure you want to delete ${scopeText}? This cannot be undone.`)) {
          event.preventDefault();
          return;
        }

        bulkForm.action = submitter.dataset.deleteUrl;
        if (bulkMethod) bulkMethod.value = "delete";
      } else {
        bulkForm.action = statusUrl;
        if (bulkMethod) bulkMethod.value = "patch";
      }

      ensureBulkCsrfToken();
      setStoredSelectAll(false);
    });
  };

  if (!window.employeeBulkControlEventsBound) {
    document.addEventListener("DOMContentLoaded", function () {
      window.initializeEmployeeBulkControls();
    });
    document.addEventListener("turbo:load", function () {
      window.initializeEmployeeBulkControls();
    });
    window.employeeBulkControlEventsBound = true;
  }

  window.initializeEmployeeBulkControls();

  function confirmDelete(employeeName, deleteUrl) {
    if (confirm(`Are you sure you want to delete ${employeeName}?`)) {
      // Create a form to submit the DELETE request
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = deleteUrl;
      
      // Add the method override for DELETE
      const methodInput = document.createElement('input');
      methodInput.type = 'hidden';
      methodInput.name = '_method';
      methodInput.value = 'DELETE';
      form.appendChild(methodInput);
      
      // Add CSRF token
      const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
      if (csrfToken) {
        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = csrfToken;
        form.appendChild(csrfInput);
      }
      
      // Submit the form
      document.body.appendChild(form);
      form.submit();
    }
  }
</script>
<style>
  .min-h-screen {
    padding-left: 16rem; 
  }

  .sidebar-hidden .min-h-screen {
    padding-left: 1rem !important;
    padding-right: 1rem !important;
  }

  .sidebar-hidden .max-w-7xl {
    max-width: 100% !important;
    width: 100% !important;
  }

  .sidebar-hidden .form-control {
    width: 100% !important;
  }

  .sidebar-hidden .grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)) !important;
  }
  .main-content {
  margin-left: 240px; 
  padding: 1rem;
  overflow-x: auto;
}
</style>
