<!-- L2 Employee Detail Quarterly View with Fixed L2 Remarks Display -->
<meta name="csrf-token" content="<%= form_authenticity_token %>">
<div class="main-content bg-gray-50 min-h-screen">
<div class="p-8 bg-white rounded-xl shadow-lg border border-gray-200 mx-4">
  <div class="border-b border-gray-200 pb-6 mb-8">
    <h2 class="text-3xl font-bold text-gray-800 flex items-center">
      <i class="fas fa-user-circle mr-3 text-gray-600"></i>
      Employee Detail - L2 Review
    </h2>
  </div>

  <!-- Status Message Container -->
  <div id="statusMessage" class="hidden mb-4 p-4 rounded-lg"></div>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Employee Code</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_code.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Employee Name</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.employee_name.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Department</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.department.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Post</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.post.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Location</p>
      <p class="text-sm font-semibold text-gray-900"><%= @employee_detail.location.presence || "N/A" %></p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Financial Year</p>
      <p class="text-sm font-semibold text-gray-900"><%= @selected_financial_year.presence || "All" %></p>
    </div>
  </div>

  <%
    # Define months to display based on quarter
    display_months = if params[:month].present?
                     [[params[:month].to_s.downcase.to_sym, short_month_label(params[:month])]]
                     else
                     case params[:quarter]
                     when 'Q1'
                       [[:april, 'APR'], [:may, 'MAY'], [:june, 'JUN']]
                     when 'Q2'
                       [[:july, 'JUL'], [:august, 'AUG'], [:september, 'SEP']]
                     when 'Q3'
                       [[:october, 'OCT'], [:november, 'NOV'], [:december, 'DEC']]
                     when 'Q4'
                       [[:january, 'JAN'], [:february, 'FEB'], [:march, 'MAR']]
                     else
                     []
                     end
                     end
    monthly_summary_totals = display_months.each_with_object({}) do |(month_symbol, _), totals|
      totals[month_symbol] = { progress_sum: 0.0, progress_count: 0 }
    end

    # Calculate quarterly data - collect all statuses for the quarter
    quarterly_statuses = []
    quarter_l1_total = 0
    quarter_l2_total = 0
    quarter_achievement_count = 0
    quarter_remarks_l1 = Set.new
    quarter_remarks_l2 = Set.new
    
    if @user_details.any? && (params[:quarter].present? || params[:month].present?)
      @user_details.each do |detail|
        quarter_achievements = detail.achievements.select { |a| display_months.map { |m| m[0].to_s }.include?(a.month) }
        quarter_achievements.each do |achievement|
          quarterly_statuses << (achievement.status || "pending")
          
          if achievement.achievement_remark.present?
            quarter_achievement_count += 1
            
            # Collect L1 data
            if achievement.achievement_remark.l1_percentage.present?
              quarter_l1_total += achievement.achievement_remark.l1_percentage.to_f
            end
            
            # Add unique L1 remarks only
            if achievement.achievement_remark.l1_remarks.present?
              quarter_remarks_l1.add(achievement.achievement_remark.l1_remarks)
            end
            
            # Collect L2 data
            if achievement.achievement_remark.l2_percentage.present?
              quarter_l2_total += achievement.achievement_remark.l2_percentage.to_f
            end
            
            # Add unique L2 remarks only
            if achievement.achievement_remark.l2_remarks.present?
              quarter_remarks_l2.add(achievement.achievement_remark.l2_remarks)
            end
          end
        end
      end
    end
    
    # FIXED: Corrected status logic with L2 data detection
    overall_quarter_status = "pending"
    l2_status = "pending"  # Separate L2 status tracking
    
    # Check if L2 has provided data (percentage or remarks)
    has_l2_data = quarter_l2_total > 0 || quarter_remarks_l2.any?
    
    if quarterly_statuses.any?
      # Check for L2 actions first (highest priority)
      if quarterly_statuses.all? { |s| s == "l2_approved" } || has_l2_data
        overall_quarter_status = "l2_approved"
        l2_status = "approved"
      elsif quarterly_statuses.any? { |s| s == "l2_returned" }
        overall_quarter_status = "l2_returned" 
        l2_status = "returned"
      # Check for L1 status when L2 hasn't acted
      elsif quarterly_statuses.all? { |s| s == "l1_approved" } || 
            (quarter_l1_total > 0 && quarter_remarks_l1.any? && !quarterly_statuses.any? { |s| ["l1_returned", "l2_returned"].include?(s) })
        overall_quarter_status = "l1_approved"
        l2_status = "pending"  # L2 is still pending when L1 is approved
      elsif quarterly_statuses.any? { |s| s == "l1_returned" }
        overall_quarter_status = "l1_returned"
        l2_status = "pending"
      elsif quarterly_statuses.any? { |s| s == "submitted" }
        overall_quarter_status = "submitted"
        l2_status = "pending"
      else
        overall_quarter_status = "pending"
        l2_status = "pending"
      end
    end
    
    # Override status if L2 data exists (means L2 has acted)
    if has_l2_data && l2_status == "pending"
      overall_quarter_status = "l2_approved"
      l2_status = "approved"
    end

    status_config = case overall_quarter_status
    when "pending"
      { color: "bg-yellow-100 text-yellow-800 border-yellow-300", text: "Pending", icon: "fas fa-clock" }
    when "l1_approved"
      { color: "bg-green-100 text-green-800 border-green-300", text: "L1 Approved", icon: "fas fa-check-circle" }
    when "l1_returned"
      { color: "bg-red-100 text-red-800 border-red-300", text: "L1 Returned", icon: "fas fa-exclamation-triangle" }
    when "l2_approved"
      { color: "bg-emerald-100 text-emerald-800 border-emerald-300", text: "L2 Approved", icon: "fas fa-check-double" }
    when "l2_returned"
      { color: "bg-orange-100 text-orange-800 border-orange-300", text: "L2 Returned", icon: "fas fa-exclamation-triangle" }
    when "submitted"
      { color: "bg-blue-100 text-blue-800 border-blue-300", text: "Submitted", icon: "fas fa-paper-plane" }
    else
      { color: "bg-gray-100 text-gray-600 border-gray-300", text: "No Status", icon: "fas fa-question-circle" }
    end
    
    # Calculate averages
    quarter_l1_average = quarter_achievement_count > 0 ? (quarter_l1_total / quarter_achievement_count).round(1) : 0.0
    quarter_l2_average = quarter_achievement_count > 0 ? (quarter_l2_total / quarter_achievement_count).round(1) : 0.0
    
    # Convert Sets to Arrays for display
    quarter_remarks_l1_array = quarter_remarks_l1.to_a
    quarter_remarks_l2_array = quarter_remarks_l2.to_a
  %>

  <% if @user_details.any? && (params[:quarter].present? || params[:month].present?) %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm mt-8">
      <div class="bg-gray-100 px-6 py-4 border-b border-gray-200 rounded-t-xl">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center">
          <i class="fas fa-trophy mr-3 text-gray-600"></i>
           <%= params[:month].present? ? "#{short_month_label(params[:month])} Achievement Details" : "Quarter Achievement Details" %>
        </h2>
      </div>

      <div class="p-6">
        <div class="table-wrapper overflow-auto bg-white rounded-lg border border-gray-200">
          <table class="table table-hover w-full min-w-full">
            <thead class="bg-gray-800">
              <tr>
                <th class="serial-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">S.No</th>
                <th class="kri-column px-4 py-3 text-left text-xs font-medium text-white tracking-wider border-r border-gray-600">Key result indicators</th>
                <th class="unit-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600">Unit of Measurement</th>
                <th class="annual-target-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600"><%= annual_target_fy_label(@selected_financial_year) %></th>

                <!-- DYNAMIC MONTH COLUMNS -->
                <% display_months.each do |month_symbol, month_name| %>
                  <th class="month-target-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Target</th>
                  <th class="month-achievement-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= month_name %> Achievement</th>
                  <th class="month-progress-column px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">% Progress</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700">Employee <%= month_name %> Remarks</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L1", month_name) %></th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-white uppercase tracking-wider border-r border-gray-600 bg-gray-700"><%= manager_remarks_column_label("L2", month_name) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <%
                target_present_for_display = lambda do |detail, month_symbol|
                  target_value = detail.public_send(month_symbol)
                  target_text = target_value.to_s.delete(",").strip
                  target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
                  target_value.present? && (!target_is_numeric || target_text.to_f.positive?)
                end
                visible_detail_index = 0
              %>
              <% @user_details.each do |detail| %>
                <% 
                  existing_achievements = detail.achievements.index_by(&:month)
                  has_quarterly_data = detail.activity.present? && display_months.any? { |month_symbol, _| target_present_for_display.call(detail, month_symbol) }
                %>
                <% if has_quarterly_data %>
                  <% visible_detail_index += 1 %>
                  <tr class="<%= visible_detail_index.odd? ? 'bg-gray-50' : 'bg-white' %> hover:bg-gray-100 transition-colors duration-200">
                    <td class="serial-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= visible_detail_index %>
                    </td>
                    <td class="kri-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200">
                      <%= detail.activity&.activity_name || 'N/A' %>
                    </td>
                    <td class="unit-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= detail.activity&.unit || '' %>
                    </td>
                    <td class="annual-target-cell px-4 py-3 text-sm text-gray-800 border-r border-gray-200 text-center">
                      <%= annual_target_display(detail.activity) %>
                    </td>

                    <!-- Dynamic Month Data Columns -->
                    <% display_months.each do |month_symbol, month_name| %>
                      <%
                        target_value = detail.send(month_symbol)
                        target_text = target_value.to_s.delete(",").strip
                        target_is_numeric = target_text.match?(/\A-?\d+(?:\.\d+)?\z/)
                        has_target = target_value.present? && (!target_is_numeric || target_text.to_f.positive?)
                        achievement_record = existing_achievements[month_symbol.to_s]
                        achievement_value = achievement_record&.achievement
                        employee_remarks = achievement_record&.employee_remarks
                        l1_manager_remarks = achievement_record&.achievement_remark&.reporting_manager_remarks
                        l2_manager_remarks = achievement_record&.achievement_remark&.l2_remarks
                        l2_can_edit_month_remark = @can_l2_approve_or_return &&
                                                   achievement_record.present? &&
                                                   ["l1_approved", "l2_returned"].include?(achievement_record.status.to_s)
                        target_number = target_is_numeric ? target_text.to_f : 0.0
                        achievement_number = achievement_value.to_s.delete(",").to_f
                        progress_percentage = has_target && target_number.positive? && achievement_value.present? ? (((achievement_number / target_number) * 100.0 * 100).floor / 100.0) : nil
                        if has_target && target_number.positive?
                          monthly_summary_totals[month_symbol][:progress_sum] += (progress_percentage || 0.0)
                          monthly_summary_totals[month_symbol][:progress_count] += 1
                        end
                      %>
                      <!-- Target -->
                      <td class="month-target-cell px-4 py-3 text-sm text-gray-800 text-center border-r border-gray-200 bg-gray-50">
                        <span class="<%= target_value.presence ? 'text-gray-800 font-medium' : 'text-gray-400' %>">
                          <%= target_value.presence || '-' %>
                        </span>
                      </td>
                      
                      <!-- Achievement -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 achievement-cell">
                        <span class="<%= achievement_value.presence ? 'text-green-700 font-semibold bg-green-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= achievement_value.presence || '-' %>
                        </span>
                      </td>

                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 progress-cell">
                        <span class="<%= progress_percentage ? 'text-emerald-700 font-semibold bg-emerald-50 px-2 py-1 rounded' : 'text-gray-400' %>">
                          <%= progress_percentage ? "#{format('%.2f', progress_percentage)}%" : '-' %>
                        </span>
                      </td>
                      
                      <!-- Remarks -->
                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 remarks-cell">
                        <% if employee_remarks.present? %>
                          <div class="text-blue-700 font-medium bg-blue-50 px-2 py-1 rounded text-xs break-words">
                            <%= employee_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>

                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 reporting-manager-remarks-cell">
                        <% if l1_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words">
                            <%= l1_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>

                      <td class="px-4 py-3 text-sm text-center border-r border-gray-200 reporting-manager-remarks-cell">
                        <% if l2_can_edit_month_remark %>
                          <textarea
                            class="l2-reporting-manager-remarks-input w-full min-w-[220px] rounded border border-gray-300 p-2 text-xs focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                            rows="2"
                            maxlength="500"
                            data-user-detail-id="<%= detail.id %>"
                            data-month="<%= month_symbol %>"
                            placeholder="L2 remarks"><%= l2_manager_remarks %></textarea>
                        <% elsif l2_manager_remarks.present? %>
                          <div class="text-indigo-700 font-medium bg-indigo-50 px-2 py-1 rounded text-xs break-words">
                            <%= l2_manager_remarks %>
                          </div>
                        <% else %>
                          <span class="text-gray-400 text-xs">-</span>
                        <% end %>
                      </td>

                    <% end %>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

<%
  review_progress_percentage = nil
  if defined?(monthly_summary_totals) && monthly_summary_totals.present?
    review_progress_sum = monthly_summary_totals.values.sum { |total| total[:progress_sum].to_f }
    review_progress_count = monthly_summary_totals.values.sum { |total| total[:progress_count].to_i }
    if review_progress_count.positive?
      review_progress_percentage = ((review_progress_sum / review_progress_count) * 100).floor / 100.0
    end
  end
%>

<!-- Single Overall Status Display for Quarter -->
<% if params[:quarter].present? || params[:month].present? %>
  <% if quarterly_statuses.any? %>
    <div class="mt-8 pt-6 border-t border-gray-200" id="quarterStatusSection">
      <div class="text-center mb-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">
           <%= params[:month].present? ? "#{short_month_label(params[:month])} Overall Status" : "Quarter Overall Status" %>
           <span class="block mt-2 text-sm font-semibold text-gray-600">
             L1: <%= @employee_detail.l1_employer_name.presence || "N/A" %> | L2: <%= @employee_detail.l2_employer_name.presence || "N/A" %>
           </span>
        </h3>
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border <%= status_config[:color] %>" id="quarterStatusBadge">
          <i class="<%= status_config[:icon] %> mr-2"></i>
          <%= status_config[:text] %>
        </span>
      </div>
    </div>
  <% end %>

  <!-- L1 & L2 Summary for Quarter -->
  <% if quarter_achievement_count > 0 %>
    <%
      # Calculate SINGLE average for entire quarter
      all_quarter_achievements = []
      @user_details.each do |detail|
        quarter_achievements = detail.achievements.select { |a| display_months.map { |m| m[0].to_s }.include?(a.month) && a.achievement_remark.present? }
        all_quarter_achievements.concat(quarter_achievements)
      end

      # Show summary values from latest approve/return action (not activity-wise aggregation)
      latest_l1_remark_record = all_quarter_achievements
                                .filter_map(&:achievement_remark)
                                .select { |remark| remark.l1_remarks.present? || remark.l1_percentage.present? }
                                .max_by(&:updated_at)
      latest_l2_remark_record = all_quarter_achievements
                                .filter_map(&:achievement_remark)
                                .select { |remark| remark.l2_remarks.present? || remark.l2_percentage.present? }
                                .max_by(&:updated_at)

      l1_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l1_percentage&.to_f }
      l2_percentages = all_quarter_achievements.filter_map { |a| a.achievement_remark&.l2_percentage&.to_f }
      saved_l1_average = l1_percentages.any? ? (l1_percentages.sum / l1_percentages.size).round(1) : 0.0
      saved_l2_average = l2_percentages.any? ? (l2_percentages.sum / l2_percentages.size).round(1) : 0.0

      final_l1_average = review_progress_percentage || latest_l1_remark_record&.l1_percentage.presence&.to_f || saved_l1_average
      final_l2_average = review_progress_percentage || latest_l2_remark_record&.l2_percentage.presence&.to_f || saved_l2_average
      final_l1_average_display = format('%.2f', final_l1_average.to_f)
      final_l2_average_display = format('%.2f', final_l2_average.to_f)

      unique_l1_remarks = latest_l1_remark_record&.l1_remarks.present? ? [ latest_l1_remark_record.l1_remarks ] : []
      unique_l2_remarks = latest_l2_remark_record&.l2_remarks.present? ? [ latest_l2_remark_record.l2_remarks ] : []
    %>

    <div id="employeeSummarySections" class="review-summary-grid review-summary-grid--two mt-6">

      <!-- L1 Quarterly Summary - ALWAYS SHOW -->
      <div id="l1-summary-section" class="review-summary-card bg-gradient-to-r from-blue-50 via-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 shadow-md">
        <h3 class="text-xl font-bold text-blue-700 mb-6 flex items-center gap-2">
          <i class="fas fa-user-check text-blue-500"></i>
          <%= params[:month].present? ? "L1 #{short_month_label(params[:month])} Summary" : "L1 Quarter Summary" %> - <%= @employee_detail.l1_employer_name.presence || "N/A" %>
        </h3>

        <!-- Quarter Average Percentage -->
        <div class="mb-6 text-center">
          <div class="summary-percent-box bg-blue-200 p-4 rounded-lg inline-block">
            <p class="text-blue-600 font-semibold text-sm mb-1"><%= params[:month].present? ? "Month Average Percentage" : "Quarter Average Percentage" %></p>
            <p class="text-3xl font-bold text-blue-800"><%= final_l1_average_display %>%</p>
          </div>
        </div>

        <!-- UNIQUE L1 Remarks -->
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <h4 class="text-blue-600 font-semibold text-sm"><%= params[:month].present? ? "Month Remarks:" : "Quarter Remarks:" %></h4>
          </div>
          
          <!-- L1 Display Section -->
          <div id="l1-display-section">
            <% if unique_l1_remarks.any? %>
              <div class="stealth-edit-wrap">
                <div class="summary-remarks-box bg-white p-4 rounded border max-h-40 overflow-y-auto" id="l1-remarks-display">
                  <% unique_l1_remarks.each_with_index do |remark, index| %>
                    <div class="text-gray-700 text-sm mb-3 pb-3 <%= 'border-b border-gray-100' unless index == unique_l1_remarks.length - 1 %>">
                      <div class="flex items-start gap-2">
                        <span class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded font-medium flex-shrink-0">
                          Remark <%= index + 1 %>
                        </span>
                        <span class="text-gray-700"><%= remark %></span>
                      </div>
                    </div>
                  <% end %>
                </div>
                <% if current_user.hod? %>
                  <button type="button" onclick="editL1Remarks()" class="stealth-edit-point stealth-edit-point-blue" aria-label="Edit L1 quarter remarks"></button>
                <% end %>
              </div>
            <% else %>
              <div class="stealth-edit-wrap">
                <div class="summary-remarks-box bg-white p-4 rounded border" id="l1-remarks-container">
                  <p class="text-gray-500 text-sm">No remarks for this <%= params[:month].present? ? "month" : "quarter" %></p>
                </div>
                <% if current_user.hod? %>
                  <button type="button" onclick="editL1Remarks()" class="stealth-edit-point stealth-edit-point-blue" aria-label="Edit L1 quarter remarks"></button>
                <% end %>
              </div>
            <% end %>
          </div>
          
          <!-- L1 Edit Form (Hidden by default) -->
          <% if current_user.hod? %>
            <div id="l1-edit-form" class="hidden bg-white p-4 rounded border">
              <form id="l1-edit-form-content" onsubmit="updateL1Data(event)">
                <div class="mb-4">
                  <label for="l1_edit_percentage" class="block text-sm font-medium text-gray-700 mb-1">L1 Percentage:</label>
