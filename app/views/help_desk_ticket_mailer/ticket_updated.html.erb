<p>Hello <%= @ticket.requester_name %>,</p>

<p>
  Your help desk <%= @ticket.request_label.downcase %> is now
  <strong><%= @ticket.status.to_s.humanize %></strong> with
  <strong><%= @ticket.department.department_type %></strong>.
</p>

<% if @ticket.assigned_to_user.present? %>
  <p>Current owner: <%= @ticket.assigned_to_user.display_name %> (<%= @ticket.current_escalation_label %>).</p>
<% end %>

<% if @ticket.response_message.present? %>
  <p><strong>Latest update:</strong></p>
  <%= simple_format(@ticket.response_message) %>
<% end %>

<p>Reference: <%= @ticket.ticket_reference %></p>
