<div class="activity-fields border border-gray-200 rounded-md p-4 mb-4 bg-gray-50">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div>
      <%= f.label :activity_id, "Key result indicator ID", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :activity_id, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter activity ID" %>
    </div>
    <div>
      <%= f.label :activity_name, "Key result indicators", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :activity_name, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter key result indicators" %>
    </div>
    <%= f.hidden_field :theme_name, value: "" %>
    
    <div>
      <%= f.label :unit, "Unit of measurement", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :unit, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter unit of measurement (optional)" %>
    </div>
    <div>
      <%= f.label :annual_target_fy, annual_target_fy_label(@selected_financial_year), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :annual_target_fy, class: "mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter annual target" %>
    </div>
  </div>
  <div class="mt-3 flex justify-end">
    <button type="button" class="remove-activity inline-flex items-center px-3 py-1 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
      </svg>
      Remove
    </button>
  </div>
  <%= f.hidden_field :_destroy, value: 0 %>
</div>
