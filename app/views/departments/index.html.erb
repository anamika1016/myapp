  async editDepartment(employeeId) {
    console.log('editDepartment called with Employee ID:', employeeId);
    try {
      const csrfToken = document.querySelector('input[name="authenticity_token"]')?.value || 
                       document.querySelector('meta[name="csrf-token"]')?.content || '';
      
      if (!csrfToken) {
        this.showError('CSRF token not found. Please refresh the page.');
        return;
      }
      
      // Add cache-busting parameter to ensure fresh data
      const timestamp = Date.now();
      const selectedFinancialYear = document.getElementById('department_financial_year')?.value || new URL(window.location).searchParams.get('financial_year') || '';
      const response = await fetch(`/departments/${employeeId}/edit_data?t=${timestamp}&financial_year=${encodeURIComponent(selectedFinancialYear)}`, {
        headers: {
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json', // Request JSON response
          'Cache-Control': 'no-cache, no-store, must-revalidate',
          'Pragma': 'no-cache'
        }
      });
      console.log('Edit response status:', response.status);
      console.log('Edit response headers:', response.headers);
      
      if (response.ok) {
        const department = await response.json();
        console.log('Department data received:', department);
        console.log('Number of activities received:', department.activities ? department.activities.length : 0);
        if (department.activities) {
          department.activities.forEach((activity, index) => {
            console.log(`Activity ${index}:`, activity);
          });
        }
        this.populateForm(department);
      } else {
        console.error('Edit request failed:', response.status, response.statusText);
        const errorText = await response.text();
        console.error('Error response body:', errorText);
        this.showError(`Error loading department data: ${response.status} ${response.statusText}`);
      }
    } catch (error) {
      console.error('Edit error:', error);
      this.showError('Error loading department data');
    }
  }

  populateForm(department) {
    console.log('=== POPULATING FORM ===');
    console.log('Department data:', department);
    
    document.getElementById('department_department_type').value = department.department_type || '';
    document.getElementById('department-theme-name').value = '';
    const financialYearSelect = document.getElementById('department_financial_year');
    if (financialYearSelect && department.financial_year) {
      financialYearSelect.value = department.financial_year;
    }
    
    // First filter employees by department, then set the employee
    if (department.department_type) {
      this.filterEmployeesByDepartment(department.department_type);
      // Wait a bit for the dropdown to be populated
      setTimeout(() => {
        document.getElementById('department_employee_reference').value = department.employee_reference || '';
        console.log('Set employee reference to:', department.employee_reference);
      }, 100);
    }

    const form = document.getElementById('department-form');
    // Don't change the form action - keep it as /departments
    // The edit logic will handle the correct endpoint in handleFormSubmit
    document.getElementById('form-method').value = 'PATCH';
    
    // Update the form method to PATCH
    const methodField = document.getElementById('form-method');
    if (methodField) {
      methodField.value = 'PATCH';
    }

    const container = document.getElementById('activities-container');
    container.innerHTML = '';
    
    this.activityIndex = 0;

    if (department.activities && department.activities.length > 0) {
      console.log(`Populating form with ${department.activities.length} activities`);
      department.activities.forEach((activity, index) => {
        console.log(`Creating activity ${index}:`, activity);
        const html = this.getActivityTemplate(this.activityIndex);
        container.insertAdjacentHTML('beforeend', html);

        const currentActivity = container.lastElementChild;
        
        currentActivity.querySelector('input[name*="[theme_name]"]').value = '';
        currentActivity.querySelector('input[name*="[activity_name]"]').value = activity.activity_name || '';
        currentActivity.querySelector('input[name*="[unit]"]').value = activity.unit || '';
        currentActivity.querySelector('input[name*="[annual_target_fy]"]').value = activity.annual_target_fy || activity.annual_target_fy_2026_27 || '';
        currentActivity.querySelector('input[name*="[id]"]').value = activity.id || '';

        console.log(`Activity ${index} populated with ID: ${activity.id}, name: ${activity.activity_name}`);
        console.log(`Activity ${index} input names:`, {
          theme_name: currentActivity.querySelector('input[name*="[theme_name]"]').name,
          activity_name: currentActivity.querySelector('input[name*="[activity_name]"]').name,
          unit: currentActivity.querySelector('input[name*="[unit]"]').name,
          annual_target_fy: currentActivity.querySelector('input[name*="[annual_target_fy]"]').name,
          id: currentActivity.querySelector('input[name*="[id]"]').name
        });
        this.activityIndex++;
      });
      console.log(`Form populated with ${this.activityIndex} activities total`);
    } else {
      console.log('No activities found, adding default activity');
      this.addActivity();
    }
 
    this.isEditing = true;
    this.editingId = department.id;
    document.getElementById('submit-button').textContent = 'Update Department';
    
    document.getElementById('department-form').scrollIntoView({ behavior: 'smooth' });
  }

  async deleteDepartment(departmentId) {
    console.log('deleteDepartment called with ID:', departmentId);
    if (!confirm('Are you sure you want to delete this department?')) return;

    try {
      // Try multiple sources for CSRF token
      console.log('Looking for CSRF token...');
      
      // First try the meta tag (most reliable)
      let csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
      console.log('From meta[name="csrf-token"]:', !!csrfToken);
      
      if (!csrfToken) {
        // Try the form input
        csrfToken = document.querySelector('input[name="authenticity_token"]')?.value;
        console.log('From input[name="authenticity_token"]:', !!csrfToken);
      }
      if (!csrfToken) {
        // Try to get it from the form's hidden input
        const form = document.getElementById('department-form');
        if (form) {
          csrfToken = form.querySelector('input[name="authenticity_token"]')?.value;
          console.log('From form input[name="authenticity_token"]:', !!csrfToken);
        } else {
          console.error('Department form not found!');
        }
      }
      
      // Also try the meta tag with different name
      if (!csrfToken) {
        csrfToken = document.querySelector('meta[name="csrf-param"]')?.content;
        console.log('From meta[name="csrf-param"]:', !!csrfToken);
      }
      
      // If still no token, try to get it from the current page URL
      if (!csrfToken) {
        // Try to extract from current page's form
        const currentForm = document.querySelector('form');
        if (currentForm) {
          csrfToken = currentForm.querySelector('input[name="authenticity_token"]')?.value;
          console.log('From current page form:', !!csrfToken);
        }
      }
      
      console.log('Final CSRF Token found:', !!csrfToken);
      console.log('CSRF Token length:', csrfToken ? csrfToken.length : 0);
      console.log('CSRF Token first 10 chars:', csrfToken ? csrfToken.substring(0, 10) + '...' : 'none');
      
      if (!csrfToken) {
        console.error('No CSRF token found from any source!');
        this.showError('CSRF token not found. Please refresh the page.');
        return;
      }
      
      // Verify the token looks valid (should be a long string)
      if (csrfToken.length < 20) {
        console.error('CSRF token seems too short:', csrfToken);
        this.showError('Invalid CSRF token. Please refresh the page.');
        return;
      }
      
      // For DELETE requests, use Rails method override with POST
      console.log('Sending DELETE request to:', `/departments/${departmentId}`);
      console.log('Request method: POST (with _method override)');
      console.log('CSRF Token:', csrfToken);
      
      // Create form data with method override
      const formData = new FormData();
      formData.append('_method', 'DELETE');
      formData.append('authenticity_token', csrfToken);
      
      const response = await fetch(`/departments/${departmentId}`, {
        method: 'POST', // Use POST, let Rails handle method override
        body: formData,
        headers: {
          'Accept': 'application/json' // Request JSON response
        }
      });
      
      console.log('Delete response status:', response.status);
      console.log('Delete response headers:', response.headers);

      let result;
      try {
        result = await response.json();
        console.log('Delete response JSON:', result);
      } catch (parseError) {
        console.error('Error parsing delete response:', parseError);
        const responseText = await response.text();
        console.log('Delete response text:', responseText);
        
        // If it's HTML (likely a redirect), show success and reload
        if (responseText.includes('<html') || responseText.includes('<!DOCTYPE')) {
          this.showSuccess('Department deleted successfully! Reloading page...');
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          this.showError('Error deleting department. Please try again.');
        }
        return;
      }

      if (response.ok && result.success === true) {
        this.showSuccess(result.message || 'Department deleted successfully!');
        // Reload the page to show updated data
        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } else {
        this.showError(result.message || 'Error deleting department');
      }
    } catch (error) {
      this.showError('Network error. Please try again.');
    }
  }

  async deleteUserActivities(departmentId, employeeId) {
    console.log('deleteUserActivities called with departmentId:', departmentId, 'and employeeId:', employeeId);
    if (!confirm('Are you sure you want to delete all activities for this employee from this department? This will only affect this specific employee.')) return;

    try {
      // Use the hidden form approach to avoid CSRF issues
      const form = document.getElementById('delete-user-form');
      const employeeIdInput = document.getElementById('delete-user-employee-id');
      
      if (!form || !employeeIdInput) {
        this.showError('Delete form not found. Please refresh the page.');
        return;
      }
      
      // Set the form action and employee ID
      form.action = `/departments/${departmentId}/delete_user_activities`;
      employeeIdInput.value = employeeId;
      
      // Submit the form
      form.submit();
      
    } catch (error) {
      console.error('Error in deleteUserActivities:', error);
      this.showError('Error occurred. Please try again.');
    }
  }

  resetForm() {
    const form = document.getElementById('department-form');
    form.reset();
    form.action = '/departments';
    document.getElementById('form-method').value = 'POST';
    document.getElementById('department-theme-name').value = '';

    const container = document.getElementById('activities-container');
    container.innerHTML = '';
    this.activityIndex = 0;
    this.addActivity();

    this.isEditing = false;
    this.editingId = null;
    document.getElementById('submit-button').textContent = 'Save Department';

    // Reset employee dropdown to show all employees
    const options = document.querySelectorAll('#department_employee_reference option[data-department]');
    options.forEach(option => option.style.display = '');

    this.hideError();
    this.hideSuccess();
  }

  // Handle regular update method as fallback
  async handleRegularUpdate(formData) {
    console.log('Using regular update method as fallback...');
    
    const csrfToken = document.querySelector('input[name="authenticity_token"]')?.value || 
                     document.querySelector('meta[name="csrf-token"]')?.content || '';
    
    if (!csrfToken) {
      this.showError('CSRF token not found. Please refresh the page.');
      return;
    }
    
    const response = await fetch(`/departments/${this.editingId}`, {
      method: 'PATCH',
      body: formData,
      headers: {
        'X-CSRF-Token': csrfToken,
        'Accept': 'application/json'
      }
    });
    
    return this.handleResponse(response);
  }

  // Handle response from form submission
  async handleResponse(response) {
    console.log('Response status:', response.status);
    console.log('Response headers:', response.headers);
    console.log('Response URL:', response.url);
    
    // Check if response is a redirect
    if (response.redirected) {
      console.log('Response was redirected to:', response.url);
      this.showSuccess('Operation completed successfully! Redirecting...');
      setTimeout(() => {
        window.location.href = response.url;
      }, 1000);
      return;
    }
    
    let result;
    try {
      result = await response.json();
      console.log('Response JSON:', result);
    } catch (parseError) {
      console.error('Error parsing JSON response:', parseError);
      const responseText = await response.text();
      console.log('Response text:', responseText);
      
      // If it's HTML (likely a redirect), show success and reload
      if (responseText.includes('<html') || responseText.includes('<!DOCTYPE')) {
        this.showSuccess('Operation completed successfully! Reloading page...');
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        this.showError('Invalid response from server. Please try again.');
      }
      return;
    }

    if (response.ok && result.success === true) {
      this.showSuccess(result.message || (this.isEditing ? 'Department updated successfully!' : 'Department created successfully!'));
      this.resetForm();
      // Reload the page to show updated data
      setTimeout(() => {
        console.log('Reloading page to show updated data...');
        const selectedFinancialYear = document.getElementById('department_financial_year')?.value || new URL(window.location).searchParams.get('financial_year') || '';
        const nextUrl = new URL(window.location);
        if (selectedFinancialYear) nextUrl.searchParams.set('financial_year', selectedFinancialYear);
        window.location.href = nextUrl.toString();
      }, 1500);
    } else {
      const errors = result.errors || [result.message] || ['Error saving department. Please check your input.'];
      this.showError(Array.isArray(errors) ? errors.join(', ') : errors);
    }
  }

  updateDepartmentList() {
    const tbody = document.getElementById('departments-table');
    const emptyState = document.getElementById('empty-state');
    tbody.innerHTML = '';

    if (this.departments.length === 0) {
      emptyState?.classList.remove('hidden');
    } else {
      emptyState?.classList.add('hidden');
      this.departments.forEach(dept => {
        // Use the employee_display_name from backend if available, otherwise fallback to manual lookup
        let employeeDisplay = dept.employee_display_name || 'N/A';
        
        // Fallback: if backend doesn't provide employee_display_name, construct it manually
        if (employeeDisplay === 'N/A' && dept.employee_reference) {
          const employee = this.employees.find(emp => emp.employee_id === dept.employee_reference);
          if (employee) {
            employeeDisplay = `${employee.employee_name} (${employee.employee_code || dept.employee_reference})`;
          } else {
            employeeDisplay = `N/A (${dept.employee_reference})`;
          }
        }

        const row = document.createElement('tr');
        row.className = 'hover:bg-gray-50';
        row.dataset.departmentId = dept.id;

        row.innerHTML = `
          <td class="px-6 py-4 text-sm font-medium text-gray-900">DEPT${dept.id}</td>
          <td class="px-6 py-4 text-sm text-gray-900">${dept.department_type || 'N/A'}</td>
          <td class="px-6 py-4 text-sm text-gray-900">${employeeDisplay}</td>
          <td class="px-6 py-4 text-sm text-gray-900">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              ${dept.activities ? dept.activities.length : 0} ${dept.activities && dept.activities.length === 1 ? 'key result indicator' : 'key result indicators'}
            </span>
          </td>
          <td class="px-6 py-4 text-sm font-medium">
            <button type="button" class="edit-btn text-gray-700 hover:text-gray-900 mr-4" data-employee-id="${dept.employee_reference}">Edit</button>
            <div class="flex space-x-2">
              <button type="button" class="delete-user-btn bg-orange-100 hover:bg-orange-200 text-orange-700 hover:text-orange-800 px-2 py-1 rounded text-xs font-medium border border-orange-300" 
                      data-department-id="${dept.id}" 
                      data-employee-id="${dept.employee_reference || ''}"
                      title="Delete only this user's activities">Delete User</button>
              <button type="button" class="delete-dept-btn bg-red-100 hover:bg-red-200 text-red-700 hover:text-red-800 px-2 py-1 rounded text-xs font-medium border border-red-300" 
                      data-department-id="${dept.id}"
                      title="Delete entire department">Delete Dept</button>
            </div>
          </td>
        `;
        tbody.appendChild(row);
      });
    }
  }

  handleSearch(term) {
    const rows = document.querySelectorAll('#departments-table tr');
    term = term.toLowerCase();

    rows.forEach(row => {
      const cells = row.querySelectorAll('td');
      const match = Array.from(cells).some(cell => cell.textContent.toLowerCase().includes(term));
      row.style.display = match ? '' : 'none';
    });
  }

  handleEmployeeFilter(employeeId) {
    if (employeeId) {
      // Redirect to filtered view
      const currentUrl = new URL(window.location);
      currentUrl.searchParams.set('employee_id', employeeId);
      window.location.href = currentUrl.toString();
    } else {
      // Remove filter and show all
      const currentUrl = new URL(window.location);
      currentUrl.searchParams.delete('employee_id');
      currentUrl.searchParams.delete('employee_code');
      window.location.href = currentUrl.toString();
    }
  }

  showSuccess(message) {
    const container = document.getElementById('success-container');
    const messageSpan = document.getElementById('success-message');
    messageSpan.textContent = message;
    container.classList.remove('hidden');
    setTimeout(() => this.hideSuccess(), 5000);
  }

  hideSuccess() {
    document.getElementById('success-container')?.classList.add('hidden');
  }

  showError(message) {
    const container = document.getElementById('error-container');
    document.getElementById('error-title').textContent = 'Error occurred:';
    document.getElementById('error-list').innerHTML = `<li>${message}</li>`;
    container.classList.remove('hidden');
  }

  hideError() {
    document.getElementById('error-container')?.classList.add('hidden');
  }

  // Cleanup method to prevent memory leaks
  destroy() {
    // Remove event listeners if needed
    console.log('DepartmentManager instance destroyed');
    window.departmentManagerInstance = null;
  }
} // End of DepartmentManager class

  // Immediate check for activity box
  (function ensureActivityBoxImmediate() {
    console.log('Immediate check for activity box...');
    const container = document.getElementById('activities-container');
    if (container) {
      console.log('Activities container found with', container.children.length, 'children');
      if (container.children.length === 0) {
        console.log('No activities found immediately, will add after initialization...');
        window.needsDefaultActivity = true;
      } else {
        console.log('Default activity already present in HTML, no need to add more');
        window.needsDefaultActivity = false;
      }
    }
  })();

  function initializeDepartmentManager() {
  console.log('initializeDepartmentManager called');

  // Prevent multiple initializations
  if (window.departmentManagerInstance || isInitializing) {
    console.log('DepartmentManager already initialized or initializing, skipping...');
    return;
  }
  
  isInitializing = true;

  // Debug: Check if data is available
  console.log('Initializing DepartmentManager...');
  
  // Check if required elements exist
  const form = document.getElementById('department-form');
  const activitiesContainer = document.getElementById('activities-container');
  const addActivityBtn = document.getElementById('add-activity');
  
  console.log('Form found:', !!form);
  console.log('Activities container found:', !!activitiesContainer);
  console.log('Add activity button found:', !!addActivityBtn);
  
  // Embed employee data in page for JavaScript access
  <% if @employee_departments %>
    window.employeeDepartments = <%= raw @employee_departments.to_json %>;
    console.log('Employee departments loaded:', window.employeeDepartments);
  <% else %>
    window.employeeDepartments = [];
    console.log('No employee departments found');
  <% end %>
  
  <% if @employees %>
    window.employees = <%= raw @employees.map { |emp| { employee_name: emp.employee_name, employee_id: employee_reference_value(emp), employee_code: employee_display_code(emp), department: emp.department } }.to_json %>;
    console.log('Employees loaded:', window.employees);
  <% else %>
    window.employees = [];
    console.log('No employees found');
  <% end %>
  
  // Check if dropdowns are populated
  const deptSelect = document.getElementById('department_department_type');
  const empSelect = document.getElementById('department_employee_reference');
  
  console.log('Department dropdown options:', deptSelect ? deptSelect.options.length : 'not found');
  console.log('Employee dropdown options:', empSelect ? empSelect.options.length : 'not found');
  
      // Initialize DepartmentManager for form handling
    try {
      console.log('Creating DepartmentManager instance...');
      window.departmentManagerInstance = new DepartmentManager();
      console.log('DepartmentManager initialized successfully');

      // Check if we need to add a default activity immediately
      if (window.needsDefaultActivity) {
        console.log('Adding default activity immediately after initialization...');
        const addActivityBtn = document.getElementById('add-activity');
        if (addActivityBtn) {
          addActivityBtn.click();
        }
        window.needsDefaultActivity = false;
      } else {
        console.log('No need to add default activity, already present in HTML');
      }
      
      // Make DepartmentManager globally accessible for debugging
      // window.departmentManagerInstance is already set above
      console.log('DepartmentManager ready and accessible');
      
    } catch (error) {
      console.error('Error initializing DepartmentManager:', error);
    } finally {
      isInitializing = false;
    }
  }

  // Use only one event listener to prevent duplicates
  document.addEventListener('DOMContentLoaded', () => {
    console.log('DOM Content Loaded event fired');
    initializeDepartmentManager();
  });

  // Global function to clear employee filter
  function clearEmployeeFilter() {
    const currentUrl = new URL(window.location);
    currentUrl.searchParams.delete('employee_id');
    currentUrl.searchParams.delete('employee_code');
    window.location.href = currentUrl.toString();
  }

  // For Turbo compatibility, but only if not already initialized
  document.addEventListener('turbo:load', () => {
    if (!window.departmentManagerInstance) {
      initializeDepartmentManager();
    }
  });
} // End of if (typeof DepartmentManager === 'undefined')

// Remove turbo:render listener as it's not needed and causes duplicates
</script>

