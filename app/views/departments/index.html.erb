      console.error('Department form not found!');
    }

    const cancelBtn = document.getElementById('cancel-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.resetForm();
      });
    }

    const searchInput = document.getElementById('search-input');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        this.handleSearch(e.target.value);
      });
    }

    // Employee filter change event
    const employeeFilter = document.getElementById('employee-filter');
    if (employeeFilter) {
      employeeFilter.addEventListener('change', (e) => {
        this.handleEmployeeFilter(e.target.value);
      });
    }

    // Department change event to filter employees
    const deptSelect = document.getElementById('department_department_type');
