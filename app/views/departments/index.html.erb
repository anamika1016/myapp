<div class="main-content sidebar-hidden">
  <body class="bg-gray-50">
    <div class="ml-64 p-6 bg-gray-50 min-h-screen">
      <div class="max-w-7xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-md mb-6">
          <h2 class="text-2xl font-bold text-gray-800 mb-6">Department Management</h2>
          
          <div id="success-container" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 hidden">
            <div id="success-message"></div>
          </div>
   
          <div id="error-container" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 hidden">
            <h4 id="error-title"></h4>
            <ul id="error-list"></ul>
          </div>

          <!-- Hidden form for deleting user activities -->
          <form id="delete-user-form" method="POST" action="" style="display: none;">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            <input type="hidden" name="employee_id" id="delete-user-employee-id">
          </form>



          <!-- Bulk Upload Section -->
          <div class="bg-white p-6 rounded-lg shadow-md mb-6">
            <div class="mb-8">
              <h2 class="text-2xl font-semibold text-gray-800 mb-4">Bulk upload departments & key result indicators</h2>

              <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 w-full">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
                  
                  <form action="/departments/import" method="post" enctype="multipart/form-data" class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
                    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                    <select name="financial_year" class="border border-gray-300 p-2 rounded-md w-full sm:w-auto">
                      <% @financial_years.each do |year| %>
                        <option value="<%= year %>" <%= 'selected' if year == @selected_financial_year %>><%= year %></option>
                      <% end %>
                    </select>
                    <input type="file" name="file" accept=".xlsx,.xls,.csv" required class="border border-gray-300 p-2 rounded-md w-full sm:w-auto">
                    <input type="submit" value="Upload" class="bg-gray-700 hover:bg-gray-800 text-white font-semibold py-2 px-6 rounded shadow cursor-pointer">
                  </form>

                  <%= link_to "Export Departments",
                      export_departments_path(format: :xlsx, financial_year: @selected_financial_year),
                      class: "inline-flex items-center bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-lg shadow-md transition duration-200" %>
                </div>

                <p class="text-sm text-gray-500 mt-4 italic">
                  * Excel columns: <strong>Mobile No.</strong>, <strong>Employee name</strong>, <strong>Employee Email</strong>, <strong>Employee code</strong>, <strong>L1 Code</strong>, <strong>L1 Employer Name</strong>, <strong>L2 Code</strong>, <strong>L2 Employer Name</strong>, <strong>Key result indicators</strong>, <strong>Unit of measurement</strong>, <strong>Annual target</strong>, <strong>APR</strong> to <strong>MAR</strong>. Department is optional when employee already has a department.
                </p>
              </div>
            </div>
            
            <!-- Form Section -->
            <form id="department-form" method="POST" action="/departments">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <input type="hidden" name="_method" value="POST" id="form-method">
              <input type="hidden" name="department[theme_name]" value="" id="department-theme-name">
              
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div>
                  <label for="department_financial_year" class="block text-sm font-medium text-gray-700">
                    Financial year
                  </label>
                  <select id="department_financial_year" name="department[financial_year]"
                    class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                    <% @financial_years.each do |year| %>
                      <option value="<%= year %>" <%= 'selected' if year == @selected_financial_year %>><%= year %></option>
                    <% end %>
                  </select>
                </div>

                <!-- Department Dropdown -->
                <div>
                  <label for="department_department_type" class="block text-sm font-medium text-gray-700">
                    Department / Region
                  </label>
                  <select id="department_department_type" name="department[department_type]" 
                    class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm 
                          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                    <option value="">Select Department / Region</option>
                    <% @employee_departments.each do |dept| %>
                      <option value="<%= dept %>"><%= dept %></option>
                    <% end %>
                  </select>
                </div>

                <!-- Employee Dropdown -->
                <div>
                  <label for="department_employee_reference" class="block text-sm font-medium text-gray-700">
                    Employee name
                  </label>
                  <select id="department_employee_reference" name="department[employee_reference]" 
                    class="mt-1 block w-full border border-gray-300 rounded-md px-3 py-2 text-sm 
                          focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" required>
                    <option value="">Select Employee</option>
                    <% @employees.each do |employee| %>
                      <option value="<%= employee_reference_value(employee) %>" data-department="<%= employee.department %>">
                        <%= employee.employee_name %> (<%= employee_display_code(employee) %>)
                      </option>
                    <% end %>
                  </select>
                </div>
              </div>

                  <!-- Key result indicators section -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-lg font-semibold text-gray-800">Key result indicators</h3>
                                    <div class="flex gap-2">
                    <button type="button" id="add-activity" onclick="if(window.departmentManagerInstance && window.departmentManagerInstance.isReady && typeof window.departmentManagerInstance.addActivity === 'function') { window.departmentManagerInstance.addActivity(); } else { console.log('DepartmentManager not ready yet, retrying...'); setTimeout(() => { if(window.departmentManagerInstance && window.departmentManagerInstance.isReady && typeof window.departmentManagerInstance.addActivity === 'function') { window.departmentManagerInstance.addActivity(); } else { console.error('DepartmentManager still not available or not ready'); } }, 100); }" class="inline-flex items-center px-4 py-2 bg-gray-700 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                      </svg>
                      Add key result indicator
                    </button>

                  </div>
                </div>
                
                <div id="activities-container">
                  <!-- Default key result indicators field - will be replaced by JavaScript if needed -->
                  <div class="activity-fields border border-gray-200 rounded-md p-4 mb-4 bg-gray-50">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                      <input type="hidden" name="department[activities_attributes][default][theme_name]" value="">
                      <div>
                        <label class="block text-sm font-medium text-gray-700">Key result indicators</label>
                        <input type="text" name="department[activities_attributes][default][activity_name]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter key result indicators" required>
                      </div>
                      <div>
                        <label class="block text-sm font-medium text-gray-700">Unit of measurement</label>
                        <input type="text" name="department[activities_attributes][default][unit]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter unit of measurement">
                      </div>
                      <div>
                        <label class="block text-sm font-medium text-gray-700 annual-target-label"><%= annual_target_fy_label(@selected_financial_year) %></label>
                        <input type="text" name="department[activities_attributes][default][annual_target_fy]" class="mt-1 block w-full border rounded-md px-3 py-2 text-sm" placeholder="Enter annual target">
                      </div>
                    </div>
                    <div class="mt-3 flex justify-end">
                      <button type="button" class="remove-activity bg-red-600 text-white text-sm px-3 py-1 rounded-md hover:bg-red-700">
                        Remove
                      </button>
                    </div>
                    <input type="hidden" name="department[activities_attributes][default][id]" value="">
                    <input type="hidden" name="department[activities_attributes][default][_destroy]" value="false">
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <button type="button" id="cancel-btn" class="inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                  Cancel
                </button>
                
                <button type="submit" id="submit-button" class="inline-flex items-center px-6 py-2 bg-gray-700 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                  Save Department
                </button>
              </div>
            </form>
          </div>

          <!-- Departments List -->
          <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-8 py-6 border-b border-gray-200">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="p-2 bg-gray-600 rounded-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 16h6M7 8h6m-6 4h6m9 2V9a2 2 0 00-2-2H5a2 2 0 002 2v8a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-gray-800">Department List</h2>
                    <p class="text-sm text-gray-600 mt-1">Manage employee departments and activities for <%= @selected_financial_year %></p>
                  </div>
                  <% if @selected_employee %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 border border-blue-200">
                      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      Filtered by: <%= @selected_employee.employee_name %> (<%= employee_display_code(@selected_employee) %>)
                    </span>
                  <% end %>
                </div>
                <div class="flex items-center gap-4">
                  <%= form_with url: departments_path, method: :get, local: true, class: "flex items-center gap-3" do |form| %>
                    <%= hidden_field_tag :employee_id, params[:employee_id] if params[:employee_id].present? %>
                    <%= hidden_field_tag :employee_code, params[:employee_code] if params[:employee_code].present? %>
                    <%= form.label :financial_year, "Financial year:", class: "text-sm font-semibold text-gray-700" %>
                    <%= form.select :financial_year,
                        options_for_select(@financial_years, @selected_financial_year),
                        {},
                        class: "bg-white border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent shadow-sm",
                        onchange: "this.form.submit();" %>
                  <% end %>

                  <!-- Employee Filter -->
                  <div class="flex items-center gap-3">
                    <label for="employee-filter" class="text-sm font-semibold text-gray-700">Filter by Employee:</label>
                    <select id="employee-filter" class="bg-white border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent shadow-sm transition-all duration-200 hover:border-gray-400">
                      <option value="">All Employees</option>
                      <% @employees.each do |employee| %>
                        <option value="<%= employee_reference_value(employee) %>" data-code="<%= employee_display_code(employee) || '' %>"
                                <%= 'selected' if params[:employee_id] == employee_reference_value(employee).to_s %>>
                          <%= employee.employee_name %> (<%= employee_display_code(employee) %>)
                        </option>
                      <% end %>
                    </select>
                    <% if params[:employee_id].present? || params[:employee_code].present? %>
                      <button type="button" onclick="clearEmployeeFilter()" class="text-sm text-red-600 hover:text-red-800 font-medium underline transition-colors duration-200">
                        Clear Filter
                      </button>
                    <% end %>
                  </div>
                  
                  <!-- Search -->
                  <div class="relative">
                    <input type="text" id="search-input" placeholder="Search departments..." class="pl-10 pr-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-500 focus:border-transparent shadow-sm transition-all duration-200 hover:border-gray-400">
                    <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                  </div>
                </div>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gradient-to-r from-gray-100 to-gray-200">
                  <tr>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider border-r border-gray-300">Employee name</th>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider border-r border-gray-300">Employee code</th>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider border-r border-gray-300">Financial year</th>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider border-r border-gray-300">Department</th>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider border-r border-gray-300">Key result indicators</th>
                    <th class="px-8 py-4 text-left text-xs font-bold text-gray-700 tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200" id="departments-table">
                  <% if @employee_activities.any? %>
                    <% @employee_activities.each do |key, data| %>
                      <tr class="hover:bg-gray-50 transition-all duration-200 border-b border-gray-100" data-department-id="<%= data[:id] %>">
                        <td class="px-8 py-5 text-sm font-semibold text-gray-800 border-r border-gray-200">
                          <div class="flex items-center">
                            <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center mr-3">
                              <svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                              </svg>
                            </div>
                            <%= data[:employee_name] %>
                          </div>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-gray-700 border-r border-gray-200">
                          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 border border-slate-200">
                            <%= data[:employee_code].presence || 'N/A' %>
                          </span>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-gray-700 border-r border-gray-200">
                          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">
                            <%= data[:financial_year].presence || @selected_financial_year %>
                          </span>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-gray-700 border-r border-gray-200">
                          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-medium bg-gray-100 text-gray-700 border border-gray-200">
                            <%= data[:department] || 'N/A' %>
                          </span>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-gray-700 border-r border-gray-200">
                          <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-semibold bg-blue-100 text-blue-800 border border-blue-200">
                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <%= data[:total_activities] %> <%= data[:total_activities] == 1 ? 'key result indicator' : 'key result indicators' %>
                          </span>
                        </td>
                        <td class="px-8 py-5 text-sm font-medium text-gray-700">
                          <div class="flex items-center space-x-3">
                            <button type="button" class="edit-btn inline-flex items-center px-4 py-2 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md" data-employee-id="<%= data[:employee_id] %>">
                              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                              </svg>
                              Edit
                            </button>
                            <button type="button" class="delete-user-btn inline-flex items-center px-3 py-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md" 
                                    data-department-id="<%= data[:id] %>" 
                                    data-employee-id="<%= data[:employee_id] %>"
                                    title="Delete only this user's activities">
                              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                              </svg>
                              Delete User
                            </button>
                            <button type="button" class="delete-dept-btn inline-flex items-center px-3 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-sm hover:shadow-md" 
                                    data-department-id="<%= data[:id] %>"
                                    title="Delete entire department">
                              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                              </svg>
                              Delete Dept
                            </button>
                          </div>
                        </td>
                      </tr>
                    <% end %>
                  <% else %>
                    <tr>
                      <td colspan="6" class="px-8 py-12 text-center">
                        <div class="flex flex-col items-center justify-center">
                          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                          </div>
                          <h3 class="text-lg font-semibold text-gray-600 mb-2">
                            <% if params[:employee_id].present? %>
                              No key result indicators found for the selected employee
                            <% else %>
                              No employee key result indicators found
                            <% end %>
                          </h3>
                          <p class="text-sm text-gray-500">
                            <% if params[:employee_id].present? %>
                              Try selecting a different employee or clear the filter.
                            <% else %>
                              Get started by creating new key result indicators using the form above.
                            <% end %>
                          </p>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <div id="empty-state" class="text-center py-16 hidden">
              <div class="flex flex-col items-center justify-center">
                <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-6">
                  <svg class="w-10 h-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-600 mb-3">No departments found</h3>
                <p class="text-sm text-gray-500 max-w-md">Get started by creating a new department using the form above. Add employees and their activities to begin managing your organization.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</div>

<script>
// Check if DepartmentManager class already exists to prevent duplicate declaration
if (typeof DepartmentManager === 'undefined') {
  // Initialize variables first
  window.departmentManagerInstance = null;
  var isInitializing = false;

class DepartmentManager {
  constructor() {
    console.log('DepartmentManager constructor called');
    this.activityIndex = 0;
    this.isEditing = false;
    this.editingId = null;
    this.isSubmitting = false;
    this.isAddingActivity = false;
    this.isReady = false;
    this.departments = [];
    this.employeeDepartments = [];
    this.employees = [];
    console.log('DepartmentManager constructor completed, calling init...');
    this.init();
  }

  async init() {
    console.log('DepartmentManager init started');
    
    // Bind events immediately so buttons work right away
    this.bindEvents();
    console.log('Events bound, buttons should now be functional');
    
    // Set the initial activity index since we now have a default activity in HTML
    const container = document.getElementById('activities-container');
    if (container) {
      this.activityIndex = container.children.length;
      console.log('Initialized with activity index:', this.activityIndex);
      
      // Convert the default activity from "default" to proper index
      const defaultActivity = container.querySelector('.activity-fields');
      if (defaultActivity) {
        const inputs = defaultActivity.querySelectorAll('input[name*="[default]"]');
        inputs.forEach(input => {
          const newName = input.name.replace('[default]', `[0]`);
          input.name = newName;
        });
        console.log('Updated default activity input names from default to index 0');
      }
    }
    
    // Load employee data in background (non-blocking)
    this.loadEmployeeData().catch(error => {
      console.error('Error loading employee data:', error);
    });
    
    // Only add default activity if none exist and we're not in editing mode
    // But first check if we already have a default activity in HTML
    if (!this.isEditing) {
      const container = document.getElementById('activities-container');
      if (container && container.children.length === 1) {
        // We already have the default activity from HTML, don't add another
        console.log('Default activity already exists in HTML, not calling ensureDefaultActivity');
      } else {
        this.ensureDefaultActivity();
      }
    }
    
    console.log('DepartmentManager init completed');
    this.isReady = true;
    console.log('DepartmentManager is now ready');
  }

  async loadEmployeeData() {
    try {
      // For now, we'll use the data embedded in the page
      // since the dropdowns should be populated from ERB
      console.log('Employee departments:', window.employeeDepartments);
      console.log('Employees:', window.employees);
      
