    // Add event listeners with proper error handling
    const addActivityBtn = document.getElementById('add-activity');
    if (addActivityBtn) {
      console.log('Add activity button found, adding click listener');
      addActivityBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        // Check if DepartmentManager is ready
        if (!this.isReady) {
          console.log('DepartmentManager not ready yet, waiting...');
          setTimeout(() => {
            if (this.isReady) {
              this.addActivity();
            } else {
              console.error('DepartmentManager still not ready');
            }
          }, 100);
          return;
        }
        
        this.addActivity();
