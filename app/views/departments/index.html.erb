  removeActivity(activityElement) {
    const container = document.getElementById('activities-container');

    if (container.children.length > 1) {
      const idInput = activityElement.querySelector('input[name*="[id]"]');
      
      // Check if we're in employee editing mode
      if (this.isEditing && this.editingId) {
        // When editing an employee, we need to remove the UserDetail record, not the activity
        if (idInput && idInput.value) {
          // This is an existing activity for this employee, mark it for removal from employee
          const destroyInput = activityElement.querySelector('input[name*="[_destroy]"]');
          if (destroyInput) {
            destroyInput.value = 'true';
            // Hide the element but don't remove it so it's included in form submission
            activityElement.style.display = 'none';
            // Add visual indicator that this activity is marked for removal from employee
            activityElement.style.opacity = '0.5';
            activityElement.style.backgroundColor = '#fef3c7'; // Yellow background to indicate employee-specific removal
            console.log('Marked activity for removal from employee:', idInput.value);
          }
        } else {
          // This is a new activity, just remove it from DOM
          activityElement.remove();
          console.log('Removed new activity from DOM');
        }
      } else {
        // When editing a department (not employee), use the original logic
        if (idInput && idInput.value) {
          // This is an existing activity, mark it for destruction
          const destroyInput = activityElement.querySelector('input[name*="[_destroy]"]');
          if (destroyInput) {
            destroyInput.value = 'true';
            // Hide the element but don't remove it so it's included in form submission
            activityElement.style.display = 'none';
            // Also add a visual indicator that this activity is marked for deletion
            activityElement.style.opacity = '0.5';
            activityElement.style.backgroundColor = '#fee2e2'; // Red background for department activity deletion
            console.log('Marked activity for destruction:', idInput.value);
          }
        } else {
          // This is a new activity, just remove it from DOM
          activityElement.remove();
          console.log('Removed new activity from DOM');
        }
      }
    } else {
      // At least one activity is required
      const inputs = activityElement.querySelectorAll('input[type!="hidden"]');
      inputs.forEach(input => input.value = '');
      this.showError('At least one key result indicator is required');
    }
  }

  async handleFormSubmit() {
    // Prevent multiple submissions
    if (this.isSubmitting) {
      console.log('Form submission already in progress, ignoring...');
      return;
    }

    this.isSubmitting = true;
    this.hideError();
    this.hideSuccess();

    // Validate form before submission
    const form = document.getElementById('department-form');
    const deptType = form.querySelector('#department_department_type').value;
    const employeeSelect = form.querySelector('#department_employee_reference');
    const empRef = employeeSelect.value.trim();
    const selectedEmployeeOption = employeeSelect.selectedOptions[0];
    const activities = form.querySelectorAll('.activity-fields');

    if (!deptType) {
      this.showError('Please select a department.');
      this.isSubmitting = false;
      return;
    }

    if (!empRef || selectedEmployeeOption?.style.display === 'none') {
      this.showError('Please select an employee.');
      this.isSubmitting = false;
      return;
    }

    if (activities.length === 0) {
      this.showError('Please add at least one key result indicator.');
      this.isSubmitting = false;
      return;
    }

    // Check if at least one activity has all required fields filled
    let hasValidActivity = false;
    activities.forEach(activity => {
      const activityName = activity.querySelector('input[name*="[activity_name]"]')?.value;
      
      if (activityName) {
        hasValidActivity = true;
      }
    });

    if (!hasValidActivity) {
      this.showError('Please fill key result indicators for at least one row.');
      this.isSubmitting = false;
      return;
    }

    // Disable submit button to prevent multiple clicks
    const submitBtn = document.getElementById('submit-button');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';
    }

    const formData = new FormData(form);

    // Debug: Log what's being sent
    console.log('Form data being sent:');
    for (let [key, value] of formData.entries()) {
      console.log(`${key}: ${value}`);
    }
    
    // Debug: Log form data structure for editing
    if (this.isEditing) {
      console.log('=== EDITING MODE DEBUG ===');
      console.log('Editing ID:', this.editingId);
      console.log('Form method:', document.getElementById('form-method').value);
      console.log('Department type:', form.querySelector('#department_department_type').value);
      console.log('Employee reference:', form.querySelector('#department_employee_reference').value);
      console.log('Number of activities:', form.querySelectorAll('.activity-fields').length);
    }
    
    // Also log activities marked for destruction
    const activitiesToDestroy = form.querySelectorAll('input[name*="[_destroy]"][value="true"]');
    console.log('Activities marked for destruction:', activitiesToDestroy.length);
    activitiesToDestroy.forEach((input, index) => {
      const activityContainer = input.closest('.activity-fields');
      const idInput = activityContainer.querySelector('input[name*="[id]"]');
      console.log(`Activity ${index} marked for destruction - ID: ${idInput?.value}`);
    });
    
    // Also log all _destroy fields to see their values
    const allDestroyFields = form.querySelectorAll('input[name*="[_destroy]"]');
    console.log('All _destroy fields:', allDestroyFields.length);
    allDestroyFields.forEach((input, index) => {
      const activityContainer = input.closest('.activity-fields');
      const idInput = activityContainer.querySelector('input[name*="[id]"]');
      console.log(`_destroy field ${index}: value="${input.value}", activity ID: ${idInput?.value}`);
    });

    try {
      // For PATCH requests, we need to send the method in the form data
      if (this.isEditing) {
        formData.append('_method', 'PATCH');
        
        // If editing, use the update_employee_activity_data endpoint
        const editUrl = `/departments/${this.editingId}/update_employee_activity_data`;
        const response = await fetch(editUrl, {
          method: 'PATCH', // Use PATCH method directly
          body: formData,
          headers: {
            'X-CSRF-Token': document.querySelector('input[name="authenticity_token"]')?.value || 
                           document.querySelector('meta[name="csrf-token"]')?.content || '',
            'Accept': 'application/json' // Request JSON response
          }
        });
        
        console.log('Edit response status:', response.status);
        console.log('Edit response headers:', response.headers);
        
        // If the custom endpoint fails, try the regular update method
        if (!response.ok) {
          console.log('Custom endpoint failed, trying regular update method...');
          return this.handleRegularUpdate(formData);
        }
        
        return this.handleResponse(response);
      }
      
      const csrfToken = document.querySelector('input[name="authenticity_token"]')?.value || 
                       document.querySelector('meta[name="csrf-token"]')?.content || '';
      
      if (!csrfToken) {
        this.showError('CSRF token not found. Please refresh the page.');
        this.isSubmitting = false;
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = this.isEditing ? 'Update Department' : 'Save Department';
        }
        return;
      }
      
      const response = await fetch(form.action, {
        method: 'POST', // Always use POST, let Rails handle the method override
        body: formData,
        headers: {
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json' // Request JSON response
        }
      });
      
            return this.handleResponse(response);
    } catch (error) {
      console.error('Form submission error:', error);
      this.showError('Network error. Please try again.');
    } finally {
      // Re-enable submit button
      this.isSubmitting = false;
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = this.isEditing ? 'Update Department' : 'Save Department';
      }
    }
  }

