  filterEmployeesByDepartment(selectedDept) {
    const employeeSelect = document.getElementById('department_employee_reference');
    if (!employeeSelect || !selectedDept) {
      // Show all employees if no department selected
      const options = employeeSelect.querySelectorAll('option[data-department]');
      options.forEach(option => option.style.display = '');
      return;
    }

    // Hide/show options based on department
    const options = employeeSelect.querySelectorAll('option[data-department]');
    options.forEach(option => {
      if (option.getAttribute('data-department') === selectedDept) {
        option.style.display = '';
      } else {
        option.style.display = 'none';
      }
    });

    // Reset employee selection
    employeeSelect.value = '';
  }

  addActivity() {
    console.log('Adding activity, index:', this.activityIndex);
    
    // Prevent rapid clicking
    if (this.isAddingActivity) {
      console.log('Adding activity already in progress, ignoring...');
      return;
    }

    this.isAddingActivity = true;
    
    const container = document.getElementById('activities-container');
    if (!container) {
      console.error('Activities container not found!');
      this.isAddingActivity = false;
      return;
    }
    
    const activityHtml = this.getActivityTemplate(this.activityIndex);
    container.insertAdjacentHTML('beforeend', activityHtml);
    
    this.activityIndex++;
    console.log('Activity added successfully, new index:', this.activityIndex);
    
    // Reset flag after a short delay
    setTimeout(() => {
      this.isAddingActivity = false;
    }, 300);
  }

  ensureDefaultActivity() {
    console.log('ensureDefaultActivity called');
    const container = document.getElementById('activities-container');
    
    if (!container) {
      console.error('Activities container not found!');
      // Try again after a short delay
      setTimeout(() => {
        this.ensureDefaultActivity();
      }, 100);
      return;
    }
    
    console.log('Activities container found, children length:', container.children.length);
    
    // Check if there are any visible activity fields (not hidden)
    const visibleActivities = Array.from(container.children).filter(child => 
      child.style.display !== 'none' && 
      child.classList.contains('activity-fields')
    );
    
    console.log('Visible activities found:', visibleActivities.length);
    
    // Also check if we're in editing mode
    if (this.isEditing) {
      console.log('In editing mode, not adding default activity');
      return;
    }
    
    // Check if there are any activities with actual content
    const hasContentActivities = visibleActivities.some(activity => {
      const activityName = activity.querySelector('input[name*="[activity_name]"]')?.value;
      const unit = activity.querySelector('input[name*="[unit]"]')?.value;
      const annualTarget = activity.querySelector('input[name*="[annual_target_fy]"]')?.value;
      
      return activityName || unit || annualTarget;
    });
    
    if (visibleActivities.length === 0 || (!hasContentActivities && visibleActivities.length === 1)) {
      console.log('No meaningful activities found, adding default activity...');
      this.addActivity();
    } else {
      console.log('Activities already present with content - container has', visibleActivities.length, 'visible activities');
    }
  }
  
  testCsrfToken() {
    console.log('=== Testing CSRF Token ===');
    
    // Debug: Show all meta tags
    console.log('All meta tags:');
    document.querySelectorAll('meta').forEach((meta, index) => {
      console.log(`Meta ${index}:`, meta.name, meta.content);
    });
    
    // Try multiple sources for CSRF token
    console.log('Looking for CSRF token...');
    
    // First try the meta tag (most reliable)
    let csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
    console.log('From meta[name="csrf-token"]:', !!csrfToken);
    
    if (!csrfToken) {
      // Try the form input
      csrfToken = document.querySelector('input[name="authenticity_token"]')?.value;
      console.log('From input[name="authenticity_token"]:', !!csrfToken);
    }
    if (!csrfToken) {
      // Try to get it from the form's hidden input
      const form = document.getElementById('department-form');
      if (form) {
        csrfToken = form.querySelector('input[name="authenticity_token"]')?.value;
        console.log('From form input[name="authenticity_token"]:', !!csrfToken);
      } else {
        console.error('Department form not found!');
      }
    }
    
    // Also try the meta tag with different name
    if (!csrfToken) {
      csrfToken = document.querySelector('meta[name="csrf-param"]')?.content;
      console.log('From meta[name="csrf-param"]:', !!csrfToken);
    }
    
    // If still no token, try to get it from the current page URL
    if (!csrfToken) {
      // Try to extract from current page's form
      const currentForm = document.querySelector('form');
      if (currentForm) {
        csrfToken = currentForm.querySelector('input[name="authenticity_token"]')?.value;
        console.log('From current page form:', !!csrfToken);
      }
    }
    
    console.log('Final CSRF Token found:', !!csrfToken);
    console.log('CSRF Token length:', csrfToken ? csrfToken.length : 0);
    console.log('CSRF Token first 10 chars:', csrfToken ? csrfToken.substring(0, 10) + '...' : 'none');
    
    if (csrfToken) {
      this.showSuccess(`CSRF Token found! Length: ${csrfToken.length} characters`);
    } else {
      this.showError('No CSRF token found!');
    }
  }

