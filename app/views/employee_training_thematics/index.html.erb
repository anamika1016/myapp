<div class="main-content sidebar-aware-content w-auto px-4 sm:px-8 py-6 sm:py-8" style="background:#f8fafc; min-height:100vh; font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
  <div class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h1 class="mb-5 text-2xl font-bold text-slate-800">Thematic/Department Master</h1>

      <%= form_with model: @employee_training_thematic, url: employee_training_thematics_path, local: true, class: "grid grid-cols-1 gap-4 md:grid-cols-2" do |form| %>
        <div>
          <%= form.label :thematic_department_name, "Thematic Type / Department", class: "mb-2 block text-sm font-semibold text-slate-700" %>
          <%= form.text_field :thematic_department_name, required: true, placeholder: "Enter thematic type / department", value: @employee_training_thematic.display_name, class: "w-full rounded-lg border border-slate-300 px-4 py-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" %>
        </div>

        <div class="flex items-end">
          <%= form.submit "Add", class: "rounded-lg bg-blue-600 px-6 py-3 text-sm font-bold text-white shadow hover:bg-blue-700" %>
        </div>
      <% end %>
    </div>

    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-xl font-bold text-slate-800">Thematic/Department List</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Thematic Type / Department</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-600">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            <% @employee_training_thematics.each do |thematic| %>
              <tr>
                <td class="px-4 py-3 text-slate-900"><%= thematic.display_name %></td>
                <td class="px-4 py-3">
                  <%= button_to "Delete", employee_training_thematic_path(thematic), method: :delete, data: { turbo_confirm: "Delete this entry?" }, class: "text-sm font-semibold text-red-600 hover:text-red-800" %>
                </td>
              </tr>
            <% end %>
            <% if @employee_training_thematics.blank? %>
              <tr>
                <td colspan="2" class="px-4 py-8 text-center text-slate-500">No thematic departments created yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
