<!-- app/views/home/index.html.erb -->

<div class="container mx-auto my-10 px-4">
  <h1 class="text-3xl font-bold text-center mb-8">Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Card 1 -->
    <div class="bg-white shadow-md rounded-2xl p-6 text-center hover:shadow-lg transition">
      <h2 class="text-xl font-semibold text-gray-800">Total Users</h2>
      <p class="text-3xl mt-2 font-bold text-blue-500"><%= User.count %></p>
    </div>

    <!-- Card 2 -->
    <div class="bg-white shadow-md rounded-2xl p-6 text-center hover:shadow-lg transition">
      <h2 class="text-xl font-semibold text-gray-800">Departments</h2>
      <p class="text-3xl mt-2 font-bold text-green-500"><%= Department.count %></p>
    </div>

    <!-- Card 3 -->
    <div class="bg-white shadow-md rounded-2xl p-6 text-center hover:shadow-lg transition">
      <h2 class="text-xl font-semibold text-gray-800">Activities</h2>
      <p class="text-3xl mt-2 font-bold text-purple-500"><%= Activity.count %></p>
    </div>

    <!-- Card 4 -->
    <div class="bg-white shadow-md rounded-2xl p-6 text-center hover:shadow-lg transition">
      <h2 class="text-xl font-semibold text-gray-800">Themes</h2>
      <p class="text-3xl mt-2 font-bold text-red-500"><%= Theme.count %></p>
    </div>
  </div>

  <!-- Role-specific content -->
  <% if current_user.admin? %>
    <div class="mt-10">
      <h2 class="text-2xl font-semibold text-gray-700 mb-4">Admin Panel</h2>
      <ul class="list-disc pl-5 text-gray-600 space-y-2">
        <li><%= link_to "Manage Users", users_path, class: "text-gray-700 hover:underline" %></li>
        <li><%= link_to "Approve Employee Details", employee_details_path, class: "text-gray-700 hover:underline" %></li>
      </ul>
    </div>
  <% else %>
    <div class="mt-10">
      <h2 class="text-2xl font-semibold text-gray-700 mb-4">Your Activity</h2>
      <ul class="list-disc pl-5 text-gray-600 space-y-2">
        <li><%= link_to "My Details", employee_details_path, class: "text-green-600 hover:underline" %></li>
        <li><%= link_to "Progress Reports", activity_progresses_path, class: "text-green-600 hover:underline" %></li>
      </ul>
    </div>
  <% end %>
</div>
