<div class="main-content annual-dashboard min-h-screen">
  <div class="dashboard-shell">
    <div class="hero-strip">
      <div class="welcome-panel">
        <span class="hero-kicker">Command Center</span>
        <h2>
          <%= @dashboard_mode == :admin ? "Welcome to the PAPL360 leadership dashboard" : "Welcome to your PAPL360 assessment dashboard" %>
        </h2>
        <p>
          <%= @dashboard_mode == :admin ? "Monitor annual scores, pulse assessments, and performance actions for every employee from one professional workspace." : "Review your annual score, pulse assessment, quarterly remarks, and recommended actions from one clean workspace." %>
        </p>

        <div class="hero-tags">
          <%= link_to "Annual Review", "#annual-review-section", class: "hero-tag hero-menu-tag" %>
          <% if @dashboard_mode == :admin %>
            <%= link_to "Pulse Score", "#pulse-score-section", class: "hero-tag hero-menu-tag" %>
            <%= link_to "Line Manager Feedback", "#pulse-remarks-section", class: "hero-tag hero-menu-tag" %>
          <% else %>
            <%= link_to "Score Range", "#action-guidance-section", class: "hero-tag hero-menu-tag" %>
            <%= link_to "Pulse Check", "#pulse-score-section", class: "hero-tag hero-menu-tag" %>
            <%= link_to "Line Manager Feedback ", "#pulse-remarks-section", class: "hero-tag hero-menu-tag" %>
          <% end %>
          <%= link_to "COMPOSITE PERFORMANCE SCORE", "#summary-box-section", class: "hero-tag hero-menu-tag" %>
          <%= link_to "Export Excel", export_dashboard_xlsx_path(format: :xlsx), class: "hero-tag export-tag" %>
        </div>
      </div>

      <div class="time-panel">
        <div class="clock-shell">
          <div class="clock-meta">
            <span id="dashboardGreeting">Good Afternoon</span>
            <p id="dashboardDate">Loading date...</p>
            <small class="clock-note">Live dashboard time</small>
          </div>

          <div class="clock-ring">
            <div class="clock-orbit">
              <span class="ring-dot ring-dot-one"></span>
              <span class="ring-dot ring-dot-two"></span>
            </div>
            <div class="clock-ring-inner">
              <div class="clock-time-stack">
                <div class="clock-time-row">
                  <div class="clock-time" id="dashboardTime">12:00</div>
                  <span class="clock-meridiem" id="dashboardMeridiem">PM</span>
                </div>
                <div class="clock-seconds" id="dashboardSeconds">:00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%
      quarter_summaries = Array(@quarter_summaries)
      manager_feedback = @dashboard_manager_feedback || {}
      manager_criteria = Array(manager_feedback[:criteria])
      employee_department = @dashboard_employee_department.presence || @user_details&.first&.department&.department_type.presence || @employee_detail&.department.presence || "N/A"
      pulse_dimensions = [
        { label: "Sense of Purpose & Mission Alignment", score: @dashboard_pulse_scores&.dig(:sense_of_purpose) },
        { label: "Workload & Well-being Balance", score: @dashboard_pulse_scores&.dig(:workload_balance) },
        { label: "Manager Effectiveness & Support", score: @dashboard_pulse_scores&.dig(:manager_effectiveness) },
        { label: "Team Collaboration & Relationships", score: @dashboard_pulse_scores&.dig(:team_collaboration) },
        { label: "Recognition & Growth Opportunities", score: @dashboard_pulse_scores&.dig(:recognition_growth) },
        { label: "Org. Communication & Transparency", score: @dashboard_pulse_scores&.dig(:org_communication) },
        { label: "Learning & Development Access", score: @dashboard_pulse_scores&.dig(:learning_development) },
        { label: "Role Clarity & Goal Setting", score: @dashboard_pulse_scores&.dig(:role_clarity) },
        { label: "Work Environment & Safety", score: @dashboard_pulse_scores&.dig(:work_environment) },
        { label: "Commitment & Retention Intent", score: @dashboard_pulse_scores&.dig(:commitment_retention) }
      ]
      pulse_raw_percentage = if @dashboard_pulse_available && @dashboard_pulse_scores&.dig(:total_score).present?
        ((@dashboard_pulse_scores[:total_score].to_f / 50.0) * 100.0).round(2)
      end
      composite_pulse_percentage = pulse_raw_percentage.to_f
      composite_manager_percentage = manager_feedback[:raw_total].to_f
      employee_composite = if @dashboard_mode != :admin && @dashboard_summary_scores.present?
        composite_category_details(@dashboard_summary_scores[:final_total])
      end
    %>

    <% if @dashboard_mode == :admin %>
      <% if @employee_rows.any? %>
        <div class="annual-box" id="annual-review-section">
          <div class="box-header">
            <div>
              <h2>SECTION A: Annually / Weightage : 75%</h2>
              <p>Sabhi users ka Q1, Q2, Q3, Q4 aur annual score sirf L1 percentage ke hisab se.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("annual", format: :xlsx), class: "section-export-btn" %>
          </div>

          <div class="table-wrap">
            <table class="annual-table admin-table">
              <thead>
                <tr>
                  <th>Employee</th>
                  <th>Code</th>
                  <th>Department</th>
                  <th>Q1</th>
                  <th>Q2</th>
                  <th>Q3</th>
                  <th>Q4</th>
                  <th>%</th>
                </tr>
              </thead>
              <tbody>
                <% @employee_rows.each do |row| %>
                  <tr>
                    <td><strong><%= row[:employee_name] %></strong></td>
                    <td><%= row[:employee_code] %></td>
                    <td><%= row[:department] %></td>
                    <% row[:quarter_summaries].each do |quarter| %>
                      <td><span class="score-chip"><%= quarter[:percentage] %>%</span></td>
                    <% end %>
                    <td><span class="score-chip percentage-chip"><%= row[:annual_percentage] %>%</span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="empty-dashboard">
          <h2>No user data found</h2>
          <p>Abhi kisi bhi employee ka annual data available nahi hai.</p>
        </div>
      <% end %>
    <% else %>
      <% if @employee_detail.present? %>
        <div class="summary-grid employee-summary-grid">
          <div class="stat-card total-card">
            <span>Employee</span>
            <strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong>
            <small class="stat-subtext"><%= @employee_detail&.employee_code.presence || "Code unavailable" %></small>
          </div>
          <div class="stat-card percentage-card">
            <span>Department</span>
            <strong><%= employee_department %></strong>
            <small class="stat-subtext">Review period dashboard</small>
          </div>
          <div class="stat-card final-card">
            <span>Section A Score</span>
            <strong><%= number_with_precision(@annual_percentage, precision: 1) %>%</strong>
            <small class="stat-subtext">KRA weightage 75%</small>
          </div>
        </div>

        <div class="annual-box employee-kra-box" id="annual-review-section">
          <div class="box-header">
            <div>
              <h2>SECTION A: Annually / Weightage : 75%</h2>
              <p>Quarter-wise annual score for your dashboard.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("annual", format: :xlsx), class: "section-export-btn" %>
          </div>

          <div class="employee-meta-grid">
            <div class="employee-meta-card">
              <span>Employee Name</span>
              <strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong>
            </div>
            <div class="employee-meta-card">
              <span>Emp Code</span>
              <strong><%= @employee_detail&.employee_code.presence || "N/A" %></strong>
            </div>
            <div class="employee-meta-card">
              <span>Department</span>
              <strong><%= employee_department %></strong>
            </div>
          </div>

          <div class="table-wrap">
            <table class="annual-table employee-kra-table">
              <thead>
                <tr>
                  <th>Quarter</th>
                  <th>KRA Score</th>
                </tr>
              </thead>
              <tbody>
                <% if quarter_summaries.any? %>
                  <% quarter_summaries.each do |quarter| %>
                    <tr>
                      <td><strong><%= quarter[:name] %></strong></td>
                      <td><span class="score-chip"><%= number_with_precision(quarter[:percentage], precision: 1) %>%</span></td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="2" class="empty-state">No quarterly annual data available.</td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot>
                <tr>
                  <td><strong>Annual Average</strong></td>
                  <td><span class="score-chip percentage-chip"><%= number_with_precision(@annual_percentage, precision: 1) %>%</span></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

        <div class="remarks-panel score-guide employee-guide-panel" id="action-guidance-section">
          <div class="box-header">
            <div>
              <h2>SCORE RANGE</h2>
              <p>Final composite score band, rating, and recommended action.</p>
            </div>
          </div>

          <div class="table-wrap">
            <table class="guide-table">
              <thead>
                <tr>
                  <th>Score Range</th>
                  <th>Band</th>
                  <th>Rating</th>
                  <th>Recommended Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>&gt;= 90%</td>
                  <td>Outstanding</td>
                  <td><span class="star-rating stars-5"><strong>5</strong> (★★★★★)</span></td>
                  <td>Accelerated growth track / highest increment</td>
                </tr>
                <tr>
                  <td>75 - 89%</td>
                  <td>Exceeds Expectations</td>
                  <td><span class="star-rating stars-4"><strong>4</strong> (★★★★)</span></td>
                  <td>Merit increment + recognition award</td>
                </tr>
                <tr>
                  <td>60 - 74%</td>
                  <td>Meets Expectations</td>
                  <td><span class="star-rating stars-3"><strong>3</strong> (★★★)</span></td>
                  <td>Standard increment as per policy</td>
                </tr>
                <tr>
                  <td>45 - 59%</td>
                  <td>Needs Improvement</td>
                  <td><span class="star-rating stars-2"><strong>2</strong> (★★)</span></td>
                  <td>PIP + structured coaching plan</td>
                </tr>
                <tr>
                  <td>&lt; 45%</td>
                  <td>Unsatisfactory</td>
                  <td><span class="star-rating stars-1"><strong>1</strong> (★)</span></td>
                  <td>Formal PIP / disciplinary review</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="employee-sections-grid">
          <div class="pulse-score-card employee-pulse-card" id="pulse-score-section">
            <div class="box-header employee-section-header">
              <div>
                <h2>SECTION B - PULSE CHECK / Weightage : 15%</h2>
                <p>Pulse survey scores with raw percentage and overall category.</p>
              </div>
              <%= link_to "Export", export_dashboard_section_xlsx_path("pulse", format: :xlsx), class: "section-export-btn pulse-export-btn" %>
            </div>

            <div class="table-wrap">
              <table class="compact-metric-table employee-metric-table">
                <thead>
                  <tr>
                    <th>Pulse Dimension</th>
                    <th>Wt %</th>
                    <th>Score (1-5)</th>
                    <th>Wtd Score</th>
                    <th>Rating</th>
                  </tr>
                </thead>
                <tbody>
                  <% pulse_dimensions.each do |dimension| %>
                    <% weighted_score = dimension[:score].present? ? ((dimension[:score].to_f / 5.0) * 10.0).round(2) : nil %>
                    <% rating_details = score_rating_details(dimension[:score]) %>
                    <tr>
                      <td><%= dimension[:label] %></td>
                      <td>10%</td>
                      <td><%= dimension[:score].presence || "-" %></td>
                      <td><%= weighted_score.present? ? "#{number_with_precision(weighted_score, precision: 2)}%" : "-" %></td>
                      <td>
                        <% if rating_details.present? %>
                          <span class="star-rating <%= rating_details[:className] %>"><strong><%= rating_details[:rating] %></strong> (<%= rating_details[:stars] %>)</span>
                        <% else %>
                          -
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr>
                    <td><strong>PULSE TOTAL</strong></td>
                    <td>100%</td>
                    <td colspan="3"><strong><%= pulse_raw_percentage.present? ? "Pulse Raw -> #{number_with_precision(pulse_raw_percentage, precision: 2)}%" : "Pending assessment" %></strong></td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <div class="metric-summary-row">
              <span class="summary-chip neutral-summary-chip"><%= pulse_raw_percentage.present? ? "Raw #{number_with_precision(pulse_raw_percentage, precision: 2)}%" : "Raw Pending" %></span>
              <span class="summary-chip pulse-summary-chip">Weighted <%= number_with_precision(@dashboard_summary_scores[:pulse_score], precision: 2) %>/15</span>
              <% if @dashboard_pulse_category.present? %>
                <span class="summary-chip annual-summary-chip"><%= @dashboard_pulse_category[:category] %></span>
              <% end %>
            </div>
          </div>

          <div class="remarks-panel employee-manager-panel" id="pulse-remarks-section">
            <div class="box-header">
              <div>
                <h2>SECTION C - LINE MANAGER FEEDBACK / Weightage : 10%</h2>
                <p>Manager criteria scores and final remarks from the latest assessment.</p>
              </div>
              <%= link_to "Export", export_dashboard_section_xlsx_path("remarks", format: :xlsx), class: "section-export-btn" %>
            </div>

            <div class="table-wrap">
              <table class="compact-metric-table employee-metric-table manager-feedback-table">
                <thead>
                  <tr>
                    <th>Assessment Criteria</th>
                    <th>Wt %</th>
                    <th>Score (1-5)</th>
                    <th>Wtd Score</th>
                    <th>Rating</th>
                  </tr>
                </thead>
                <tbody>
                  <% manager_criteria.each do |criterion| %>
                    <% rating_details = score_rating_details(criterion[:score]) %>
                    <tr>
                      <td><%= criterion[:label] %></td>
                      <td><%= criterion[:weight] %>%</td>
                      <td><%= criterion[:score].presence || "-" %></td>
                      <td><%= criterion[:weighted_score].present? ? "#{number_with_precision(criterion[:weighted_score], precision: 2)}%" : "-" %></td>
                      <td>
                        <% if rating_details.present? %>
                          <span class="star-rating <%= rating_details[:className] %>"><strong><%= rating_details[:rating] %></strong> (<%= rating_details[:stars] %>)</span>
                        <% else %>
                          -
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr>
                    <td><strong>MANAGER TOTAL</strong></td>
                    <td>100%</td>
                    <td colspan="3"><strong><%= manager_feedback[:available] ? "Mgr Raw -> #{number_with_precision(manager_feedback[:raw_total], precision: 2)}%" : "Pending assessment" %></strong></td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <div class="metric-summary-row">
              <span class="summary-chip neutral-summary-chip"><%= manager_feedback[:available] ? "Raw #{number_with_precision(manager_feedback[:raw_total], precision: 2)}%" : "Raw Pending" %></span>
              <span class="summary-chip remarks-summary-chip">Weighted <%= number_with_precision(@dashboard_summary_scores[:remarks_score], precision: 2) %>/10</span>
              <span class="summary-chip annual-summary-chip">Score <%= @dashboard_pulse_remark_score.present? ? "#{number_with_precision(@dashboard_pulse_remark_score, precision: 1)}/10" : "Pending" %></span>
            </div>

            <div class="single-remark-box employee-remark-box">
              <div class="dashboard-remark-heading">Manager Remarks</div>
              <% if @dashboard_pulse_remarks.present? %>
                <p><%= @dashboard_pulse_remarks %></p>
              <% else %>
                <p class="empty-state">No manager remarks available yet.</p>
              <% end %>
            </div>
          </div>
        </div>

        <div class="remarks-panel summary-panel employee-summary-panel" id="summary-box-section">
          <div class="box-header">
            <div>
              <h2>COMPOSITE PERFORMANCE SCORE</h2>
              <p>KRA 75% + Pulse 15% + Line Manager Feedback 10% combined into one final score.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("summary", format: :xlsx), class: "section-export-btn" %>
          </div>

          <div class="employee-summary-layout">
            <div class="table-wrap">
              <table class="summary-table employee-summary-table">
                <thead>
                  <tr>
                    <th>Section</th>
                    <th>Raw Score</th>
                    <th>Section Weight</th>
                    <th>Weighted Contribution</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>A - KRA</td>
                    <td><%= number_with_precision(@annual_percentage, precision: 2) %>%</td>
                    <td>75%</td>
                    <td><span class="summary-chip annual-summary-chip"><%= number_with_precision(@dashboard_summary_scores[:annual_score], precision: 2) %>%</span></td>
                  </tr>
                  <tr>
                    <td>B - Pulse Check</td>
                    <td><%= number_with_precision(composite_pulse_percentage, precision: 2) %>%</td>
                    <td>15%</td>
                    <td><span class="summary-chip pulse-summary-chip"><%= number_with_precision(@dashboard_summary_scores[:pulse_score], precision: 2) %>%</span></td>
                  </tr>
                  <tr>
                    <td>C - Manager Feedback</td>
                    <td><%= number_with_precision(composite_manager_percentage, precision: 2) %>%</td>
                    <td>10%</td>
                    <td><span class="summary-chip remarks-summary-chip"><%= number_with_precision(@dashboard_summary_scores[:remarks_score], precision: 2) %>%</span></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="employee-final-card">
              <span class="final-card-label">Final Composite Score</span>
              <strong><%= number_with_precision(@dashboard_summary_scores[:final_total], precision: 2) %>%</strong>
              <div class="employee-final-band"><%= employee_composite[:band] %></div>
              <div class="employee-final-rating">Rating <%= employee_composite[:rating] %> / 5</div>
              <p><%= employee_composite[:action] %></p>
            </div>
          </div>
        </div>
      <% else %>
        <div class="empty-dashboard">
          <h2>No annual data found</h2>
          <p>Is user ke liye employee record ya quarterly percentage abhi available nahi hai.</p>
        </div>
      <% end %>
    <% end %>

    <% if @dashboard_mode == :admin %>
    <div class="remarks-panel score-guide admin-guide-panel" id="action-guidance-section">
      <div class="box-header">
        <div>
          <h2>SCORE RANGE</h2>
          <p>Final composite score band, rating, and recommended action guide.</p>
        </div>
      </div>

      <div class="table-wrap">
        <table class="guide-table">
          <thead>
            <tr>
              <th>Score Range</th>
              <th>Band</th>
              <th>Rating</th>
              <th>Recommended Action</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>≥ 90%</td>
              <td>Outstanding</td>
              <td><span class="star-rating stars-5" style="gap: 5px;"><strong>5</strong> (★★★★★)</span></td>
              <td>Accelerated growth track / highest increment</td>
            </tr>
            <tr>
              <td>75 - 89%</td>
              <td>Exceeds Expectations</td>
              <td><span class="star-rating stars-4" style="gap: 5px;"><strong>4</strong> (★★★★)</span></td>
              <td>Merit increment + recognition award</td>
            </tr>
            <tr>
              <td>60 - 74%</td>
              <td>Meets Expectations</td>
              <td><span class="star-rating stars-3" style="gap: 5px;"><strong>3</strong> (★★★)</span></td>
              <td>Standard increment as per policy</td>
            </tr>
            <tr>
              <td>45 - 59%</td>
              <td>Needs Improvement</td>
              <td><span class="star-rating stars-2" style="gap: 5px;"><strong>2</strong> (★★)</span></td>
              <td>PIP + structured coaching plan</td>
            </tr>
            <tr>
              <td>&lt; 45%</td>
              <td>Unsatisfactory</td>
              <td><span class="star-rating stars-1" style="gap: 5px;"><strong>1</strong> (★)</span></td>
              <td>Formal PIP / disciplinary review</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="pulse-score-card" id="pulse-score-section">
      <div class="box-header">
        <div>
          <h2>SECTION B: PULSE-360 ASSESSMENT SCORE / Weightage : 15%</h2>
          <p>All user pulse survey scores, total score, and category in one place.</p>
        </div>
        <%= link_to "Export", export_dashboard_section_xlsx_path("pulse", format: :xlsx), class: "section-export-btn pulse-export-btn" %>
      </div>

      <div class="table-wrap pulse-score-table-wrap">
        <%
          pulse_category_markup = lambda do |total_score|
            case total_score
            when 45..50
              '<span class="star-rating stars-5">★★★★★</span> <span class="category-label">Outstanding</span>'
            when 38..44
              '<span class="star-rating stars-4">★★★★</span> <span class="category-label">Exceeds Expectations</span>'
            when 30..37
              '<span class="star-rating stars-3">★★★</span> <span class="category-label">Meets Expectations</span>'
            when 23..29
              '<span class="star-rating stars-2">★★</span> <span class="category-label">Needs Improvement</span>'
            else
              '<span class="star-rating stars-1">★</span> <span class="category-label">Unsatisfactory</span>'
            end.html_safe
          end
        %>
        <table class="pulse-table">
          <thead>
            <tr>
              <th>Staff Name</th>
              <th>Role</th>
              <th>Wt %</th>
              <th>Sense of Purpose & Mission Alignment (1-5)</th>
              <th>Workload & Well-being Balance (1-5)</th>
              <th>Manager Effectiveness & Support (1-5)</th>
              <th>Team Collaboration & Relationships (1-5)</th>
              <th>Recognition & Growth Opportunities (1-5)</th>
              <th>Org. Communication & Transparency (1-5)</th>
              <th>Learning & Development Access (1-5)</th>
              <th>Role Clarity & Goal Setting (1-5)</th>
              <th>Work Environment & Safety (1-5)</th>
              <th>Commitment & Retention Intent (1-5)</th>
              <th>Total /50</th>
              <th>Category & Action</th>
            </tr>
          </thead>
          <tbody>
            <% if @dashboard_mode == :admin %>
              <% @employee_rows.each do |row| %>
                <tr>
                  <td><%= row[:employee_name] %></td>
                  <td><%= row[:role] %></td>
                  <td><%= row[:summary_scores][:pulse_score] %>%</td>
                  <td><%= row[:pulse_scores][:sense_of_purpose] %></td>
                  <td><%= row[:pulse_scores][:workload_balance] %></td>
                  <td><%= row[:pulse_scores][:manager_effectiveness] %></td>
                  <td><%= row[:pulse_scores][:team_collaboration] %></td>
                  <td><%= row[:pulse_scores][:recognition_growth] %></td>
                  <td><%= row[:pulse_scores][:org_communication] %></td>
                  <td><%= row[:pulse_scores][:learning_development] %></td>
                  <td><%= row[:pulse_scores][:role_clarity] %></td>
                  <td><%= row[:pulse_scores][:work_environment] %></td>
                  <td><%= row[:pulse_scores][:commitment_retention] %></td>
                  <td class="pulse-total"><%= row[:pulse_scores][:total_score] %></td>
                  <td><%= row[:pulse_available] ? pulse_category_markup.call(row[:pulse_scores][:total_score]) : "" %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td><%= @employee_detail&.employee_name.presence || current_user.email %></td>
                <td><%= @user_details.first&.department&.department_type.presence || @employee_detail&.department.presence || "N/A" %></td>
                <td><%= @dashboard_summary_scores[:pulse_score] %>%</td>
                <td><%= @dashboard_pulse_scores[:sense_of_purpose] %></td>
                <td><%= @dashboard_pulse_scores[:workload_balance] %></td>
                <td><%= @dashboard_pulse_scores[:manager_effectiveness] %></td>
                <td><%= @dashboard_pulse_scores[:team_collaboration] %></td>
                <td><%= @dashboard_pulse_scores[:recognition_growth] %></td>
                <td><%= @dashboard_pulse_scores[:org_communication] %></td>
                <td><%= @dashboard_pulse_scores[:learning_development] %></td>
                <td><%= @dashboard_pulse_scores[:role_clarity] %></td>
                <td><%= @dashboard_pulse_scores[:work_environment] %></td>
                <td><%= @dashboard_pulse_scores[:commitment_retention] %></td>
                <td class="pulse-total"><%= @dashboard_pulse_scores[:total_score] %></td>
                <td><%= @dashboard_pulse_available ? pulse_category_markup.call(@dashboard_pulse_scores[:total_score]) : "" %></td>
              </tr>
            <% end %>
          </tbody>
          <% if @dashboard_mode == :admin && @employee_rows.any? %>
