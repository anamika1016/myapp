<div class="main-content annual-dashboard min-h-screen">
  <div class="dashboard-shell">
    <div class="hero-strip">
      <div class="welcome-panel">
        <h2>
          <%= @dashboard_mode == :admin ? "Welcome to the PAPL360 leadership dashboard" : "Welcome to your PAPL360 assessment dashboard" %>
        </h2>
        <p>
          <%= @dashboard_mode == :admin ? "Monitor annual scores, pulse assessments, and performance actions for every employee from one professional workspace." : "Review your annual score, pulse assessment, quarterly remarks, and recommended actions from one clean workspace." %>
        </p>

        <div class="hero-tags">
          <%= link_to "Annual Review", "#annual-review-section", class: "hero-tag hero-menu-tag" %>
          <% if @dashboard_mode == :admin %>
            <%= link_to "Pulse Score", "#pulse-score-section", class: "hero-tag hero-menu-tag" %>
          <% else %>
            <%= link_to "Score Range", "#action-guidance-section", class: "hero-tag hero-menu-tag" %>
            <%= link_to "Pulse Check", "#pulse-score-section", class: "hero-tag hero-menu-tag" %>
          <% end %>
          <%= link_to "COMPOSITE PERFORMANCE SCORE", "#summary-box-section", class: "hero-tag hero-menu-tag" %>
          <%= link_to "Export Excel", export_dashboard_xlsx_path(format: :xlsx, financial_year: @selected_financial_year), class: "hero-tag export-tag" %>
        </div>

        <%= form_with url: dashboard_path, method: :get, local: true, class: "financial-year-filter" do |form| %>
          <%= form.label :financial_year, "Financial Year" %>
          <%= form.select :financial_year,
              options_for_select(@financial_years, @selected_financial_year),
              {},
              onchange: "this.form.submit();" %>
        <% end %>
      </div>

      <div class="time-panel">
        <div class="clock-shell">
          <div class="clock-meta">
            <span id="dashboardGreeting">Good Afternoon</span>
            <p id="dashboardDate">Loading date...</p>
            <small class="clock-note">Live dashboard time</small>
          </div>

          <div class="clock-ring">
            <div class="clock-orbit">
              <span class="ring-dot ring-dot-one"></span>
              <span class="ring-dot ring-dot-two"></span>
            </div>
            <div class="clock-ring-inner">
              <div class="clock-time-stack">
                <div class="clock-time-row">
                  <div class="clock-time" id="dashboardTime">12:00</div>
                  <span class="clock-meridiem" id="dashboardMeridiem">PM</span>
                </div>
                <div class="clock-seconds" id="dashboardSeconds">:00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%
      fmt_pct = ->(value, precision = 2) { "#{number_with_precision(value, precision: precision, strip_insignificant_zeros: true)}%" }
      fmt_num = ->(value, precision = 1) { number_with_precision(value, precision: precision, strip_insignificant_zeros: true) }
      quarter_summaries = Array(@quarter_summaries)
      employee_department = @dashboard_employee_department.presence || @user_details&.first&.department&.department_type.presence || @employee_detail&.department.presence || "N/A"
      pulse_dimensions = pulse_dimension_rows_for(@dashboard_pulse_scores).map do |dimension|
        score = dimension[:score]
        dimension.merge(
          weight: 3,
          weighted_score: score.present? ? ((score.to_f / 5.0) * 3.0).round(2) : nil
        )
      end
      pulse_raw_percentage = if @dashboard_pulse_available && @dashboard_pulse_scores&.dig(:total_score).present?
        ((@dashboard_pulse_scores[:total_score].to_f / 25.0) * 100.0).round(2)
      end
      pulse_total_score = if @dashboard_pulse_scores&.dig(:total_score).present?
        fmt_num.call(@dashboard_pulse_scores[:total_score], 1)
      end
      composite_pulse_percentage = pulse_raw_percentage.to_f
      render_rating_badge = lambda do |rating_details|
        next "-" unless rating_details.present?

        stars_markup = (1..rating_details[:rating].to_i).map do |index|
          %(<span class="star-icon star-icon-#{index}">★</span>)
        end.join

        %(
          <span class="star-rating #{rating_details[:className]}">
            <strong>#{rating_details[:rating]}</strong>
            <span class="star-cluster">(<span class="star-seq">#{stars_markup}</span>)</span>
          </span>
        ).html_safe
      end
      employee_composite = if @dashboard_mode != :admin && @dashboard_summary_scores.present?
        composite_category_details(composite_display_total(annual_percentage: @annual_percentage, pulse_total_score: @dashboard_pulse_scores[:total_score]))
      end
    %>

    <% if @dashboard_mode == :admin %>
      <% if @employee_rows.any? %>
        <div class="annual-box" id="annual-review-section">
          <div class="box-header">
            <div>
              <h2>SECTION A: Annually / Weightage : 75%</h2>
              <p>Sabhi users ka annual score sirf un quarters ke L1 percentage ke hisab se hai jisme KRA score available hai. Formula: Annual Score = scored quarters total / scored quarters count.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("annual", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn" %>
          </div>

          <div class="table-wrap">
            <table class="annual-table admin-table">
              <thead>
                <tr>
                  <th>Employee</th>
                  <th>Code</th>
                  <th>Department</th>
                  <th>Q1</th>
                  <th>Q2</th>
                  <th>Q3</th>
                  <th>Q4</th>
                  <th>%</th>
                </tr>
              </thead>
              <tbody>
                <% @employee_rows.each do |row| %>
                  <tr>
                    <td><strong><%= row[:employee_name] %></strong></td>
                    <td><%= row[:employee_code] %></td>
                    <td><%= row[:department] %></td>
                    <% row[:quarter_summaries].each do |quarter| %>
                      <td><span class="score-chip"><%= "#{compact_number(quarter[:percentage])}%" %></span></td>
                    <% end %>
                    <td><span class="score-chip percentage-chip"><%= "#{compact_number(row[:annual_percentage])}%" %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="empty-dashboard">
          <h2>No user data found</h2>
          <p><%= @selected_financial_year %> ke liye abhi kisi bhi employee ka annual data available nahi hai.</p>
        </div>
      <% end %>
    <% else %>
      <% if @employee_detail.present? %>
        <div class="summary-grid employee-summary-grid">
          <div class="stat-card total-card">
            <span>Employee</span>
            <strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong>
            <small class="stat-subtext"><%= @employee_detail&.employee_code.presence || "Code unavailable" %></small>
          </div>
          <div class="stat-card percentage-card">
            <span>Department</span>
            <strong><%= employee_department %></strong>
            <small class="stat-subtext">Review period dashboard</small>
          </div>
          <div class="stat-card final-card">
            <span>Section A Score</span>
            <strong><%= "#{compact_number(@annual_percentage)}%" %></strong>
            <small class="stat-subtext">KRA weightage 75%</small>
          </div>
        </div>

        <div class="annual-box employee-kra-box" id="annual-review-section">
          <div class="box-header">
            <div>
              <h2>SECTION A: Annually / Weightage : 75%</h2>
              <p>Quarter-wise annual score for your dashboard. Formula: Annual Score = scored quarters total / scored quarters count.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("annual", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn" %>
          </div>

          <div class="employee-meta-grid">
            <div class="employee-meta-card">
              <span>Employee Name</span>
              <strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong>
            </div>
            <div class="employee-meta-card">
              <span>Emp Code</span>
              <strong><%= @employee_detail&.employee_code.presence || "N/A" %></strong>
            </div>
            <div class="employee-meta-card">
              <span>Department</span>
              <strong><%= employee_department %></strong>
            </div>
          </div>

          <div class="table-wrap">
            <table class="annual-table employee-kra-table">
              <thead>
                <tr>
                  <th>Quarter</th>
                  <th>KRA Score</th>
                </tr>
              </thead>
              <tbody>
                <% if quarter_summaries.any? %>
                  <% quarter_summaries.each do |quarter| %>
                    <tr>
                      <td><strong><%= quarter[:name] %></strong></td>
                      <td><span class="score-chip"><%= "#{compact_number(quarter[:percentage])}%" %></span></td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="2" class="empty-state">No quarterly annual data available.</td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot>
                <tr>
                  <td><strong>Annual Average</strong></td>
                  <td><span class="score-chip percentage-chip"><%= "#{compact_number(@annual_percentage)}%" %></span></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>

        <div class="remarks-panel score-guide employee-guide-panel" id="action-guidance-section">
          <div class="box-header">
            <div>
              <h2>PULSE SCORE RANGE</h2>
              <p>Pulse score band, rating, and recommended action guide.</p>
            </div>
          </div>

          <div class="table-wrap">
            <table class="guide-table">
              <thead>
                <tr>
                  <th>Total / 25 Range</th>
                  <th>Band</th>
                  <th>Rating</th>
                  <th>Recommended Action</th>
                </tr>
              </thead>
              <tbody>
                <% score_range_rows.each do |row| %>
                  <tr>
                    <td><%= row[:score_range] %></td>
                    <td><%= row[:band] %></td>
                    <td><%= render_rating_badge.call(score_rating_details(row[:rating_value])) %></td>
                    <td><%= row[:action] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="employee-sections-grid">
          <div class="pulse-score-card employee-pulse-card" id="pulse-score-section">
            <div class="box-header employee-section-header">
              <div>
                <h2>SECTION B - PULSE CHECK / Weightage : 25%</h2>
                <p>Pulse survey scores with raw percentage and overall category.</p>
              </div>
              <%= link_to "Export", export_dashboard_section_xlsx_path("pulse", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn pulse-export-btn" %>
            </div>

            <div class="table-wrap">
              <table class="compact-metric-table employee-metric-table">
                <thead>
                  <tr>
                    <th>Pulse Dimension</th>
                    <th>Score (1-5)</th>
                    <th>Rating</th>
                  </tr>
                </thead>
                <tbody>
                  <% pulse_dimensions.each do |dimension| %>
                    <tr>
                      <td><%= dimension[:label] %></td>
                      <td><%= dimension[:score].presence || "-" %></td>
                      <td>
                        <% if dimension[:rating_text].present? && dimension[:score].present? %>
                          <% rating_details = score_rating_details(dimension[:score]) %>
                          <%= render_rating_badge.call(rating_details) %>
                        <% else %>
                          -
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
                <tfoot>
                  <tr>
                    <td><strong>PULSE TOTAL</strong></td>
                    <td colspan="2"><strong><%= pulse_raw_percentage.present? ? "Total -> #{pulse_total_score}/25 | Pulse Raw -> #{fmt_pct.call(pulse_raw_percentage)}" : "Pending assessment" %></strong></td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <div class="metric-summary-row">
              <span class="summary-chip neutral-summary-chip"><%= pulse_raw_percentage.present? ? "Raw #{fmt_pct.call(pulse_raw_percentage)}" : "Raw Pending" %></span>
              <span class="summary-chip pulse-summary-chip">Weighted <%= fmt_num.call(@dashboard_summary_scores[:pulse_score], 2) %>/25</span>
              <% if @dashboard_pulse_category.present? %>
                <span class="summary-chip annual-summary-chip"><%= @dashboard_pulse_category[:category] %></span>
              <% end %>
            </div>

            <div class="single-remark-box employee-remark-box">
              <div class="dashboard-remark-heading">Pulse Remarks</div>
              <% if @dashboard_pulse_section_remarks.present? %>
                <p><%= @dashboard_pulse_section_remarks %></p>
              <% else %>
                <p class="empty-state">No pulse remarks available yet.</p>
              <% end %>
            </div>
          </div>

        </div>

        <div class="remarks-panel summary-panel employee-summary-panel" id="summary-box-section">
          <div class="box-header">
            <div>
              <h2>COMPOSITE PERFORMANCE SCORE</h2>
              <p>KRA 75% + Pulse 25% combined into one final score.</p>
            </div>
            <%= link_to "Export", export_dashboard_section_xlsx_path("summary", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn" %>
          </div>

          <div class="employee-summary-layout">
            <div class="table-wrap">
              <table class="summary-table employee-summary-table">
                <thead>
                  <tr>
                    <th>Section</th>
                    <th>Section Weight</th>
                    <th>Raw Score</th>
                    <th>Weighted Contribution</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>A - KRA</td>
                    <td>75%</td>
                    <td><%= compact_number(@annual_percentage) %></td>
                    <td><span class="summary-chip annual-summary-chip"><%= compact_number(@annual_percentage.to_f * 0.75) %></span></td>
                  </tr>
                  <tr>
                    <td>B - Pulse Check</td>
                    <td>25%</td>
                    <td><%= compact_number(composite_pulse_percentage) %></td>
                    <td><span class="summary-chip pulse-summary-chip"><%= compact_number(composite_pulse_percentage.to_f * 0.25) %></span></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="employee-final-card">
              <span class="final-card-label">Final Composite Score</span>
              <strong><%= "#{compact_number(composite_display_total(annual_percentage: @annual_percentage, pulse_total_score: @dashboard_pulse_scores[:total_score]))}%" %></strong>
              <div class="employee-final-band"><%= employee_composite&.dig(:band) || "Unsatisfactory" %></div>
            </div>
          </div>
        </div>
      <% else %>
        <div class="empty-dashboard">
          <h2>No annual data found</h2>
          <p>Is user ke liye employee record ya quarterly percentage abhi available nahi hai.</p>
        </div>
      <% end %>
    <% end %>

    <% if @dashboard_mode == :admin %>
    <div class="remarks-panel score-guide admin-guide-panel" id="action-guidance-section">
      <div class="box-header">
        <div>
          <h2>PULSE SCORE RANGE</h2>
          <p>Pulse score band, rating, and recommended action guide.</p>
        </div>
      </div>

      <div class="table-wrap">
        <table class="guide-table">
          <thead>
            <tr>
              <th>Total / 25 Range</th>
              <th>Band</th>
              <th>Rating</th>
              <th>Recommended Action</th>
            </tr>
          </thead>
          <tbody>
            <% score_range_rows.each do |row| %>
              <tr>
                <td><%= row[:score_range] %></td>
                <td><%= row[:band] %></td>
                <td><%= render_rating_badge.call(score_rating_details(row[:rating_value])) %></td>
                <td><%= row[:action] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="pulse-score-card" id="pulse-score-section">
      <div class="box-header">
        <div>
          <h2>SECTION B: PULSE-360 ASSESSMENT SCORE / Weightage : 25%</h2>
          <p>All user pulse survey scores, total score, and category in one place.</p>
        </div>
        <%= link_to "Export", export_dashboard_section_xlsx_path("pulse", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn pulse-export-btn" %>
      </div>

      <div class="table-wrap pulse-score-table-wrap">
        <%
          pulse_category_markup = lambda do |total_score|
            total_score = total_score.to_f
            if total_score > 23
              '<span class="star-rating stars-5">★★★★★</span> <span class="category-label">Exceptional</span>'
            elsif total_score >= 19
              '<span class="star-rating stars-4">★★★★</span> <span class="category-label">Outstanding</span>'
            elsif total_score >= 15
              '<span class="star-rating stars-3">★★★</span> <span class="category-label">Meets Expectations</span>'
            elsif total_score >= 11
              '<span class="star-rating stars-2">★★</span> <span class="category-label">Needs Improvement</span>'
            else
              '<span class="star-rating stars-1">★</span> <span class="category-label">Unsatisfactory</span>'
            end.html_safe
          end
        %>
        <table class="pulse-table">
          <thead>
            <tr>
              <th>Staff Name</th>
              <th>Role</th>
              <% pulse_group_rows_for(@dashboard_pulse_scores).each do |dimension| %>
              <th><%= dimension[:label] %> (1-5)</th>
              <% end %>
              <th>Total /25</th>
              <th>25% Computed</th>
              <th>Pulse Remarks</th>
              <th>Category & Action</th>
            </tr>
          </thead>
          <tbody>
            <% if @dashboard_mode == :admin %>
              <% @employee_rows.each do |row| %>
                <% grouped_scores = pulse_group_rows_for(row[:pulse_scores]) %>
                <tr>
                  <td><%= row[:employee_name] %></td>
                  <td><%= row[:role] %></td>
                  <% grouped_scores.each do |dimension| %>
                    <td><%= dimension[:score].present? ? fmt_num.call(dimension[:score], 1) : "-" %></td>
                  <% end %>
                  <td class="pulse-total"><%= row[:pulse_scores][:total_score].present? ? fmt_num.call(row[:pulse_scores][:total_score], 1) : "-" %></td>
                  <td class="pulse-total"><%= "#{row[:summary_scores][:pulse_score].to_f.round}%" %></td>
                  <td><%= row[:pulse_remarks].presence || "-" %></td>
                  <td><%= row[:pulse_available] ? pulse_category_markup.call(row[:pulse_scores][:total_score]) : "" %></td>
                </tr>
              <% end %>
            <% else %>
              <% grouped_scores = pulse_group_rows_for(@dashboard_pulse_scores) %>
              <tr>
                <td><%= @employee_detail&.employee_name.presence || current_user.email %></td>
                <td><%= @user_details.first&.department&.department_type.presence || @employee_detail&.department.presence || "N/A" %></td>
                <% grouped_scores.each do |dimension| %>
                  <td><%= dimension[:score].present? ? fmt_num.call(dimension[:score], 1) : "-" %></td>
                <% end %>
                <td class="pulse-total"><%= @dashboard_pulse_scores[:total_score].present? ? fmt_num.call(@dashboard_pulse_scores[:total_score], 1) : "-" %></td>
                <td class="pulse-total"><%= "#{@dashboard_summary_scores[:pulse_score].to_f.round}%" %></td>
                <td><%= @dashboard_pulse_section_remarks.presence || "-" %></td>
                <td><%= @dashboard_pulse_available ? pulse_category_markup.call(@dashboard_pulse_scores[:total_score]) : "" %></td>
              </tr>
            <% end %>
          </tbody>
          <% if @dashboard_mode == :admin && (team_average = pulse_team_average(@employee_rows)) %>
            <tfoot style="background: rgba(18, 56, 77, 0.05); font-weight: bold; border-top: 2px solid #cbd5e1;">
              <tr>
                <td colspan="2">TEAM AVERAGE</td>
                <% team_average[:grouped_scores].each do |dimension| %>
                  <td><%= dimension[:score].present? ? fmt_num.call(dimension[:score], 1) : "-" %></td>
                <% end %>
                <td class="pulse-total"><%= fmt_num.call(team_average[:total_score], 1) %></td>
                <td class="pulse-total"><%= "#{team_average[:pulse_score].to_f.round}%" %></td>
                <td>-</td>
                <td><%= team_average[:category][:stars] %> <%= team_average[:category][:category] %></td>
              </tr>
            </tfoot>
          <% end %>
        </table>
      </div>
    </div>

    <div class="remarks-panel summary-panel" id="summary-box-section">
      <div class="box-header">
        <div>
          <h2><i class="fas fa-chart-line"></i> COMPOSITE PERFORMANCE SCORE — KRA 75% + Pulse 25%</h2>
          <p>User wise weighted total based on Annually / Weightage : 75% and PULSE-360 ASSESSMENT SCORE / Weightage : 25%.</p>
        </div>
        <%= link_to "Export", export_dashboard_section_xlsx_path("summary", format: :xlsx, financial_year: @selected_financial_year), class: "section-export-btn" %>
      </div>

      <div class="table-wrap summary-wrap">
        <table class="summary-table">
          <thead>
            <tr>
              <th>User</th>
              <th>SECTION A -KRA %</th>
              <th>SECTION B -Pulse %</th>
              <th>Calculation</th>
              <th>Final Total</th>
            </tr>
          </thead>
          <tbody>
            <% if @dashboard_mode == :admin %>
              <% @employee_rows.each_with_index do |row, row_index| %>
                <tr>
                  <td><strong><%= row[:employee_name] %></strong></td>
                  <td><span class="summary-chip neutral-summary-chip"><%= compact_number(row[:annual_percentage]) %></span></td>
                  <td><span class="summary-chip neutral-summary-chip"><%= compact_number(row[:pulse_raw_percentage]) %></span></td>
                  <td class="formula-cell">
                    <button type="button" class="formula-toggle" aria-expanded="false" aria-controls="adminFormula<%= row_index %>" onclick="toggleFormula('adminFormula<%= row_index %>', this)">+</button>
                    <div class="formula-details" id="adminFormula<%= row_index %>">
                      <span class="formula-note"><%= pulse_formula_text(row.dig(:pulse_scores, :total_score)) %></span><br>
                      <span class="formula-note"><strong><%= composite_formula_text(annual_percentage: row[:annual_percentage], pulse_total_score: row.dig(:pulse_scores, :total_score)) %></strong></span>
                    </div>
                  </td>
                  <td><span class="summary-chip total-summary-chip"><%= "#{compact_number(composite_display_total(annual_percentage: row[:annual_percentage], pulse_total_score: row.dig(:pulse_scores, :total_score)))}%" %></span></td>
                </tr>
              <% end %>
            <% elsif @employee_detail.present? %>
              <tr>
                <td><strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong></td>
                <td><span class="summary-chip neutral-summary-chip"><%= compact_number(@annual_percentage) %></span></td>
                <td><span class="summary-chip neutral-summary-chip"><%= compact_number(composite_pulse_percentage) %></span></td>
                <td class="formula-cell">
                  <button type="button" class="formula-toggle" aria-expanded="false" aria-controls="employeeFormula" onclick="toggleFormula('employeeFormula', this)">+</button>
                  <div class="formula-details" id="employeeFormula">
                    <span class="formula-note"><%= pulse_formula_text(@dashboard_pulse_scores[:total_score]) %></span><br>
                    <span class="formula-note"><strong><%= composite_formula_text(annual_percentage: @annual_percentage, pulse_total_score: @dashboard_pulse_scores[:total_score]) %></strong></span>
                  </div>
                </td>
                <td><span class="summary-chip total-summary-chip"><%= "#{compact_number(composite_display_total(annual_percentage: @annual_percentage, pulse_total_score: @dashboard_pulse_scores[:total_score]))}%" %></span></td>
              </tr>
            <% end %>
          </tbody>
          <% if @dashboard_mode == :admin && @employee_rows.any? %>
            <tfoot style="background: rgba(18, 56, 77, 0.05); font-weight: bold; border-top: 2px solid #cbd5e1;">
              <tr>
                <td>TEAM AVERAGE</td>
                <td><span class="summary-chip neutral-summary-chip"><%= compact_number(@employee_rows.sum { |r| r[:annual_percentage].to_f } / @employee_rows.size) %></span></td>
