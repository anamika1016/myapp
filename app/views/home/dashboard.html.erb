      </div>
    </div>

    <% if @dashboard_mode == :admin && @employee_rows.any? %>
      <div class="remarks-panel pulse-remarks-panel" id="pulse-remarks-section">
        <div class="box-header">
          <div>
            <h2>SECTION C: LINE MANAGER FEEDBACK / Weightage : 10%</h2>
            <p>All user manager-feedback scores and remarks shown directly by criteria.</p>
          </div>
          <%= link_to "Export", export_dashboard_section_xlsx_path("remarks", format: :xlsx), class: "section-export-btn" %>
        </div>

        <div class="table-wrap pulse-remarks-wrap">
          <table class="pulse-remarks-table">
            <thead>
              <tr>
                <th>Employee</th>
                <th>Code</th>
                <th>Professionalism & Conduct (1-5)</th>
                <th>Quality & Accuracy of Work Output (1-5)</th>
                <th>Initiative & Problem-Solving (1-5)</th>
                <th>Adherence to PAPL Values & Culture (1-5)</th>
                <th>Cross-functional Collaboration (1-5)</th>
                <th>Time Management & Reliability (1-5)</th>
                <th>Growth Mindset & Development (1-5)</th>
                <th>Mgr Score /10</th>
                <th>Manager Remarks</th>
              </tr>
            </thead>
            <tbody>
              <% @employee_rows.each do |row| %>
                <% criteria = row[:manager_feedback][:criteria] %>
                <tr>
                  <td><strong><%= row[:employee_name] %></strong></td>
                  <td><%= row[:employee_code] %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[0][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[1][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[2][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[3][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[4][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[5][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= criteria[6][:score].presence || "-" %></td>
                  <td class="pulse-remark-score-cell"><%= row[:pulse_assessment_score].present? ? "#{number_with_precision(row[:pulse_assessment_score], precision: 1)}/10" : "-" %></td>
                  <td><%= row[:pulse_assessment_remarks].presence || "-" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% elsif @dashboard_mode != :admin && @employee_detail.present? %>
      <div class="remarks-panel pulse-remarks-panel" id="pulse-remarks-section">
        <div class="box-header">
          <div>
            <h2>LINE MANAGER FEEDBACK / 10%</h2>
            <p>Latest manager feedback remarks and score.</p>
          </div>
          <%= link_to "Export", export_dashboard_section_xlsx_path("remarks", format: :xlsx), class: "section-export-btn" %>
        </div>

        <div class="single-remark-box">
          <div class="pulse-remark-inline">
            <div class="pulse-remark-text">
              <% if @dashboard_pulse_remarks.present? %>
                <p><%= @dashboard_pulse_remarks %></p>
              <% else %>
                <p>&nbsp;</p>
              <% end %>
            </div>

            <div class="pulse-remark-score-box">
              <span>Pulse Remarks Score</span>
              <% if @dashboard_pulse_remark_score.present? %>
                <strong><%= @dashboard_pulse_remark_score %>/10</strong>
              <% else %>
                <strong>&nbsp;</strong>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="remarks-panel summary-panel" id="summary-box-section">
      <div class="box-header">
        <div>
          <h2><i class="fas fa-chart-line"></i> COMPOSITE PERFORMANCE SCORE — KRA 75% + Pulse 15% + Manager Feedback 10%</h2>
          <p>User wise weighted total based on Annually / Weightage : 75%, PULSE-360 ASSESSMENT SCORE / Weightage : 15%, and Manager Feedback / Weightage : 10%.</p>
        </div>
        <%= link_to "Export", export_dashboard_section_xlsx_path("summary", format: :xlsx), class: "section-export-btn" %>
      </div>

      <div class="table-wrap summary-wrap">
        <table class="summary-table">
          <thead>
            <tr>
              <th>User</th>
              <th>SECTION A -KRA %</th>
              <th>SECTION B -Pulse %</th>
              <th>SECTION C -Manager %</th>
              <th>Final Total</th>
            </tr>
          </thead>
          <tbody>
            <% if @dashboard_mode == :admin %>
              <% @employee_rows.each do |row| %>
                <tr>
                  <td><strong><%= row[:employee_name] %></strong></td>
                  <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(row[:annual_percentage], precision: 2) %>%</span></td>
                  <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(row[:pulse_raw_percentage], precision: 2) %>%</span></td>
                  <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(row[:manager_raw_percentage], precision: 2) %>%</span></td>
                  <td><span class="summary-chip total-summary-chip"><%= number_with_precision(row[:summary_scores][:final_total], precision: 2) %>%</span></td>
                </tr>
              <% end %>
            <% elsif @employee_detail.present? %>
              <tr>
                <td><strong><%= @employee_detail&.employee_name.presence || current_user.email %></strong></td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(@annual_percentage, precision: 2) %>%</span></td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(composite_pulse_percentage, precision: 2) %>%</span></td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision(composite_manager_percentage, precision: 2) %>%</span></td>
                <td><span class="summary-chip total-summary-chip"><%= number_with_precision(@dashboard_summary_scores[:final_total], precision: 2) %>%</span></td>
              </tr>
            <% end %>
          </tbody>
          <% if @dashboard_mode == :admin && @employee_rows.any? %>
            <tfoot style="background: rgba(18, 56, 77, 0.05); font-weight: bold; border-top: 2px solid #cbd5e1;">
              <tr>
                <td>TEAM AVERAGE</td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision((@employee_rows.sum { |r| r[:annual_percentage].to_f } / @employee_rows.size), precision: 2) %>%</span></td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision((@employee_rows.sum { |r| r[:pulse_raw_percentage].to_f } / @employee_rows.size), precision: 2) %>%</span></td>
                <td><span class="summary-chip neutral-summary-chip"><%= number_with_precision((@employee_rows.sum { |r| r[:manager_raw_percentage].to_f } / @employee_rows.size), precision: 2) %>%</span></td>
                <td><span class="summary-chip total-summary-chip"><%= number_with_precision((@employee_rows.sum { |r| r[:summary_scores][:final_total].to_f } / @employee_rows.size), precision: 2) %>%</span></td>
              </tr>
            </tfoot>
          <% end %>
        </table>
      </div>
    </div>
    <% end %>
  </div>
</div>

