<script>
  function toggleFormula(targetId, button) {
    const target = document.getElementById(targetId);
    if (!target) return;

    const isOpen = target.classList.toggle("is-open");
    button.textContent = isOpen ? "-" : "+";
    button.setAttribute("aria-expanded", isOpen.toString());
  }

  (function() {
    const timeNode = document.getElementById("dashboardTime");
    const secondsNode = document.getElementById("dashboardSeconds");
    const dateNode = document.getElementById("dashboardDate");
    const greetingNode = document.getElementById("dashboardGreeting");
    const meridiemNode = document.getElementById("dashboardMeridiem");

    if (!timeNode || !secondsNode || !dateNode || !greetingNode || !meridiemNode) return;

    function updateDashboardClock() {
      const now = new Date();
      const hour = now.getHours();

      let greeting = "Good Evening";
      if (hour < 12) {
        greeting = "Good Morning";
      } else if (hour < 17) {
        greeting = "Good Afternoon";
      }

      timeNode.textContent = now.toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
        hour12: true
      }).replace(/\s?(AM|PM)$/i, "");

      meridiemNode.textContent = now.toLocaleTimeString([], {
        hour: "2-digit",
        hour12: true
      }).replace(/^\d+\s?/g, "");

      secondsNode.textContent = ":" + now.toLocaleTimeString([], {
        second: "2-digit"
      });

      dateNode.textContent = now.toLocaleDateString([], {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric"
      });

      greetingNode.textContent = greeting;
    }

    updateDashboardClock();
    setInterval(updateDashboardClock, 1000);
  })();
</script>
