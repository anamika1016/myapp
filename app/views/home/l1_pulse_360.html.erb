<script>
  (function() {
    function getCategory(total) {
      if (total > 23) return { stars: "★★★★★", category: "Exceptional", action: "Accelerated growth track / highest increment", className: "stars-5" };
      if (total >= 19) return { stars: "★★★★", category: "Outstanding", action: "Merit increment / recognition award", className: "stars-4" };
      if (total >= 15) return { stars: "★★★", category: "Meets Expectations", action: "Standard increment as per policy", className: "stars-3" };
      if (total >= 11) return { stars: "★★", category: "Needs Improvement", action: "PIP / structured coaching plan", className: "stars-2" };
      return { stars: "★", category: "Unsatisfactory", action: "Formal PIP / disciplinary review", className: "stars-1" };
    }

    function updateRow(rowId) {
      const rowB = document.querySelector(`.pulse-input-row[data-employee-id="${rowId}"]`);

      if (rowB) {
        let pTotal = 0;
        let hasPulseScores = false;
        rowB.querySelectorAll("[data-pulse-score]").forEach(i => {
          if (i.value) {
            hasPulseScores = true;
            pTotal += parseFloat(i.value);
          }
        });
        rowB.querySelector("[data-pulse-raw-total]").textContent = hasPulseScores ? (Number.isInteger(pTotal) ? String(pTotal) : pTotal.toFixed(1)) : "";
        rowB.querySelector("[data-pulse-weighted]").textContent = hasPulseScores ? Math.round((pTotal / 25.0) * 25.0) + "%" : "0%";

        const starsNode = rowB.querySelector("[data-pulse-stars]");
        const categoryNode = rowB.querySelector("[data-pulse-category-name]");
        const actionNode = rowB.querySelector("[data-pulse-action]");

        if (hasPulseScores) {
          const cat = getCategory(pTotal);
          starsNode.textContent = cat.stars;
          starsNode.className = "stars " + cat.className;
          categoryNode.textContent = cat.category;
          actionNode.textContent = cat.action;
        } else {
          starsNode.textContent = "";
          starsNode.className = "stars";
          categoryNode.textContent = "";
          actionNode.textContent = "";
        }
      }
    }

    document.querySelectorAll(".pulse-input").forEach(input => {
      input.addEventListener("input", function() {
        const rowId = this.closest("tr").dataset.employeeId;
        updateRow(rowId);
      });
    });
  })();
</script>
