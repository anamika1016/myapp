<div class="main-content l1-pulse-page min-h-screen">
  <div class="l1-pulse-shell">
    <div class="l1-pulse-header-card">
      <div class="l1-pulse-hero-copy">
        <span class="l1-pulse-kicker">L1 Dashboard</span>
        <h1>L1 Assessment (Pulse-360)</h1>
        <p>
          PULSE-360 assessment contributes 25% to the final review block.
        </p>
        <div class="l1-pulse-chip-row">
          <span class="l1-pulse-chip chip-kra">KRA 75%</span>
          <span class="l1-pulse-chip chip-pulse">Pulse 25%</span>
          <span class="l1-pulse-chip chip-total">Composite 100%</span>
        </div>
      </div>

      <div class="l1-pulse-header-stats">
        <div class="l1-pulse-mini-stat stat-employees">
          <span>Total Employees</span>
          <strong><%= @pulse_rows.size %></strong>
          <small>Active review list</small>
        </div>
        <div class="l1-pulse-mini-stat stat-pulse">
          <span>Pulse Weight</span>
          <strong>25%</strong>
          <small>Section B contribution</small>
        </div>
        <div class="l1-pulse-mini-stat stat-total">
          <span>Review Block</span>
          <strong>25%</strong>
          <small>Pulse contribution</small>
        </div>
      </div>
    </div>

    <% if @pulse_rows.any? %>
      <%= form_with url: save_l1_pulse_360_path, method: :patch, local: true do %>
        <% if @pulse_error_message.present? %>
          <div class="l1-pulse-alert error"><%= @pulse_error_message %></div>
        <% end %>

        <%# SCORE GUIDE %>
        <div class="l1-pulse-card score-guide-card">
          <div class="l1-pulse-card-header">
            <h2>PULSE-360 ASSESSMENT SCORE GUIDE</h2>
          </div>
          <div class="guide-table-wrap">
            <table class="guide-table">
              <thead>
                <tr>
                  <th>Total / 25 Range</th>
                  <th>Band</th>
                  <th>Rating</th>
                  <th>Recommended Action</th>
                </tr>
              </thead>
              <tbody>
                <% score_range_rows.each do |row| %>
                  <tr class="guide-row guide-row-<%= row[:rating_value] %>">
                    <td><%= row[:score_range] %></td>
                    <td><strong class="rating-band rating-band-<%= row[:rating_value] %>"><%= row[:band] %></strong></td>
                    <td><span class="rating-pill rating-pill-<%= row[:rating_value] %>"><%= row[:rating_value] %> (<%= row[:stars] %>)</span></td>
                    <td><%= row[:action] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <%# SECTION B: PULSE-360 %>
        <div class="l1-pulse-card glass-panel">
          <div class="l1-pulse-card-header">
            <span class="section-tag pulse-tag">Section B</span>
            <h2>PULSE-360 SURVEY SCORE (Weightage : 25%)</h2>
            <p>Please provide scores (1-5) under the five Section B headings. Category will update dynamically.</p>
          </div>

          <div class="l1-pulse-table-wrap">
            <table class="l1-pulse-table pulse-theme-table">
              <thead>
                <tr>
                  <th class="sticky-col">Employee Name</th>
                  <th class="metric-th">Values Alignment</th>
                  <th class="metric-th">Technical Knowledge</th>
                  <th class="metric-th">Customer &amp; Field Engagement</th>
                  <th class="metric-th">Execution &amp; Accountability</th>
                  <th class="metric-th">Initiative &amp; Leadership</th>
                  <th class="total-col">Total / 25</th>
                  <th class="total-col">Wt % / 25%</th>
                  <th class="remarks-th">Pulse Remarks</th>
                  <th class="category-col">Category & Action</th>
                </tr>
              </thead>
              <tbody>
                <% @pulse_rows.each do |row| %>
                  <% assessment = row[:assessment] %>
                  <% cat = row[:pulse_category] %>
                  <% values_alignment = assessment.values_alignment.present? ? (assessment.values_alignment.to_f % 1 == 0 ? assessment.values_alignment.to_i : assessment.values_alignment) : nil %>
                  <% technical_knowledge = assessment.technical_knowledge.present? ? (assessment.technical_knowledge.to_f % 1 == 0 ? assessment.technical_knowledge.to_i : assessment.technical_knowledge) : nil %>
                  <% customer_field_engagement = assessment.customer_field_engagement.present? ? (assessment.customer_field_engagement.to_f % 1 == 0 ? assessment.customer_field_engagement.to_i : assessment.customer_field_engagement) : nil %>
                  <% execution_accountability = assessment.execution_accountability.present? ? (assessment.execution_accountability.to_f % 1 == 0 ? assessment.execution_accountability.to_i : assessment.execution_accountability) : nil %>
                  <% initiative_leadership = assessment.initiative_leadership.present? ? (assessment.initiative_leadership.to_f % 1 == 0 ? assessment.initiative_leadership.to_i : assessment.initiative_leadership) : nil %>
                  <tr class="pulse-input-row" data-employee-id="<%= row[:employee_detail_id] %>">
                    <td class="staff-name sticky-col">
                      <strong><%= row[:employee_name] %></strong>
                      <small><%= row[:employee_code] %></small>
                    </td>
                    <td><%= number_field_tag "pulse_assessments[#{row[:employee_detail_id]}][values_alignment]", values_alignment, min: 1, max: 5, step: 1, class: "pulse-input pulse-bg-light", data: { pulse_score: true } %></td>
                    <td><%= number_field_tag "pulse_assessments[#{row[:employee_detail_id]}][technical_knowledge]", technical_knowledge, min: 1, max: 5, step: 1, class: "pulse-input pulse-bg-light", data: { pulse_score: true } %></td>
                    <td><%= number_field_tag "pulse_assessments[#{row[:employee_detail_id]}][customer_field_engagement]", customer_field_engagement, min: 1, max: 5, step: 1, class: "pulse-input pulse-bg-light", data: { pulse_score: true } %></td>
                    <td><%= number_field_tag "pulse_assessments[#{row[:employee_detail_id]}][execution_accountability]", execution_accountability, min: 1, max: 5, step: 1, class: "pulse-input pulse-bg-light", data: { pulse_score: true } %></td>
                    <td><%= number_field_tag "pulse_assessments[#{row[:employee_detail_id]}][initiative_leadership]", initiative_leadership, min: 1, max: 5, step: 1, class: "pulse-input pulse-bg-light", data: { pulse_score: true } %></td>
                    <td class="total-cell" data-pulse-raw-total><%= row[:total_score].present? ? (row[:total_score].to_f % 1 == 0 ? row[:total_score].to_i : row[:total_score]) : "" %></td>
                    <td class="total-cell" data-pulse-weighted><%= row[:pulse_weighted].present? ? "#{row[:pulse_weighted].round}%" : "0%" %></td>
                    <td>
                      <%= text_area_tag "pulse_assessments[#{row[:employee_detail_id]}][pulse_remarks]", assessment.pulse_remarks, rows: 1, class: "pulse-remarks-input", placeholder: "Pulse remarks..." %>
                    </td>
                    <td class="category-cell-mini">
                      <div class="cat-action-box <%= cat&.dig(:className) %>-box" data-cat-box>
                        <span class="stars <%= cat&.dig(:className) %>" data-pulse-stars><%= cat&.dig(:stars) %></span>
                        <strong class="rating-band <%= cat&.dig(:className) %>-text" data-pulse-category-name><%= cat&.dig(:category) %></strong>
                        <small data-pulse-action><%= cat&.dig(:action) %></small>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="l1-pulse-save-bar">
          <%= submit_tag "Save All Assessments", class: "l1-pulse-submit-btn" %>
        </div>
      <% end %>

    <% else %>
      <div class="l1-pulse-empty">
        <h2>No assessment records found</h2>
      </div>
    <% end %>
  </div>
</div>

<style>
  :root {
    --l1-sky: #0f5f8c;
    --l1-navy: #12384d;
    --l1-ink: #172534;
    --l1-muted: #617282;
    --l1-border: #d8e6ef;
    --l1-card: rgba(255, 255, 255, 0.96);
    --l1-soft-blue: #e8f5ff;
    --l1-soft-gold: #fff3de;
    --l1-soft-emerald: #e8f8ef;
    --l1-soft-rose: #fff0ee;
  }

  .l1-pulse-page {
    margin-left: 240px;
    padding: 2rem 2rem 2.5rem;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 22%),
      radial-gradient(circle at top right, rgba(251, 191, 36, 0.12), transparent 20%),
      linear-gradient(180deg, #f7fbff 0%, #eef5fa 52%, #e8f1f7 100%);
    font-family: "Segoe UI", "Trebuchet MS", sans-serif;
  }

  .l1-pulse-shell {
    width: 100%;
    margin: 0 auto;
  }

  .l1-pulse-header-card {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.95fr);
    gap: 1.4rem;
    align-items: start;
    padding: 2.25rem;
    margin-bottom: 1.65rem;
    border-radius: 30px;
    border: 1px solid var(--l1-border);
    background:
      radial-gradient(circle at top right, rgba(14, 165, 233, 0.13), transparent 25%),
      linear-gradient(135deg, #ffffff 0%, #f9fcff 56%, #eef7ff 100%);
    box-shadow: 0 22px 42px rgba(15, 23, 42, 0.08);
  }

  .l1-pulse-header-card::before {
    content: "";
    position: absolute;
    inset: auto -90px -110px auto;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 68%);
    pointer-events: none;
  }

  .l1-pulse-hero-copy,
  .l1-pulse-header-stats {
    position: relative;
    z-index: 1;
  }

  .l1-pulse-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #5a7388;
    font-weight: 800;
    font-size: 0.76rem;
  }

  .l1-pulse-header-card h1 {
    margin: 0.4rem 0 0;
    font-size: 2.45rem;
    line-height: 1.08;
    color: var(--l1-navy);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .l1-pulse-header-card p {
    margin: 0.95rem 0 0;
    max-width: 760px;
    color: #4e6274;
    line-height: 1.72;
    font-size: 1rem;
  }

  .l1-pulse-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .l1-pulse-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .chip-kra {
    background: #edf7ef;
    border-color: #cce7d3;
    color: #166534;
  }

  .chip-pulse {
    background: #edf5ff;
    border-color: #c6dcff;
    color: #1d4ed8;
  }

  .chip-manager {
    background: #fff3e3;
    border-color: #f3d4b1;
    color: #b45309;
  }

  .chip-total {
    background: #eff6fb;
    border-color: #d1e0eb;
    color: var(--l1-navy);
  }

  .l1-pulse-header-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .l1-pulse-mini-stat {
    padding: 1rem 1.05rem;
    border-radius: 22px;
    border: 1px solid var(--l1-border);
    background: linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .l1-pulse-mini-stat span {
    display: block;
    color: #64748b;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .l1-pulse-mini-stat strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1.85rem;
    line-height: 1;
    color: var(--l1-navy);
  }

  .l1-pulse-mini-stat small {
    display: block;
    margin-top: 0.4rem;
    color: var(--l1-muted);
    font-size: 0.82rem;
    line-height: 1.4;
  }

  .stat-employees {
    background: linear-gradient(180deg, #ffffff 0%, #f3fbff 100%);
  }

  .stat-pulse {
    background: linear-gradient(180deg, #f3f8ff 0%, #e8f1ff 100%);
  }

  .stat-manager {
    background: linear-gradient(180deg, #fffaf2 0%, #fff2dd 100%);
  }

  .stat-total {
    background: linear-gradient(180deg, #f7fff8 0%, #ebf9ef 100%);
  }

  .l1-pulse-alert.error,
  .l1-pulse-empty {
    padding: 1.25rem 1.4rem;
    border-radius: 22px;
    margin-bottom: 1.35rem;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid var(--l1-border);
    box-shadow: 0 18px 28px rgba(15, 23, 42, 0.05);
  }

  .l1-pulse-alert.error {
    border-color: #fecaca;
    background: linear-gradient(180deg, #fff5f5 0%, #fff0f0 100%);
    color: #b91c1c;
    font-weight: 700;
  }

  .l1-pulse-empty {
    text-align: center;
  }

  .l1-pulse-empty h2 {
    margin: 0;
    color: var(--l1-navy);
    font-size: 1.6rem;
  }

  .l1-pulse-card {
    width: 100%;
    margin-bottom: 1.75rem;
    padding: 1.9rem;
    border-radius: 28px;
    border: 1px solid var(--l1-border);
    background: var(--l1-card);
    box-shadow: 0 20px 36px rgba(15, 23, 42, 0.06);
  }

  .score-guide-card {
    background: linear-gradient(180deg, #fbfdff 0%, #f4f9fe 100%);
  }

  .glass-panel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 250, 253, 0.96) 100%);
  }

  .mgr-section {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 242, 0.97) 100%);
  }

  .l1-pulse-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.15rem;
  }

  .l1-pulse-card-header h2 {
    margin: 0;
    font-size: 1.7rem;
    color: var(--l1-navy);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .l1-pulse-card-header p {
    margin: 0;
    color: var(--l1-muted);
    line-height: 1.65;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.55rem;
  }

  .pulse-tag {
    background: #dff2ff;
    color: #1d4ed8;
  }

  .mgr-tag {
    background: #fff0df;
    color: #b45309;
  }

  .guide-table-wrap,
  .l1-pulse-table-wrap {
    overflow: auto;
    width: 100%;
    border-radius: 20px;
    border: 1px solid #dce8f2;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  .guide-table {
    width: 100%;
    min-width: 860px;
    border-collapse: collapse;
  }

  .guide-table th {
    padding: 1rem 1.1rem;
    text-align: left;
    color: var(--l1-sky);
    font-size: 0.76rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: linear-gradient(180deg, #edf7ff 0%, #e0f1ff 100%);
    border-bottom: 1px solid #cfe1ee;
  }

  .guide-table td {
    padding: 1rem 1.1rem;
    border-bottom: 1px solid #e7eef4;
    font-size: 0.95rem;
    color: var(--l1-ink);
    background: rgba(255, 255, 255, 0.96);
  }

  .guide-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .guide-row td:first-child {
    font-weight: 700;
  }

  .guide-row-5 td:first-child {
    box-shadow: inset 4px 0 0 #f59e0b;
  }

  .guide-row-4 td:first-child {
    box-shadow: inset 4px 0 0 #fb923c;
  }

  .guide-row-3 td:first-child {
    box-shadow: inset 4px 0 0 #3b82f6;
  }

  .guide-row-2 td:first-child {
    box-shadow: inset 4px 0 0 #8b5cf6;
  }

  .guide-row-1 td:first-child {
    box-shadow: inset 4px 0 0 #ef4444;
  }

  .guide-row-5 td {
    background: linear-gradient(90deg, rgba(251, 191, 36, 0.07), rgba(255, 255, 255, 0.95));
  }

  .guide-row-4 td {
    background: linear-gradient(90deg, rgba(251, 146, 60, 0.06), rgba(255, 255, 255, 0.95));
  }

  .guide-row-3 td {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.05), rgba(255, 255, 255, 0.95));
  }

  .guide-row-2 td {
    background: linear-gradient(90deg, rgba(139, 92, 246, 0.05), rgba(255, 255, 255, 0.95));
  }

  .guide-row-1 td {
    background: linear-gradient(90deg, rgba(239, 68, 68, 0.05), rgba(255, 255, 255, 0.95));
  }

  .l1-pulse-table {
    width: 100%;
    min-width: 1480px;
    border-collapse: collapse;
  }

  .l1-pulse-table th {
    padding: 0.9rem 0.65rem;
    font-size: 0.73rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #436174;
    background: #f8fbfd;
    border-bottom: 1px solid #dbe7ef;
  }

  .pulse-theme-table th {
    background: linear-gradient(180deg, #ecf6ff 0%, #deefff 100%);
    color: #1d4ed8;
    border-bottom-color: #bfdcff;
  }

  .pulse-theme-table .metric-th {
    min-width: 145px;
    white-space: normal;
    text-transform: none;
    letter-spacing: 0.02em;
    line-height: 1.35;
  }

  .mgr-theme-table th {
    background: linear-gradient(180deg, #fff5e7 0%, #ffe8cb 100%) !important;
    color: #b45309 !important;
    border-bottom-color: #f6d8b7 !important;
  }

  .l1-pulse-table td {
    padding: 0.85rem 0.6rem;
    text-align: center;
    vertical-align: middle;
    color: var(--l1-ink);
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid #e8eef3;
  }

  .l1-pulse-table tbody tr:nth-child(even) td {
    background: rgba(247, 250, 252, 0.98);
  }

  .l1-pulse-table tbody tr:hover td {
    background: rgba(238, 246, 251, 0.98);
  }

  .sticky-col {
    position: sticky;
    left: 0;
    z-index: 2;
    min-width: 220px;
    text-align: left !important;
    border-right: 1px solid #dce8f2 !important;
    background: linear-gradient(180deg, #ffffff 0%, #f8fbfe 100%) !important;
    box-shadow: 10px 0 18px rgba(15, 23, 42, 0.05);
  }

  .staff-name strong {
    display: block;
    font-size: 1rem;
    color: #142f42;
    white-space: nowrap;
  }

  .staff-name small {
    display: block;
    margin-top: 0.3rem;
    color: #728396;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pulse-input {
    width: 64px;
    padding: 0.68rem 0.45rem;
    border-radius: 14px;
    border: 1px solid #cad8e3;
    text-align: center;
    font-weight: 800;
    font-size: 1.05rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .pulse-input:hover {
    border-color: #95b9d4;
    transform: translateY(-1px);
  }

  .pulse-input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.14);
  }

  .pulse-bg-light {
    background: linear-gradient(180deg, #f4fbff 0%, #e7f4ff 100%);
    color: #0f5f8c;
  }

  .mgr-bg-light {
    background: linear-gradient(180deg, #fffaf1 0%, #fff0dc 100%);
    color: #9a4f0f;
  }

  .total-col {
    min-width: 110px;
  }

  .total-cell,
  .mgr-raw-cell {
    font-weight: 900;
    font-size: 1.2rem;
  }

  .total-cell {
    color: #0f5f8c;
    background: linear-gradient(180deg, #edf8ff 0%, #dff1ff 100%) !important;
  }

  .mgr-raw-cell {
    color: #9a3412;
    background: linear-gradient(180deg, #fff7ed 0%, #ffe9d4 100%) !important;
  }

  .category-col,
  .category-cell-mini {
    min-width: 330px;
  }

  .cat-action-box {
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid #dbe7ef;
    background: linear-gradient(180deg, #ffffff 0%, #f7fbfe 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.95);
    text-align: left;
  }

  .stars-5-box {
    border-color: #f8d48c;
    background: linear-gradient(180deg, #fff8e8 0%, #ffefc3 100%);
  }

  .stars-4-box {
    border-color: #fec89a;
    background: linear-gradient(180deg, #fff5ec 0%, #ffe1c7 100%);
  }

  .stars-3-box {
    border-color: #a9c9ff;
    background: linear-gradient(180deg, #f2f7ff 0%, #dbeafe 100%);
  }

  .stars-2-box {
    border-color: #d1b8ff;
    background: linear-gradient(180deg, #f7f2ff 0%, #ece2ff 100%);
  }

  .stars-1-box {
    border-color: #ffc1c1;
    background: linear-gradient(180deg, #fff1f1 0%, #ffe0e0 100%);
  }

  .rating-band,
  .rating-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 800;
  }

  .rating-pill {
    font-size: 0.9rem;
    font-weight: 800;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.38);
  }

  .cat-action-box strong {
    display: block;
    margin: 0.35rem 0 0.2rem;
    font-size: 1rem;
    color: var(--l1-navy);
  }

  .cat-action-box small {
    display: block;
    color: var(--l1-muted);
    font-size: 0.82rem;
    line-height: 1.5;
