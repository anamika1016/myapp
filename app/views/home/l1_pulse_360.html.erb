<script>
  (function() {
    function getCategory(total) {
      if (total >= 45) return { stars: "★★★★★", category: "Outstanding", action: "Accelerated growth track / highest increment", className: "stars-5" };
      if (total >= 38) return { stars: "★★★★", category: "Exceeds Expectations", action: "Merit increment + recognition award", className: "stars-4" };
      if (total >= 30) return { stars: "★★★", category: "Meets Expectations", action: "Standard increment as per policy", className: "stars-3" };
      if (total >= 23) return { stars: "★★", category: "Needs Improvement", action: "PIP + structured coaching plan", className: "stars-2" };
      return { stars: "★", category: "Unsatisfactory", action: "Formal PIP / disciplinary review", className: "stars-1" };
    }

    function updateRow(rowId) {
      const rowB = document.querySelector(`.pulse-input-row[data-employee-id="${rowId}"]`);
      const rowC = document.querySelector(`.mgr-input-row[data-employee-id="${rowId}"]`);
      
      if (rowB) {
        let pTotal = 0;
        rowB.querySelectorAll("[data-pulse-score]").forEach(i => { if(i.value) pTotal += parseInt(i.value); });
        rowB.querySelector("[data-pulse-total]").textContent = (pTotal > 0 ? ((pTotal/50.0)*15.0).toFixed(2) : "0.00");
        
        const cat = getCategory(pTotal);
        rowB.querySelector("[data-pulse-stars]").textContent = cat.stars;
        rowB.querySelector("[data-pulse-stars]").className = "stars " + cat.className;
        rowB.querySelector("[data-pulse-category-name]").textContent = cat.category;
        rowB.querySelector("[data-pulse-action]").textContent = cat.action;
      }

      if (rowC) {
        let mgrWeighted = 0;
        let hasMgr = false;
        rowC.querySelectorAll("[data-manager-score]").forEach(i => {
          if(i.value) {
            hasMgr = true;
            mgrWeighted += (parseInt(i.value)/5.0) * parseFloat(i.dataset.weight);
          }
        });
        rowC.querySelector("[data-mgr-raw]").textContent = (hasMgr ? (mgrWeighted * 0.10).toFixed(2) : "0.00") + "%";
      }
    }

    document.querySelectorAll(".pulse-input").forEach(input => {
      input.addEventListener("input", function() {
        const rowId = this.closest("tr").dataset.employeeId;
        updateRow(rowId);
      });
    });
  })();
</script>
